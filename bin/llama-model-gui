#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
APP_TITLE="LLM Model Manager"
APP_BYLINE="Local Runtime Control"
DEFAULT_LLAMA_MODEL_WEB_BIN="$SCRIPT_DIR/llama-model-web"
if [[ ! -x "$DEFAULT_LLAMA_MODEL_WEB_BIN" ]] && command -v llama-model-web >/dev/null 2>&1; then
    DEFAULT_LLAMA_MODEL_WEB_BIN="$(command -v llama-model-web)"
fi
DEFAULT_LLAMA_MODEL_BIN="$SCRIPT_DIR/llama-model"
if [[ ! -x "$DEFAULT_LLAMA_MODEL_BIN" ]] && command -v llama-model >/dev/null 2>&1; then
    DEFAULT_LLAMA_MODEL_BIN="$(command -v llama-model)"
fi

LLAMA_MODEL_BIN="${LLAMA_MODEL_BIN:-$DEFAULT_LLAMA_MODEL_BIN}"
CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/llama-server"
MODELS_FILE="${LLAMA_MODELS_FILE:-$CONFIG_DIR/models.tsv}"
DEFAULTS_FILE="${LLAMA_DEFAULTS_FILE:-$CONFIG_DIR/defaults.env}"
HELP_FILE="${LLAMA_HELP_FILE:-$CONFIG_DIR/HELP.txt}"
detect_terminal() {
    if [[ -n "${TERMINAL_BIN:-}" ]]; then
        command -v "$TERMINAL_BIN" && return 0
    fi
    local candidate
    for candidate in x-terminal-emulator gnome-terminal konsole xfce4-terminal mate-terminal lxterminal alacritty kitty xterm; do
        if command -v "$candidate" >/dev/null 2>&1; then
            command -v "$candidate"
            return 0
        fi
    done
    return 1
}
TERMINAL_BIN="$(detect_terminal || true)"

if [[ "${LLAMA_MODEL_UI:-web}" != "zenity" ]] && [[ -x "$DEFAULT_LLAMA_MODEL_WEB_BIN" ]] && command -v python3 >/dev/null 2>&1; then
    exec "$DEFAULT_LLAMA_MODEL_WEB_BIN" "$@"
fi

die() {
    zenity --error --title="$APP_TITLE" --text="$*"
    exit 1
}

[[ -x "$LLAMA_MODEL_BIN" ]] || die "Missing llama-model helper: $LLAMA_MODEL_BIN"
command -v zenity >/dev/null 2>&1 || {
    printf 'zenity is required for llama-model-gui\n' >&2
    exit 1
}

show_text() {
    local title="$1"
    local body="$2"
    local tmp

    tmp="$(mktemp)" || die "Failed to create temp file"
    trap 'rm -f "$tmp"' EXIT
    printf '%s\n' "$body" >"$tmp"
    zenity --text-info --title="$title" --width=980 --height=720 --filename="$tmp"
    rm -f "$tmp"
    trap - EXIT
}

open_terminal_cmd() {
    local title="$1"
    local cmd="$2"
    local escaped_title
    local term_base

    [[ -n "$TERMINAL_BIN" ]] || die "No terminal emulator found"

    printf -v escaped_title '%q' "$title"
    term_base="$(basename "$TERMINAL_BIN")"
    case "$term_base" in
        gnome-terminal)
            "$TERMINAL_BIN" -- bash -lc "printf '%s\n\n' $escaped_title; $cmd; status=\$?; printf '\nExit status: %s\n' \"\$status\"; printf 'Press Enter to close...'; read -r; exit \$status"
            ;;
        *)
            "$TERMINAL_BIN" -e bash -lc "printf '%s\n\n' $escaped_title; $cmd; status=\$?; printf '\nExit status: %s\n' \"\$status\"; printf 'Press Enter to close...'; read -r; exit \$status"
            ;;
    esac
}

show_current() {
    show_text "Current Model & Gateway" "$("$LLAMA_MODEL_BIN" status 2>/dev/null || "$LLAMA_MODEL_BIN" current)"
}

menu_status_text() {
    local status_out
    local alias
    local health
    local mode
    local gw_max

    status_out="$("$LLAMA_MODEL_BIN" status 2>/dev/null || "$LLAMA_MODEL_BIN" current 2>/dev/null || true)"
    alias="$(printf '%s\n' "$status_out" | awk -F': ' '/^alias:/ { print $2; exit }')"
    health="$(printf '%s\n' "$status_out" | awk -F': ' '/^health:/ { print $2; exit }')"
    mode="$(printf '%s\n' "$status_out" | awk -F': ' '/^active_mode:/ { print $2; exit }')"
    gw_max="$(printf '%s\n' "$status_out" | awk -F': ' '/^gateway_max_context:/ { print $2; exit }')"

    [[ -n "$alias" ]] || alias="stopped"
    [[ -n "$health" ]] || health="unavailable"
    [[ -n "$mode" ]] || mode="stopped"

    local summary="Model: $alias  Mode: $mode  Health: $health"
    if [[ -n "$gw_max" ]]; then
        local gw_safety gw_allowed gw_mode
        gw_safety="$(printf '%s\n' "$status_out" | awk -F': ' '/^gateway_safety_margin:/ { print $2; exit }')"
        gw_allowed="$(printf '%s\n' "$status_out" | awk -F': ' '/^gateway_allowed_prompt:/ { print $2; exit }')"
        gw_mode="$(printf '%s\n' "$status_out" | awk -F': ' '/^gateway_overflow_mode:/ { print $2; exit }')"
        summary="$summary"$'\n'"Budget: max=$gw_max margin=$gw_safety allowed=$gw_allowed mode=$gw_mode"
    fi
    printf '%s' "$summary"
}

show_list() {
    if [[ ! -f "$MODELS_FILE" ]]; then
        local _msg
        printf -v _msg 'No registry file exists yet at:\n\n%s\n\nSave a model from the web dashboard or create entries with:\n  llama-model add <alias> <path>' "$MODELS_FILE"
        show_text "Registered Models" "$_msg"
        return 0
    fi
    show_text "Registered Models" "$("$LLAMA_MODEL_BIN" list)"
}

show_logs() {
    local lines
    local cmd

    lines="$(zenity --entry --title="Llama Logs" --text="How many log lines should be shown?" --entry-text="40")" || return 0
    [[ "$lines" =~ ^[0-9]+$ ]] || die "Log lines must be a number"
    (( lines >= 1 && lines <= 5000 )) || die "Log lines must be between 1 and 5000"
    printf -v cmd '%q logs %q' "$LLAMA_MODEL_BIN" "$lines"
    open_terminal_cmd "Llama Server Logs" "$cmd"
}

select_model() {
    local current_alias=""
    local alias
    local path
    local extra
    local context
    local selected
    local -a args

    if [[ ! -f "$MODELS_FILE" ]]; then
        die "No registry file exists yet: $MODELS_FILE"
    fi

    current_alias="$("$LLAMA_MODEL_BIN" current 2>/dev/null | awk -F': ' '/^alias:/ {print $2}' || true)"
    args=(
        --list
        --radiolist
        --title="Switch Llama Model"
        --width=1100
        --height=520
        --column ""
        --column "Alias"
        --column "Model"
        --column "Extra Args"
        --column "Context"
    )

    while IFS=$'\t' read -r alias path extra context _rest; do
        [[ -n "$alias" ]] || continue
        [[ "${alias:0:1}" == "#" ]] && continue
        if [[ "$alias" == "$current_alias" ]]; then
            args+=(TRUE "$alias" "$path" "${extra:-}" "${context:-}")
        else
            args+=(FALSE "$alias" "$path" "${extra:-}" "${context:-}")
        fi
    done <"$MODELS_FILE"

    selected="$(zenity "${args[@]}")" || return 0
    [[ -n "$selected" ]] || return 0

    local cmd
    printf -v cmd '%q switch %q' "$LLAMA_MODEL_BIN" "$selected"
    open_terminal_cmd "Switching To $selected" "$cmd"
}

set_client_mode() {
    local current_mode
    local selected
    local cmd

    current_mode="$("$LLAMA_MODEL_BIN" mode 2>/dev/null | awk -F': ' '/^configured_mode:/ { print $2; exit }' || true)"

    selected="$(
        zenity --list \
            --radiolist \
            --title="Client Mode" \
            --width=760 \
            --height=320 \
            --text="Single Client is safer on this machine. Multi Client restores auto parallel slots." \
            --column "" \
            --column "Mode" \
            --column "Behavior" \
            "$([[ "$current_mode" == "single-client" ]] && printf TRUE || printf FALSE)" "single" "One active client at a time; safer and steadier" \
            "$([[ "$current_mode" == "multi-client" ]] && printf TRUE || printf FALSE)" "multi" "Auto parallel slots; more concurrency, more pressure"
    )" || return 0

    [[ -n "$selected" ]] || return 0

    printf -v cmd '%q set-mode %q --restart' "$LLAMA_MODEL_BIN" "$selected"
    open_terminal_cmd "Applying ${selected^} Client Mode" "$cmd"
}

restart_server() {
    local cmd

    printf -v cmd '%q restart' "$LLAMA_MODEL_BIN"
    open_terminal_cmd "Restarting Llama Server" "$cmd"
}

stop_server() {
    zenity --question --title="Stop Llama Server" --text="Stop the active llama.cpp server?" || return 0

    local cmd
    printf -v cmd '%q stop' "$LLAMA_MODEL_BIN"
    open_terminal_cmd "Stopping Llama Server" "$cmd"
}

ensure_editable_file() {
    local path="$1"
    mkdir -p "$(dirname "$path")"
    if [[ ! -e "$path" ]]; then
        if [[ "$(basename "$path")" == "models.tsv" ]]; then
            printf '# alias\tmodel_path\textra_args\tcontext\n' >"$path"
        else
            : >"$path"
        fi
    fi
}

open_file() {
    local path="$1"

    if command -v xdg-open >/dev/null 2>&1; then
        xdg-open "$path" >/dev/null 2>&1 &
    else
        local cmd
        printf -v cmd '%q %q' "${EDITOR:-nano}" "$path"
        open_terminal_cmd "Open $path" "$cmd"
    fi
}

show_help() {
    if [[ -f "$HELP_FILE" ]]; then
        zenity --text-info --title="$APP_TITLE Help" --width=980 --height=720 --filename="$HELP_FILE"
    else
        show_text "$APP_TITLE Help" "No help file found at:

$HELP_FILE

Useful commands:
  llama-model current          — show running model, gateway, and health
  llama-model list             — show registered model aliases
  llama-model switch <alias>   — switch to another model
  llama-model add <alias> <path> --context N  — register a model
  llama-model gateway start    — start the LMM gateway
  llama-model status           — show full status including context budget"
    fi
}

main_menu() {
    zenity --list \
        --title="$APP_TITLE" \
        --width=760 \
        --height=520 \
        --text="$APP_BYLINE"$'\n\n'"$(menu_status_text)" \
        --column "Action" \
        --column "Description" \
        "Status" "Show model, gateway context budget, and health" \
        "List" "Show registered model aliases" \
        "Switch" "Pick a model and restart the server" \
        "Client Mode" "Toggle single-client safer mode vs multi-client auto slots" \
        "Restart" "Restart the current model with the current defaults" \
        "Logs" "Open recent server logs in a terminal" \
        "Stop" "Stop the active llama.cpp server" \
        "Registry" "Open models.tsv for editing" \
        "Defaults" "Open defaults.env for runtime tuning" \
        "Help" "Show commands and registry format" \
        "Exit" "Close the manager"
}

while true; do
    choice="$(main_menu)" || exit 0
    case "$choice" in
        Status) show_current ;;
        List) show_list ;;
        Switch) select_model ;;
        "Client Mode") set_client_mode ;;
        Restart) restart_server ;;
        Logs) show_logs ;;
        Stop) stop_server ;;
        Registry) ensure_editable_file "$MODELS_FILE"; open_file "$MODELS_FILE" ;;
        Defaults) ensure_editable_file "$DEFAULTS_FILE"; open_file "$DEFAULTS_FILE" ;;
        Help) show_help ;;
        Exit) exit 0 ;;
    esac
done
