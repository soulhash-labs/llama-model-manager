#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
APP_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
INSTALLED_APP_ROOT="${XDG_DATA_HOME:-$HOME/.local/share}/llama-model-manager"
if [[ ! -d "$APP_ROOT/web" ]] && [[ -d "$INSTALLED_APP_ROOT" ]]; then
    APP_ROOT="$INSTALLED_APP_ROOT"
fi

DEFAULT_LLAMA_SERVER_BIN="$HOME/.local/bin/llama-server"
if command -v llama-server >/dev/null 2>&1; then
    DEFAULT_LLAMA_SERVER_BIN="$(command -v llama-server)"
fi

CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/llama-server"
STATE_DIR="${XDG_STATE_HOME:-$HOME/.local/state}/llama-server"
DEFAULTS_FILE="${LLAMA_DEFAULTS_FILE:-$CONFIG_DIR/defaults.env}"
MODELS_FILE="${LLAMA_MODELS_FILE:-$CONFIG_DIR/models.tsv}"
STATE_FILE="${LLAMA_STATE_FILE:-$STATE_DIR/current.env}"
LLAMA_SERVER_RUNTIME_DIR="${LLAMA_SERVER_RUNTIME_DIR:-$APP_ROOT/runtime}"
LLAMA_CPP_REPO_URL="${LLAMA_CPP_REPO_URL:-https://github.com/ggml-org/llama.cpp.git}"
LLAMA_CPP_REF="${LLAMA_CPP_REF:-b8851}"

LLAMA_SERVER_BIN="$DEFAULT_LLAMA_SERVER_BIN"
LLAMA_SERVER_HOST="127.0.0.1"
LLAMA_SERVER_PORT="8081"
LLAMA_SERVER_DEVICE=""
LLAMA_SERVER_CONTEXT="128000"
LLAMA_SERVER_NGL="999"
LLAMA_SERVER_BATCH="128"
LLAMA_SERVER_THREADS="16"
LLAMA_SERVER_PARALLEL=""
LLAMA_SERVER_LOG="$HOME/models/llama-server.log"
LLAMA_SERVER_WAIT_SECONDS="300"
LLAMA_SERVER_EXTRA_ARGS=""

DASHBOARD_SERVICE_NAME="llama-model-web.service"
DASHBOARD_SERVICE_UNIT_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/systemd/user"
DASHBOARD_SERVICE_UNIT_FILE="$DASHBOARD_SERVICE_UNIT_DIR/$DASHBOARD_SERVICE_NAME"
DASHBOARD_SERVICE_INSTALLED_BIN="$HOME/.local/bin/llama-model-web"
DASHBOARD_SERVICE_HOST="${LLAMA_MODEL_WEB_HOST:-127.0.0.1}"
DASHBOARD_SERVICE_PORT="${LLAMA_MODEL_WEB_PORT:-8765}"
DASHBOARD_SERVICE_URL="http://${DASHBOARD_SERVICE_HOST}:${DASHBOARD_SERVICE_PORT}/"
OPENCODE_CONFIG_FILE="${OPENCODE_CONFIG_FILE:-${XDG_CONFIG_HOME:-$HOME/.config}/opencode/opencode.json}"
OPENCODE_MODEL_STATE_FILE="${OPENCODE_MODEL_STATE_FILE:-${XDG_STATE_HOME:-$HOME/.local/state}/opencode/model.json}"
OPENCLAW_PROFILE="${OPENCLAW_PROFILE:-}"
OPENCLAW_API_KEY="${OPENCLAW_API_KEY:-llama-local}"
CLAUDE_SETTINGS_FILE="${CLAUDE_SETTINGS_FILE:-$HOME/.claude/settings.json}"
CLAUDE_GATEWAY_HOST="${CLAUDE_GATEWAY_HOST:-127.0.0.1}"
CLAUDE_GATEWAY_PORT="${CLAUDE_GATEWAY_PORT:-4000}"
CLAUDE_GATEWAY_LOG="${CLAUDE_GATEWAY_LOG:-$HOME/models/claude-gateway.log}"
CLAUDE_GATEWAY_UPSTREAM_TIMEOUT_SECONDS="${CLAUDE_GATEWAY_UPSTREAM_TIMEOUT_SECONDS:-1800}"
CLAUDE_GATEWAY_PID_FILE="${CLAUDE_GATEWAY_PID_FILE:-$STATE_DIR/claude-gateway.pid}"
CLAUDE_BASE_URL="${CLAUDE_BASE_URL:-}"
CLAUDE_MODEL_ID="${CLAUDE_MODEL_ID:-}"
CLAUDE_AUTH_TOKEN="${CLAUDE_AUTH_TOKEN:-}"
CLAUDE_API_KEY="${CLAUDE_API_KEY:-}"
GLYPHOS_CONFIG_FILE="${GLYPHOS_CONFIG_FILE:-$HOME/.glyphos/config.yaml}"
GLYPHOS_LLAMACPP_TIMEOUT_SECONDS="${GLYPHOS_LLAMACPP_TIMEOUT_SECONDS:-300}"

if [[ -f "$DEFAULTS_FILE" ]]; then
    # User-tunable runtime defaults live here, not in the wrapper itself.
    # shellcheck disable=SC1090
    source "$DEFAULTS_FILE"
fi

REQUESTED_LLAMA_SERVER_BIN="${LLAMA_SERVER_BIN:-}"
mkdir -p "$STATE_DIR"

SELECTED_LLAMA_SERVER_BIN=""
SELECTED_LLAMA_SERVER_SOURCE=""
SELECTED_LLAMA_SERVER_BACKEND=""
SELECTED_LLAMA_SERVER_STATUS=""
SELECTED_LLAMA_SERVER_MESSAGE=""
SELECTED_LLAMA_SERVER_GUIDANCE=""
SELECTED_LLAMA_SERVER_HOST_OS=""
SELECTED_LLAMA_SERVER_HOST_ARCH=""
SELECTED_LLAMA_SERVER_HOST_BACKENDS=""
SELECTED_LLAMA_SERVER_LABEL=""
SELECTED_LLAMA_SERVER_BUNDLE_MANIFEST=""
SELECTED_LLAMA_SERVER_PATH_KIND=""
BUNDLE_VALIDATE_REASON=""
BUNDLE_VALIDATE_BACKEND=""
BUNDLE_VALIDATE_LABEL=""
BUNDLE_VALIDATE_MANIFEST=""
EXTERNAL_VALIDATE_REASON=""
BUNDLED_SELECTION_FAILURE_REASON=""

usage() {
    cat <<'EOF'
Usage:
  llama-model list
  llama-model show <alias>
  llama-model add <alias> <path> [--mmproj <path>] [--extra "<args>"] [--context N] [--ngl N] [--batch N] [--threads N] [--parallel auto|N] [--device NAME] [--notes TEXT]
  llama-model remove <alias>
  llama-model discover [root]
  llama-model current
  llama-model doctor
  llama-model build-runtime [--backend auto|cpu|cuda|vulkan|metal] [--ref REF]
  llama-model mode
  llama-model set-mode <single|multi> [--restart]
  llama-model switch <alias|/path/to/model.gguf> [extra llama-server args...]
  llama-model restart [alias|/path/to/model.gguf] [extra llama-server args...]
  llama-model sync-opencode [--preset balanced|long-run] [alias|/path/to/model.gguf]
  llama-model sync-openclaw [--profile NAME] [alias|/path/to/model.gguf]
  llama-model sync-claude [model-id]
  llama-model sync-glyphos [alias|/path/to/model.gguf]
  llama-model claude-gateway start|stop|restart|status|logs
  llama-model stop
  llama-model logs [lines]
  llama-model dashboard-service install|enable|disable|start|stop|restart|status|logs|uninstall

Examples:
  llama-model list
  llama-model show gemma4-e4b-q8
  llama-model add gemma4-e4b-q8 /models/Gemma-4-E4B-Q8_K_P.gguf --mmproj /models/mmproj-Gemma-4-E4B-f16.gguf
  llama-model discover ~/models
  llama-model build-runtime --backend auto
  llama-model mode
  llama-model set-mode single --restart
  llama-model switch qwen35-9b-q8
  llama-model sync-opencode --preset balanced
  llama-model sync-opencode --preset long-run
  llama-model sync-openclaw --profile lmm-eval qwen35-9b-q8
  llama-model sync-claude qwen35-9b-q8
  llama-model claude-gateway start
  llama-model sync-glyphos
  llama-model switch /absolute/path/to/model.gguf --no-warmup
  llama-model dashboard-service status
  llama-model dashboard-service install

Registry format:
  alias<TAB>model_path<TAB>extra_args<TAB>context<TAB>ngl<TAB>batch<TAB>threads<TAB>parallel<TAB>device<TAB>notes

Older 3-column files remain supported.

Notes:
  - Bundled llama.cpp binaries are backend-, platform-, and architecture-specific.
  - llama-model only auto-accepts bundled binaries that pass an explicit compatibility check.
  - If no safe binary is available, run: llama-model build-runtime
  - opencode, OpenClaw, Claude Code, and GlyphOS keep their own client settings.
  - sync-opencode, sync-openclaw, sync-claude, and sync-glyphos align those settings with the active llama-model runtime.
EOF
}

die() {
    printf 'error: %s\n' "$*" >&2
    exit 1
}

timestamp() {
    date +%Y%m%dT%H%M%S
}

iso_timestamp() {
    if date --iso-8601=seconds >/dev/null 2>&1; then
        date --iso-8601=seconds
    else
        date '+%Y-%m-%dT%H:%M:%S%z'
    fi
}

ensure_models_file() {
    mkdir -p "$CONFIG_DIR"
    if [[ ! -f "$MODELS_FILE" ]]; then
        cat >"$MODELS_FILE" <<'EOF'
# alias<TAB>model_path<TAB>extra_args<TAB>context<TAB>ngl<TAB>batch<TAB>threads<TAB>parallel<TAB>device<TAB>notes
EOF
    fi
}

trim_whitespace() {
    local value="$1"
    value="${value#"${value%%[![:space:]]*}"}"
    value="${value%"${value##*[![:space:]]}"}"
    printf '%s\n' "$value"
}

normalize_os() {
    local raw="${1:-}"
    raw="${raw,,}"
    case "$raw" in
        linux) printf 'linux\n' ;;
        darwin|macos|mac|osx) printf 'darwin\n' ;;
        *) printf '%s\n' "$raw" ;;
    esac
}

normalize_arch() {
    local raw="${1:-}"
    raw="${raw,,}"
    case "$raw" in
        amd64|x86_64) printf 'x86_64\n' ;;
        arm64|aarch64) printf 'arm64\n' ;;
        *) printf '%s\n' "$raw" ;;
    esac
}

detect_host_os() {
    if [[ -n "${LLAMA_HOST_OS:-}" ]]; then
        normalize_os "$LLAMA_HOST_OS"
    else
        normalize_os "$(uname -s)"
    fi
}

detect_host_arch() {
    if [[ -n "${LLAMA_HOST_ARCH:-}" ]]; then
        normalize_arch "$LLAMA_HOST_ARCH"
    else
        normalize_arch "$(uname -m)"
    fi
}

command_available() {
    command -v "$1" >/dev/null 2>&1
}

read_state_file() {
    [[ -f "$STATE_FILE" ]] || return 1
    # shellcheck disable=SC1090
    source "$STATE_FILE"
}

clear_state_file() {
    rm -f "$STATE_FILE"
}

managed_state_pid() {
    if read_state_file && [[ -n "${CURRENT_PID:-}" ]]; then
        if kill -0 "$CURRENT_PID" 2>/dev/null && pid_matches_managed_server "$CURRENT_PID"; then
            printf '%s
' "$CURRENT_PID"
            return 0
        fi
    fi
    return 1
}

pid_command_line() {
    local pid="$1"

    if [[ -r "/proc/$pid/cmdline" ]]; then
        tr '\0' ' ' <"/proc/$pid/cmdline"
        return 0
    fi

    ps -o command= -p "$pid" 2>/dev/null || true
}

pid_matches_managed_server() {
    local pid="$1"
    local cmdline

    cmdline="$(pid_command_line "$pid")"
    [[ -n "$cmdline" ]] || return 1
    [[ "$cmdline" == *llama-server* ]] || return 1
    [[ "$cmdline" == *"--port ${LLAMA_SERVER_PORT}"* ]] || return 1
    return 0
}

state_value() {
    local key="$1"

    read_state_file || return 1
    case "$key" in
        -m) printf '%s\n' "${CURRENT_MODEL:-}" ;;
        -c) printf '%s\n' "${CURRENT_CONTEXT:-}" ;;
        -ngl) printf '%s\n' "${CURRENT_NGL:-}" ;;
        -b) printf '%s\n' "${CURRENT_BATCH:-}" ;;
        --threads) printf '%s\n' "${CURRENT_THREADS:-}" ;;
        --device) printf '%s\n' "${CURRENT_DEVICE:-}" ;;
        -np) printf '%s\n' "${CURRENT_PARALLEL:-}" ;;
        *) return 1 ;;
    esac
}

port_is_listening() {
    if command_available ss; then
        ss -ltn "( sport = :$LLAMA_SERVER_PORT )" 2>/dev/null | grep -q LISTEN
        return $?
    fi

    if command_available lsof; then
        lsof -nP -iTCP:"$LLAMA_SERVER_PORT" -sTCP:LISTEN >/dev/null 2>&1
        return $?
    fi

    if command_available netstat; then
        netstat -an 2>/dev/null | grep -E "[\.\:]${LLAMA_SERVER_PORT}[[:space:]].*LISTEN" >/dev/null
        return $?
    fi

    return 1
}

split_shell_words() {
    local raw="$1"
    local item
    local -a fallback_words=()

    [[ -n "$raw" ]] || return 0

    if command_available python3; then
        while IFS= read -r -d '' item; do
            printf '%s\0' "$item"
        done < <(
            python3 -c 'import shlex, sys; sys.stdout.buffer.write(b"".join(part.encode("utf-8") + b"\0" for part in shlex.split(sys.argv[1])))' "$raw"
        )
        return 0
    fi

    read -r -a fallback_words <<<"$raw"
    for item in "${fallback_words[@]}"; do
        printf '%s\0' "$item"
    done
}

split_tsv_record() {
    local raw="${1-}"

    if command_available python3; then
        python3 -c '
import sys
parts = sys.argv[1].split("\t")
parts.extend([""] * (10 - len(parts)))
sys.stdout.buffer.write(b"".join(part.encode("utf-8") + b"\0" for part in parts[:10]))
' "$raw"
        return 0
    fi

    # Fallback: shell splitting does not preserve empty tab fields reliably.
    printf '%s\0' "$raw" "" "" "" "" "" "" "" "" ""
}

canonicalize_path() {
    local target="$1"
    local dir
    local base

    if command_available realpath; then
        realpath "$target"
        return 0
    fi

    if [[ -d "$target" ]]; then
        (cd "$target" && pwd -P)
        return 0
    fi

    dir="$(dirname "$target")"
    base="$(basename "$target")"
    (cd "$dir" && printf '%s/%s\n' "$(pwd -P)" "$base")
}

host_has_cuda_runtime() {
    case "${LLAMA_HOST_CUDA_AVAILABLE:-}" in
        1|true|yes) return 0 ;;
        0|false|no) return 1 ;;
    esac

    if command_available nvidia-smi && nvidia-smi -L >/dev/null 2>&1; then
        return 0
    fi
    [[ -e /dev/nvidiactl || -d /proc/driver/nvidia ]] && return 0
    return 1
}

host_has_vulkan_runtime() {
    case "${LLAMA_HOST_VULKAN_AVAILABLE:-}" in
        1|true|yes) return 0 ;;
        0|false|no) return 1 ;;
    esac

    if command_available vulkaninfo && vulkaninfo --summary >/dev/null 2>&1; then
        return 0
    fi
    if command_available ldconfig && ldconfig -p 2>/dev/null | grep -q 'libvulkan\.so'; then
        return 0
    fi
    return 1
}

host_has_metal_runtime() {
    case "${LLAMA_HOST_METAL_AVAILABLE:-}" in
        1|true|yes) return 0 ;;
        0|false|no) return 1 ;;
    esac

    [[ "$(detect_host_os)" == "darwin" ]] || return 1
    if command_available system_profiler; then
        system_profiler SPDisplaysDataType 2>/dev/null | grep -qi 'metal' && return 0
    fi
    return 0
}

detect_host_backends() {
    local normalized=""
    local entry

    if [[ -n "${LLAMA_HOST_BACKENDS:-}" ]]; then
        for entry in ${LLAMA_HOST_BACKENDS//,/ }; do
            entry="$(trim_whitespace "$entry")"
            [[ -n "$entry" ]] || continue
            case "$entry" in
                cpu|cuda|vulkan|metal)
                    if [[ ",$normalized," != *",$entry,"* ]]; then
                        normalized="${normalized:+$normalized,}$entry"
                    fi
                    ;;
            esac
        done
    fi

    if [[ -z "$normalized" ]]; then
        normalized="cpu"
        if host_has_cuda_runtime; then
            normalized+=",cuda"
        fi
        if host_has_vulkan_runtime; then
            normalized+=",vulkan"
        fi
        if host_has_metal_runtime; then
            normalized+=",metal"
        fi
    elif [[ ",$normalized," != *",cpu,"* ]]; then
        normalized="cpu,$normalized"
    fi

    printf '%s\n' "$normalized"
}

host_has_backend() {
    local backend="$1"
    [[ ",$SELECTED_LLAMA_SERVER_HOST_BACKENDS," == *",$backend,"* ]]
}

infer_backend_from_device() {
    local device="${1:-}"
    device="${device,,}"
    case "$device" in
        cuda*) printf 'cuda\n' ;;
        vulkan*|vk*) printf 'vulkan\n' ;;
        metal*) printf 'metal\n' ;;
        *) printf '\n' ;;
    esac
}

cc_to_int() {
    local value="${1:-}"
    local major=0
    local minor=0

    value="${value//[[:space:]]/}"
    IFS='.' read -r major minor <<<"$value"
    major="${major:-0}"
    minor="${minor:-0}"
    printf '%d%02d\n' "$major" "$minor"
}

detect_host_cuda_cc() {
    local cc

    if [[ -n "${LLAMA_HOST_CUDA_CC:-}" ]]; then
        printf '%s\n' "$LLAMA_HOST_CUDA_CC"
        return 0
    fi

    if command_available nvidia-smi; then
        cc="$(nvidia-smi --query-gpu=compute_cap --format=csv,noheader 2>/dev/null | head -n 1 | tr -d '[:space:]' || true)"
        if [[ -n "$cc" ]]; then
            printf '%s\n' "$cc"
            return 0
        fi
    fi

    return 1
}

manifest_value() {
    local file="$1"
    local key="$2"
    local line

    [[ -f "$file" ]] || return 1
    line="$(grep -E "^${key}=" "$file" | tail -n 1 || true)"
    [[ -n "$line" ]] || return 1
    line="${line#*=}"
    line="${line%\"}"
    line="${line#\"}"
    line="${line%\'}"
    line="${line#\'}"
    printf '%s\n' "$line"
}

binary_file_info() {
    file -bL "$1" 2>/dev/null || true
}

binary_platform_matches_host() {
    local binary="$1"
    local info

    info="$(binary_file_info "$binary")"
    if [[ -z "$info" ]] || [[ "$info" == *"script"* ]] || [[ "$info" == *"text executable"* ]]; then
        return 0
    fi

    case "$SELECTED_LLAMA_SERVER_HOST_OS" in
        linux)
            [[ "$info" == *ELF* ]] || return 1
            ;;
        darwin)
            [[ "$info" == *Mach-O* ]] || return 1
            ;;
    esac

    case "$SELECTED_LLAMA_SERVER_HOST_ARCH" in
        x86_64)
            [[ "$info" == *x86-64* || "$info" == *x86_64* ]] || return 1
            ;;
        arm64)
            [[ "$info" == *arm64* || "$info" == *aarch64* ]] || return 1
            ;;
    esac

    return 0
}

binary_dynamic_links_resolve() {
    local binary="$1"
    local info
    local output

    info="$(binary_file_info "$binary")"
    if [[ -z "$info" ]] || [[ "$info" == *"script"* ]] || [[ "$info" == *"text executable"* ]]; then
        return 0
    fi

    case "$SELECTED_LLAMA_SERVER_HOST_OS" in
        linux)
            if command_available ldd; then
                output="$(ldd "$binary" 2>&1 || true)"
                [[ "$output" != *"not found"* ]] || return 1
            fi
            ;;
        darwin)
            if command_available otool; then
                output="$(otool -L "$binary" 2>&1 || true)"
                [[ "$output" != *"not found"* ]] || return 1
            fi
            ;;
    esac

    return 0
}

bundle_manifest_for_binary() {
    printf '%s.compat.env\n' "$1"
}

validate_cuda_bundle() {
    local manifest="$1"
    local exact_cc
    local min_cc
    local max_cc
    local host_cc
    local host_cc_int
    local candidate

    exact_cc="$(manifest_value "$manifest" LLAMA_BUNDLE_CUDA_CC || true)"
    min_cc="$(manifest_value "$manifest" LLAMA_BUNDLE_CUDA_CC_MIN || true)"
    max_cc="$(manifest_value "$manifest" LLAMA_BUNDLE_CUDA_CC_MAX || true)"

    if [[ -z "$exact_cc" && -z "$min_cc" && -z "$max_cc" ]]; then
        BUNDLE_VALIDATE_REASON="bundled CUDA binary is missing compute-capability metadata"
        return 1
    fi

    host_cc="$(detect_host_cuda_cc || true)"
    if [[ -z "$host_cc" ]]; then
        BUNDLE_VALIDATE_REASON="host CUDA compute capability could not be detected"
        return 1
    fi

    host_cc_int="$(cc_to_int "$host_cc")"
    if [[ -n "$exact_cc" ]]; then
        for candidate in ${exact_cc//,/ }; do
            if [[ "$(cc_to_int "$candidate")" == "$host_cc_int" ]]; then
                return 0
            fi
        done
        BUNDLE_VALIDATE_REASON="bundled CUDA binary targets compute capability ${exact_cc}, host reports ${host_cc}"
        return 1
    fi

    if [[ -n "$min_cc" ]] && (( host_cc_int < $(cc_to_int "$min_cc") )); then
        BUNDLE_VALIDATE_REASON="bundled CUDA binary requires compute capability >= ${min_cc}, host reports ${host_cc}"
        return 1
    fi
    if [[ -n "$max_cc" ]] && (( host_cc_int > $(cc_to_int "$max_cc") )); then
        BUNDLE_VALIDATE_REASON="bundled CUDA binary requires compute capability <= ${max_cc}, host reports ${host_cc}"
        return 1
    fi

    return 0
}

validate_bundled_binary() {
    local binary="$1"
    local manifest
    local bundle_os
    local bundle_arch
    local bundle_backend
    local bundle_label

    BUNDLE_VALIDATE_REASON=""
    BUNDLE_VALIDATE_BACKEND=""
    BUNDLE_VALIDATE_LABEL=""
    BUNDLE_VALIDATE_MANIFEST=""

    [[ -x "$binary" ]] || {
        BUNDLE_VALIDATE_REASON="bundled binary not executable: $binary"
        return 1
    }

    manifest="$(bundle_manifest_for_binary "$binary")"
    [[ -f "$manifest" ]] || {
        BUNDLE_VALIDATE_REASON="bundled binary is missing ${manifest##*/}"
        return 1
    }

    bundle_os="$(normalize_os "$(manifest_value "$manifest" LLAMA_BUNDLE_OS || true)")"
    bundle_arch="$(normalize_arch "$(manifest_value "$manifest" LLAMA_BUNDLE_ARCH || true)")"
    bundle_backend="$(trim_whitespace "$(manifest_value "$manifest" LLAMA_BUNDLE_BACKEND || true)")"
    bundle_label="$(trim_whitespace "$(manifest_value "$manifest" LLAMA_BUNDLE_LABEL || true)")"

    [[ -n "$bundle_os" && -n "$bundle_arch" && -n "$bundle_backend" ]] || {
        BUNDLE_VALIDATE_REASON="bundled manifest is missing required OS/arch/backend fields"
        return 1
    }

    [[ "$bundle_os" == "$SELECTED_LLAMA_SERVER_HOST_OS" ]] || {
        BUNDLE_VALIDATE_REASON="bundled binary targets ${bundle_os}, host is ${SELECTED_LLAMA_SERVER_HOST_OS}"
        return 1
    }
    [[ "$bundle_arch" == "$SELECTED_LLAMA_SERVER_HOST_ARCH" ]] || {
        BUNDLE_VALIDATE_REASON="bundled binary targets ${bundle_arch}, host is ${SELECTED_LLAMA_SERVER_HOST_ARCH}"
        return 1
    }

    case "$bundle_backend" in
        cpu|cuda|vulkan|metal) ;;
        *)
            BUNDLE_VALIDATE_REASON="bundled binary declares unsupported backend: ${bundle_backend}"
            return 1
            ;;
    esac

    if [[ "$bundle_backend" != "cpu" ]] && ! host_has_backend "$bundle_backend"; then
        BUNDLE_VALIDATE_REASON="host does not expose the required ${bundle_backend} runtime"
        return 1
    fi

    binary_platform_matches_host "$binary" || {
        BUNDLE_VALIDATE_REASON="bundled binary format does not match this host"
        return 1
    }
    binary_dynamic_links_resolve "$binary" || {
        BUNDLE_VALIDATE_REASON="bundled binary has unresolved dynamic library dependencies"
        return 1
    }

    if [[ "$bundle_backend" == "cuda" ]]; then
        validate_cuda_bundle "$manifest" || return 1
    fi

    BUNDLE_VALIDATE_BACKEND="$bundle_backend"
    BUNDLE_VALIDATE_LABEL="${bundle_label:-$bundle_backend}"
    BUNDLE_VALIDATE_MANIFEST="$manifest"
    return 0
}

validate_external_binary() {
    local binary="$1"

    EXTERNAL_VALIDATE_REASON=""
    [[ -x "$binary" ]] || {
        EXTERNAL_VALIDATE_REASON="binary not executable: $binary"
        return 1
    }
    binary_platform_matches_host "$binary" || {
        EXTERNAL_VALIDATE_REASON="binary format does not match host ${SELECTED_LLAMA_SERVER_HOST_OS}/${SELECTED_LLAMA_SERVER_HOST_ARCH}"
        return 1
    }
    binary_dynamic_links_resolve "$binary" || {
        EXTERNAL_VALIDATE_REASON="binary has unresolved dynamic library dependencies"
        return 1
    }
    return 0
}

runtime_build_guidance() {
    cat <<EOF
Run \`llama-model build-runtime\` to fetch ${LLAMA_CPP_REPO_URL} and compile a host-specific llama-server build. Bundled binaries are backend-, platform-, and architecture-specific. If you need CUDA, Vulkan, or Metal, build that backend locally or point LLAMA_SERVER_BIN at your own compatible install.
EOF
}

select_binary_record() {
    SELECTED_LLAMA_SERVER_BIN="$1"
    SELECTED_LLAMA_SERVER_SOURCE="$2"
    SELECTED_LLAMA_SERVER_BACKEND="$3"
    SELECTED_LLAMA_SERVER_STATUS="$4"
    SELECTED_LLAMA_SERVER_MESSAGE="$5"
    SELECTED_LLAMA_SERVER_GUIDANCE="$6"
    SELECTED_LLAMA_SERVER_LABEL="${7:-}"
    SELECTED_LLAMA_SERVER_BUNDLE_MANIFEST="${8:-}"
}

list_bundled_binaries() {
    local runtime_root="$LLAMA_SERVER_RUNTIME_DIR/llama-server"
    [[ -d "$runtime_root" ]] || return 0
    find "$runtime_root" -mindepth 2 -maxdepth 2 -type f -name 'llama-server' -print0 | sort -z
}

bundled_binary_preference_order() {
    local requested_backend="$1"
    local order=""
    local backend

    for backend in "$requested_backend" metal cuda vulkan cpu; do
        [[ -n "$backend" ]] || continue
        if [[ ",$order," != *",$backend,"* ]]; then
            order="${order:+$order,}$backend"
        fi
    done
    printf '%s\n' "$order"
}

select_compatible_bundled_binary() {
    local requested_backend="$1"
    local order
    local backend
    local candidate

    BUNDLED_SELECTION_FAILURE_REASON=""
    order="$(bundled_binary_preference_order "$requested_backend")"
    for backend in ${order//,/ }; do
        while IFS= read -r -d '' candidate; do
            if validate_bundled_binary "$candidate" && [[ "$BUNDLE_VALIDATE_BACKEND" == "$backend" ]]; then
                select_binary_record \
                    "$candidate" \
                    "bundled" \
                    "$BUNDLE_VALIDATE_BACKEND" \
                    "compatible" \
                    "validated bundled ${BUNDLE_VALIDATE_LABEL} binary" \
                    "" \
                    "$BUNDLE_VALIDATE_LABEL" \
                    "$BUNDLE_VALIDATE_MANIFEST"
                if [[ "$BUNDLE_VALIDATE_BACKEND" == "cpu" && -n "$BUNDLED_SELECTION_FAILURE_REASON" ]]; then
                    SELECTED_LLAMA_SERVER_SOURCE="bundled-cpu-fallback"
                    SELECTED_LLAMA_SERVER_STATUS="fallback"
                    SELECTED_LLAMA_SERVER_MESSAGE="${BUNDLED_SELECTION_FAILURE_REASON}; using validated bundled CPU fallback instead"
                fi
                return 0
            elif [[ -z "$BUNDLED_SELECTION_FAILURE_REASON" && -n "$BUNDLE_VALIDATE_REASON" ]]; then
                BUNDLED_SELECTION_FAILURE_REASON="$BUNDLE_VALIDATE_REASON"
            fi
        done < <(list_bundled_binaries)
    done

    return 1
}

probe_server_binary() {
    local requested_backend
    local fallback_note=""
    local configured_path="${REQUESTED_LLAMA_SERVER_BIN:-}"
    local default_path="$DEFAULT_LLAMA_SERVER_BIN"
    local runtime_root

    SELECTED_LLAMA_SERVER_HOST_OS="$(detect_host_os)"
    SELECTED_LLAMA_SERVER_HOST_ARCH="$(detect_host_arch)"
    SELECTED_LLAMA_SERVER_HOST_BACKENDS="$(detect_host_backends)"
    SELECTED_LLAMA_SERVER_BIN=""
    SELECTED_LLAMA_SERVER_SOURCE=""
    SELECTED_LLAMA_SERVER_BACKEND=""
    SELECTED_LLAMA_SERVER_STATUS=""
    SELECTED_LLAMA_SERVER_MESSAGE=""
    SELECTED_LLAMA_SERVER_GUIDANCE=""
    SELECTED_LLAMA_SERVER_LABEL=""
    SELECTED_LLAMA_SERVER_BUNDLE_MANIFEST=""
    SELECTED_LLAMA_SERVER_PATH_KIND=""

    requested_backend="$(infer_backend_from_device "${LLAMA_SERVER_DEVICE:-}")"
    runtime_root="$(canonicalize_path "$LLAMA_SERVER_RUNTIME_DIR" 2>/dev/null || printf '%s\n' "$LLAMA_SERVER_RUNTIME_DIR")"

    if [[ -n "$configured_path" ]]; then
        SELECTED_LLAMA_SERVER_PATH_KIND="configured"
        if [[ -x "$configured_path" ]]; then
            if [[ -n "$runtime_root" ]] && [[ "$(canonicalize_path "$configured_path" 2>/dev/null || printf '%s\n' "$configured_path")" == "$runtime_root"* ]]; then
                if validate_bundled_binary "$configured_path"; then
                    select_binary_record \
                        "$configured_path" \
                        "bundled" \
                        "$BUNDLE_VALIDATE_BACKEND" \
                        "compatible" \
                        "validated configured bundled ${BUNDLE_VALIDATE_LABEL} binary" \
                        "" \
                        "$BUNDLE_VALIDATE_LABEL" \
                        "$BUNDLE_VALIDATE_MANIFEST"
                    return 0
                fi
                fallback_note="configured bundled binary rejected: ${BUNDLE_VALIDATE_REASON}"
            else
                if validate_external_binary "$configured_path"; then
                    select_binary_record \
                        "$configured_path" \
                        "external" \
                        "external" \
                        "external-unvalidated" \
                        "using external llama-server binary; backend compatibility must be managed by the installer" \
                        "" \
                        "external install"
                    return 0
                fi
                fallback_note="configured binary rejected: ${EXTERNAL_VALIDATE_REASON}"
            fi
        else
            fallback_note="configured binary not found: ${configured_path}"
        fi
    elif [[ -x "$default_path" ]]; then
        SELECTED_LLAMA_SERVER_PATH_KIND="default"
        if validate_external_binary "$default_path"; then
            select_binary_record \
                "$default_path" \
                "external" \
                "external" \
                "external-unvalidated" \
                "using installed llama-server from PATH; backend compatibility must be managed by the installer" \
                "" \
                "external install"
            return 0
        fi
        fallback_note="default installed binary rejected: ${EXTERNAL_VALIDATE_REASON}"
    fi

    if select_compatible_bundled_binary "$requested_backend"; then
        if [[ -n "$fallback_note" && "$SELECTED_LLAMA_SERVER_BACKEND" == "cpu" ]]; then
            SELECTED_LLAMA_SERVER_SOURCE="bundled-cpu-fallback"
            SELECTED_LLAMA_SERVER_STATUS="fallback"
            SELECTED_LLAMA_SERVER_MESSAGE="${fallback_note}; using validated bundled CPU fallback instead"
        elif [[ -n "$fallback_note" ]]; then
            SELECTED_LLAMA_SERVER_MESSAGE="${fallback_note}; using validated bundled ${SELECTED_LLAMA_SERVER_BACKEND} binary instead"
        fi
        return 0
    fi

    select_binary_record \
        "" \
        "none" \
        "none" \
        "unavailable" \
        "${fallback_note:-${BUNDLED_SELECTION_FAILURE_REASON:-no compatible llama-server binary found}}" \
        "$(runtime_build_guidance)"
    return 1
}

detect_primary_build_backend() {
    local requested="${1:-auto}"

    if [[ "$requested" != "auto" ]]; then
        printf '%s\n' "$requested"
        return 0
    fi

    if [[ ",$SELECTED_LLAMA_SERVER_HOST_BACKENDS," == *",metal,"* ]]; then
        printf 'metal\n'
    elif [[ ",$SELECTED_LLAMA_SERVER_HOST_BACKENDS," == *",cuda,"* ]]; then
        printf 'cuda\n'
    elif [[ ",$SELECTED_LLAMA_SERVER_HOST_BACKENDS," == *",vulkan,"* ]]; then
        printf 'vulkan\n'
    else
        printf 'cpu\n'
    fi
}

build_job_count() {
    if command_available nproc; then
        nproc
    elif command_available sysctl; then
        sysctl -n hw.logicalcpu 2>/dev/null || printf '4\n'
    else
        printf '4\n'
    fi
}

is_interactive_session() {
    [[ -t 0 && -t 1 ]]
}

confirm_prompt() {
    local prompt="$1"
    local default="${2:-Y}"
    local reply

    if ! is_interactive_session; then
        return 1
    fi

    if [[ "$default" == "Y" ]]; then
        printf '%s [Y/n] ' "$prompt"
    else
        printf '%s [y/N] ' "$prompt"
    fi

    read -r reply || return 1
    reply="${reply,,}"
    if [[ -z "$reply" ]]; then
        [[ "$default" == "Y" ]]
        return
    fi
    [[ "$reply" == "y" || "$reply" == "yes" ]]
}

detect_package_manager() {
    if command_available apt-get; then
        printf 'apt-get\n'
    elif command_available dnf; then
        printf 'dnf\n'
    elif command_available pacman; then
        printf 'pacman\n'
    elif command_available zypper; then
        printf 'zypper\n'
    elif command_available brew; then
        printf 'brew\n'
    else
        printf 'none\n'
    fi
}

dependency_key_label() {
    case "$1" in
        git) printf 'git\n' ;;
        cmake) printf 'cmake\n' ;;
        compiler) printf 'C++ compiler\n' ;;
        cuda_toolkit) printf 'CUDA toolkit (nvcc)\n' ;;
        vulkan_sdk) printf 'Vulkan SDK tools\n' ;;
        xcode_tools) printf 'Xcode Command Line Tools\n' ;;
        *) printf '%s\n' "$1" ;;
    esac
}

missing_build_dependencies() {
    local backend="$1"
    local host_os="${SELECTED_LLAMA_SERVER_HOST_OS:-$(detect_host_os)}"

    if ! command_available git; then
        printf 'git\n'
    fi
    if ! command_available cmake; then
        printf 'cmake\n'
    fi

    if [[ "$host_os" == "darwin" ]]; then
        if ! command_available xcrun; then
            printf 'xcode_tools\n'
        fi
    elif ! command_available c++ && ! command_available clang++ && ! command_available g++; then
        printf 'compiler\n'
    fi

    case "$backend" in
        cuda)
            command_available nvcc || printf 'cuda_toolkit\n'
            ;;
        vulkan)
            if ! command_available glslc && ! command_available glslangValidator; then
                printf 'vulkan_sdk\n'
            fi
            ;;
        metal)
            command_available xcrun || printf 'xcode_tools\n'
            ;;
    esac
}

append_unique_words() {
    local package_string="$1"
    shift
    local item
    local existing

    for item in $package_string; do
        [[ -n "$item" ]] || continue
        existing=0
        for word in "$@"; do
            if [[ "$word" == "$item" ]]; then
                existing=1
                break
            fi
        done
        if [[ "$existing" -eq 0 ]]; then
            printf '%s\n' "$item"
        fi
    done
}

packages_for_manager_key() {
    local manager="$1"
    local key="$2"

    case "$manager:$key" in
        apt-get:git|dnf:git|pacman:git|zypper:git|brew:git)
            printf 'git\n'
            ;;
        apt-get:cmake|dnf:cmake|pacman:cmake|zypper:cmake|brew:cmake)
            printf 'cmake\n'
            ;;
        apt-get:compiler)
            printf 'build-essential\n'
            ;;
        dnf:compiler|zypper:compiler)
            printf 'gcc-c++ make\n'
            ;;
        pacman:compiler)
            printf 'base-devel\n'
            ;;
        apt-get:cuda_toolkit)
            printf 'nvidia-cuda-toolkit\n'
            ;;
        dnf:cuda_toolkit|zypper:cuda_toolkit)
            printf 'cuda-toolkit\n'
            ;;
        pacman:cuda_toolkit)
            printf 'cuda\n'
            ;;
        apt-get:vulkan_sdk)
            printf 'vulkan-tools glslang-tools libvulkan-dev\n'
            ;;
        dnf:vulkan_sdk)
            printf 'vulkan-tools glslang\n'
            ;;
        pacman:vulkan_sdk)
            printf 'vulkan-tools shaderc\n'
            ;;
        zypper:vulkan_sdk)
            printf 'vulkan-tools glslang\n'
            ;;
        brew:vulkan_sdk)
            printf 'vulkan-tools shaderc\n'
            ;;
        *)
            printf '\n'
            ;;
    esac
}

preview_dependency_install_commands() {
    local manager="$1"
    shift
    local key
    local package_string
    local -a packages=()
    local pkg
    local prefix=""

    if [[ "$manager" == "none" ]]; then
        return 1
    fi

    for key in "$@"; do
        if [[ "$key" == "xcode_tools" ]]; then
            printf 'xcode-select --install\n'
            continue
        fi

        package_string="$(packages_for_manager_key "$manager" "$key")"
        if [[ -z "$package_string" ]]; then
            continue
        fi
        while IFS= read -r pkg; do
            [[ -n "$pkg" ]] || continue
            packages+=("$pkg")
        done < <(append_unique_words "$package_string" "${packages[@]}")
    done

    if ((${#packages[@]} == 0)); then
        return 0
    fi

    case "$manager" in
        apt-get)
            prefix="$( [[ "$EUID" -eq 0 ]] && printf '' || printf 'sudo ' )"
            printf '%sapt-get update\n' "$prefix"
            printf '%sapt-get install -y %s\n' "$prefix" "${packages[*]}"
            ;;
        dnf)
            prefix="$( [[ "$EUID" -eq 0 ]] && printf '' || printf 'sudo ' )"
            printf '%sdnf install -y %s\n' "$prefix" "${packages[*]}"
            ;;
        pacman)
            prefix="$( [[ "$EUID" -eq 0 ]] && printf '' || printf 'sudo ' )"
            printf '%spacman -Sy --needed --noconfirm %s\n' "$prefix" "${packages[*]}"
            ;;
        zypper)
            prefix="$( [[ "$EUID" -eq 0 ]] && printf '' || printf 'sudo ' )"
            printf '%szypper --non-interactive install %s\n' "$prefix" "${packages[*]}"
            ;;
        brew)
            printf 'brew install %s\n' "${packages[*]}"
            ;;
    esac
}

ensure_sudo_if_needed() {
    local manager="$1"

    case "$manager" in
        apt-get|dnf|pacman|zypper)
            if [[ "$EUID" -ne 0 ]] && ! command_available sudo; then
                die "sudo is required to install build dependencies with ${manager}"
            fi
            ;;
    esac
}

run_dependency_install_commands() {
    local manager="$1"
    shift
    local key
    local package_string
    local -a packages=()
    local pkg

    ensure_sudo_if_needed "$manager"

    for key in "$@"; do
        if [[ "$key" == "xcode_tools" ]]; then
            if command_available xcode-select && xcode-select -p >/dev/null 2>&1; then
                continue
            fi
            command_available xcode-select || die "xcode-select is not available on this host"
            xcode-select --install || true
            printf 'Complete the Xcode Command Line Tools installation, then rerun llama-model build-runtime.\n'
            return 1
        fi

        package_string="$(packages_for_manager_key "$manager" "$key")"
        if [[ -z "$package_string" ]]; then
            continue
        fi
        while IFS= read -r pkg; do
            [[ -n "$pkg" ]] || continue
            packages+=("$pkg")
        done < <(append_unique_words "$package_string" "${packages[@]}")
    done

    if ((${#packages[@]} == 0)); then
        return 0
    fi

    case "$manager" in
        apt-get)
            if [[ "$EUID" -eq 0 ]]; then
                apt-get update
                apt-get install -y "${packages[@]}"
            else
                sudo apt-get update
                sudo apt-get install -y "${packages[@]}"
            fi
            ;;
        dnf)
            if [[ "$EUID" -eq 0 ]]; then
                dnf install -y "${packages[@]}"
            else
                sudo dnf install -y "${packages[@]}"
            fi
            ;;
        pacman)
            if [[ "$EUID" -eq 0 ]]; then
                pacman -Sy --needed --noconfirm "${packages[@]}"
            else
                sudo pacman -Sy --needed --noconfirm "${packages[@]}"
            fi
            ;;
        zypper)
            if [[ "$EUID" -eq 0 ]]; then
                zypper --non-interactive install "${packages[@]}"
            else
                sudo zypper --non-interactive install "${packages[@]}"
            fi
            ;;
        brew)
            brew install "${packages[@]}"
            ;;
        *)
            return 1
            ;;
    esac
}

install_missing_build_dependencies() {
    local backend="$1"
    shift
    local -a missing=("$@")
    local manager
    local preview=""
    local key

    manager="$(detect_package_manager)"
    if [[ "$manager" == "none" ]]; then
        return 1
    fi

    preview="$(preview_dependency_install_commands "$manager" "${missing[@]}" || true)"
    if [[ -z "$preview" ]]; then
        return 1
    fi

    printf 'Missing build dependencies for backend %s:\n' "$backend"
    for key in "${missing[@]}"; do
        printf '  - %s\n' "$(dependency_key_label "$key")"
    done
    printf '\nProposed install commands:\n%s\n' "$preview"

    case "${LLAMA_AUTO_INSTALL_DEPS:-prompt}" in
        1|true|yes)
            ;;
        0|false|no)
            return 1
            ;;
        *)
            confirm_prompt "Install the missing build dependencies now?" "Y" || return 1
            ;;
    esac

    run_dependency_install_commands "$manager" "${missing[@]}"
}

ensure_build_dependencies() {
    local backend="$1"
    local -a missing=()
    local summary=""
    local key

    mapfile -t missing < <(missing_build_dependencies "$backend")
    if ((${#missing[@]} == 0)); then
        return 0
    fi

    install_missing_build_dependencies "$backend" "${missing[@]}" || true
    mapfile -t missing < <(missing_build_dependencies "$backend")
    if ((${#missing[@]} == 0)); then
        return 0
    fi

    for key in "${missing[@]}"; do
        summary="${summary:+$summary, }$(dependency_key_label "$key")"
    done
    die "missing build dependencies for backend ${backend}: ${summary}. Install them and rerun llama-model build-runtime --backend ${backend}."
}

sync_llama_cpp_source() {
    local ref="$1"
    local src_root="$LLAMA_SERVER_RUNTIME_DIR/src"
    local src_dir="$src_root/llama.cpp"

    mkdir -p "$src_root"
    if [[ ! -d "$src_dir/.git" ]]; then
        git clone "$LLAMA_CPP_REPO_URL" "$src_dir" >/dev/null
    fi

    git -C "$src_dir" fetch --tags origin >/dev/null
    if git -C "$src_dir" rev-parse --verify "$ref^{commit}" >/dev/null 2>&1; then
        git -C "$src_dir" checkout --detach "$ref" >/dev/null
    else
        git -C "$src_dir" checkout --detach "origin/$ref" >/dev/null 2>&1 \
            || die "unable to resolve llama.cpp ref: $ref"
    fi

    printf '%s\n' "$src_dir"
}

write_bundle_manifest() {
    local binary="$1"
    local backend="$2"
    local ref="$3"
    local manifest
    local label
    local cuda_cc=""

    case "$backend" in
        cpu) label="CPU" ;;
        cuda) label="NVIDIA CUDA" ;;
        vulkan) label="Vulkan" ;;
        metal) label="Apple Metal" ;;
        *) label="$backend" ;;
    esac

    if [[ "$backend" == "cuda" ]]; then
        cuda_cc="$(detect_host_cuda_cc || true)"
        [[ -n "$cuda_cc" ]] || die "unable to detect CUDA compute capability for this host; set LLAMA_HOST_CUDA_CC or build cpu instead"
    fi

    manifest="$(bundle_manifest_for_binary "$binary")"
    {
        printf 'LLAMA_BUNDLE_OS=%s\n' "$SELECTED_LLAMA_SERVER_HOST_OS"
        printf 'LLAMA_BUNDLE_ARCH=%s\n' "$SELECTED_LLAMA_SERVER_HOST_ARCH"
        printf 'LLAMA_BUNDLE_BACKEND=%s\n' "$backend"
        printf 'LLAMA_BUNDLE_LABEL=%s\n' "$label"
        printf 'LLAMA_BUNDLE_SOURCE_REF=%s\n' "$ref"
        printf 'LLAMA_BUNDLE_BUILT_AT=%s\n' "$(iso_timestamp)"
        if [[ -n "$cuda_cc" ]]; then
            printf 'LLAMA_BUNDLE_CUDA_CC=%s\n' "$cuda_cc"
        fi
    } >"$manifest"
}

locate_built_llama_server() {
    local build_dir="$1"
    find "$build_dir" -type f -name 'llama-server' -perm -u+x | sort | head -n 1
}

build_runtime_backend() {
    local src_dir="$1"
    local backend="$2"
    local ref="$3"
    local jobs="$4"
    local build_dir="$LLAMA_SERVER_RUNTIME_DIR/build/${SELECTED_LLAMA_SERVER_HOST_OS}-${SELECTED_LLAMA_SERVER_HOST_ARCH}-${backend}"
    local install_dir="$LLAMA_SERVER_RUNTIME_DIR/llama-server/${SELECTED_LLAMA_SERVER_HOST_OS}-${SELECTED_LLAMA_SERVER_HOST_ARCH}-${backend}"
    local -a cmake_args=()
    local binary=""

    rm -rf "$build_dir"
    mkdir -p "$build_dir" "$install_dir"

    if command_available ninja; then
        cmake_args+=(-G Ninja)
    fi

    cmake_args+=(-DCMAKE_BUILD_TYPE=Release)
    case "$backend" in
        cpu)
            cmake_args+=(-DGGML_CUDA=OFF -DGGML_VULKAN=OFF -DGGML_METAL=OFF)
            ;;
        cuda)
            cmake_args+=(-DGGML_CUDA=ON -DGGML_VULKAN=OFF -DGGML_METAL=OFF)
            ;;
        vulkan)
            cmake_args+=(-DGGML_CUDA=OFF -DGGML_VULKAN=ON -DGGML_METAL=OFF)
            ;;
        metal)
            cmake_args+=(-DGGML_CUDA=OFF -DGGML_VULKAN=OFF -DGGML_METAL=ON)
            ;;
        *)
            die "unsupported build backend: $backend"
            ;;
    esac

    cmake -S "$src_dir" -B "$build_dir" "${cmake_args[@]}" >/dev/null
    cmake --build "$build_dir" --target llama-server -j "$jobs" >/dev/null

    binary="$(locate_built_llama_server "$build_dir")"
    [[ -n "$binary" ]] || die "llama-server binary was not produced for backend ${backend}"

    install -m 0755 "$binary" "$install_dir/llama-server"
    write_bundle_manifest "$install_dir/llama-server" "$backend" "$ref"
    printf 'built %s runtime at %s\n' "$backend" "$install_dir/llama-server"
}

build_runtime() {
    local backend="auto"
    local ref="$LLAMA_CPP_REF"
    local primary_backend
    local src_dir
    local jobs
    local target
    local built_any=0
    local targets=""

    while (($#)); do
        case "$1" in
            --backend)
                [[ $# -ge 2 ]] || die "--backend requires a value"
                backend="$2"
                shift 2
                ;;
            --ref)
                [[ $# -ge 2 ]] || die "--ref requires a value"
                ref="$2"
                shift 2
                ;;
            *)
                die "unknown build-runtime option: $1"
                ;;
        esac
    done

    case "$backend" in
        auto|cpu|cuda|vulkan|metal) ;;
        *)
            die "unsupported backend: $backend (expected auto, cpu, cuda, vulkan, or metal)"
            ;;
    esac

    SELECTED_LLAMA_SERVER_HOST_OS="$(detect_host_os)"
    SELECTED_LLAMA_SERVER_HOST_ARCH="$(detect_host_arch)"
    SELECTED_LLAMA_SERVER_HOST_BACKENDS="$(detect_host_backends)"
    primary_backend="$(detect_primary_build_backend "$backend")"
    jobs="${LLAMA_BUILD_JOBS:-$(build_job_count)}"

    ensure_build_dependencies "$primary_backend"
    ensure_build_dependencies cpu
    mkdir -p "$LLAMA_SERVER_RUNTIME_DIR"
    src_dir="$(sync_llama_cpp_source "$ref")"

    for target in "$primary_backend" cpu; do
        if [[ ",$targets," == *",$target,"* ]]; then
            continue
        fi
        targets="${targets:+$targets,}$target"
        build_runtime_backend "$src_dir" "$target" "$ref" "$jobs"
        built_any=1
    done

    [[ "$built_any" -eq 1 ]] || die "no runtime builds were produced"
    printf 'runtime_dir: %s\n' "$LLAMA_SERVER_RUNTIME_DIR"
    printf 'host: %s/%s (%s)\n' "$SELECTED_LLAMA_SERVER_HOST_OS" "$SELECTED_LLAMA_SERVER_HOST_ARCH" "$SELECTED_LLAMA_SERVER_HOST_BACKENDS"
}

sanitize_alias() {
    local raw="$1"
    raw="${raw##*/}"
    raw="${raw%.gguf}"
    raw="$(printf '%s' "$raw" | tr '[:upper:]' '[:lower:]' | sed -E 's/[^a-z0-9]+/-/g; s/^-+//; s/-+$//; s/-+/-/g')"
    printf '%s\n' "$raw"
}

find_pid() {
    local pid
    local pattern="${LLAMA_SERVER_BIN:-}"

    if read_state_file && [[ -n "${CURRENT_PID:-}" ]]; then
        if kill -0 "$CURRENT_PID" 2>/dev/null && pid_matches_managed_server "$CURRENT_PID"; then
            printf '%s\n' "$CURRENT_PID"
            return 0
        fi
    fi

    if [[ -z "$pattern" ]]; then
        pattern='(^|/)llama-server([[:space:]]|$)'
    fi

    pid="$(
        pgrep -af "$pattern" 2>/dev/null \
            | awk -v port="$LLAMA_SERVER_PORT" '$0 ~ ("--port " port "([[:space:]]|$)") { print $1; exit }' \
            || true
    )"
    printf '%s\n' "$pid"
}

pid_cgroup_text() {
    local pid="$1"

    if [[ -r "/proc/$pid/cgroup" ]]; then
        cat "/proc/$pid/cgroup"
    fi
}

systemd_unit_from_cgroup_text() {
    local text="$1"
    local unit

    unit="$(printf '%s
' "$text" | grep -oE '[A-Za-z0-9_.@-]+\.service' | tail -n 1 || true)"
    [[ -n "$unit" ]] && printf '%s
' "$unit"
}

pid_systemd_unit() {
    local pid="$1"
    local cgroup_text

    cgroup_text="$(pid_cgroup_text "$pid")"
    [[ -n "$cgroup_text" ]] || return 1
    systemd_unit_from_cgroup_text "$cgroup_text"
}

pid_owned_by_manager() {
    local pid="$1"
    local managed_pid=""

    managed_pid="$(managed_state_pid 2>/dev/null || true)"
    [[ -n "$managed_pid" && "$managed_pid" == "$pid" ]]
}

cmd_arg_from_pid() {
    local pid="$1"
    local key="$2"
    local -a args=()
    local i
    local cmdline

    if state_value "$key" >/dev/null 2>&1; then
        state_value "$key"
        return 0
    fi

    if [[ -r "/proc/$pid/cmdline" ]]; then
        mapfile -d '' -t args <"/proc/$pid/cmdline"
    else
        cmdline="$(pid_command_line "$pid")"
        [[ -n "$cmdline" ]] || return 1
        mapfile -d '' -t args < <(split_shell_words "$cmdline")
    fi

    for ((i = 0; i < ${#args[@]}; i++)); do
        if [[ "${args[i]}" == "$key" ]] && (( i + 1 < ${#args[@]} )); then
            printf '%s\n' "${args[i + 1]}"
            return 0
        fi
    done

    return 1
}

lookup_model() {
    local needle="$1"
    local raw_line
    local -a fields=()
    local alias
    local path
    local extra
    local context
    local ngl
    local batch
    local threads
    local parallel
    local device
    local notes

    [[ -f "$MODELS_FILE" ]] || die "model registry not found: $MODELS_FILE"

    while IFS= read -r raw_line || [[ -n "$raw_line" ]]; do
        mapfile -d '' -t fields < <(split_tsv_record "$raw_line")
        alias="${fields[0]}"
        path="${fields[1]}"
        extra="${fields[2]}"
        context="${fields[3]}"
        ngl="${fields[4]}"
        batch="${fields[5]}"
        threads="${fields[6]}"
        parallel="${fields[7]}"
        device="${fields[8]}"
        notes="${fields[9]}"
        [[ -n "$alias" ]] || continue
        [[ "${alias:0:1}" == "#" ]] && continue
        if [[ "$alias" == "$needle" ]]; then
            printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\n' \
                "$alias" "$path" "${extra:-}" "${context:-}" "${ngl:-}" "${batch:-}" "${threads:-}" "${parallel:-}" "${device:-}" "${notes:-}"
            return 0
        fi
    done <"$MODELS_FILE"

    return 1
}

lookup_alias_for_path() {
    local needle="$1"
    local raw_line
    local -a fields=()
    local alias
    local path

    [[ -f "$MODELS_FILE" ]] || return 1

    while IFS= read -r raw_line || [[ -n "$raw_line" ]]; do
        mapfile -d '' -t fields < <(split_tsv_record "$raw_line")
        alias="${fields[0]}"
        path="${fields[1]}"
        [[ -n "$alias" ]] || continue
        [[ "${alias:0:1}" == "#" ]] && continue
        if [[ "$path" == "$needle" ]]; then
            printf '%s\n' "$alias"
            return 0
        fi
    done <"$MODELS_FILE"

    return 1
}

configured_mode_name() {
    if [[ "${LLAMA_SERVER_PARALLEL:-}" == "1" ]]; then
        printf 'single-client\n'
    else
        printf 'multi-client\n'
    fi
}

active_parallel_value() {
    local pid="$1"
    local active_parallel

    active_parallel="$(cmd_arg_from_pid "$pid" -np || true)"
    if [[ -n "$active_parallel" ]]; then
        printf '%s\n' "$active_parallel"
    else
        printf 'auto\n'
    fi
}

active_mode_name() {
    local active_parallel="$1"

    if [[ "$active_parallel" == "1" ]]; then
        printf 'single-client\n'
    else
        printf 'multi-client\n'
    fi
}

ensure_defaults_file() {
    mkdir -p "$CONFIG_DIR"
    [[ -f "$DEFAULTS_FILE" ]] || : >"$DEFAULTS_FILE"
}

set_default_value() {
    local key="$1"
    local value="$2"
    local tmp

    ensure_defaults_file
    tmp="$(mktemp)"
    awk -v key="$key" -v value="$value" '
        BEGIN { updated = 0 }
        $0 ~ ("^" key "=") {
            print key "=" value
            updated = 1
            next
        }
        { print }
        END {
            if (!updated) {
                print key "=" value
            }
        }
    ' "$DEFAULTS_FILE" >"$tmp"
    mv "$tmp" "$DEFAULTS_FILE"
}

resolve_model() {
    local spec="$1"
    local resolved

    if [[ -f "$spec" ]]; then
        printf 'custom\t%s\t\t\t\t\t\t\t\t\n' "$(canonicalize_path "$spec")"
        return 0
    fi

    if resolved="$(lookup_model "$spec")"; then
        printf '%s\n' "$resolved"
        return 0
    fi

    die "unknown model alias or path: $spec"
}

backup_log() {
    local backup_path

    [[ -s "$LLAMA_SERVER_LOG" ]] || return 0
    backup_path="${LLAMA_SERVER_LOG}.pre-switch-$(timestamp)"
    cp -a "$LLAMA_SERVER_LOG" "$backup_path"
    printf 'backed up log to %s\n' "$backup_path"
}

stop_server() {
    local pid
    local waited

    pid="$(find_pid)"
    if [[ -z "$pid" ]]; then
        clear_state_file
        return 0
    fi

    kill -INT "$pid" 2>/dev/null || true
    for waited in $(seq 1 30); do
        if ! kill -0 "$pid" 2>/dev/null; then
            wait_for_port_release
            clear_state_file
            return 0
        fi
        sleep 1
    done

    kill -TERM "$pid" 2>/dev/null || true
    for waited in $(seq 1 10); do
        if ! kill -0 "$pid" 2>/dev/null; then
            wait_for_port_release
            clear_state_file
            return 0
        fi
        sleep 1
    done

    die "server pid $pid did not stop"
}

wait_for_port_release() {
    local waited

    for waited in $(seq 1 30); do
        if ! port_is_listening; then
            return 0
        fi
        sleep 1
    done

    die "port $LLAMA_SERVER_PORT did not become free"
}

wait_for_health() {
    local pid="$1"
    local waited
    local url="http://${LLAMA_SERVER_HOST}:${LLAMA_SERVER_PORT}/health"

    for ((waited = 0; waited < LLAMA_SERVER_WAIT_SECONDS; waited++)); do
        if curl -fsS "$url" >/dev/null 2>&1; then
            return 0
        fi

        if ! kill -0 "$pid" 2>/dev/null; then
            tail -n 60 "$LLAMA_SERVER_LOG" >&2 || true
            die "llama-server exited during startup"
        fi

        sleep 1
    done

    tail -n 60 "$LLAMA_SERVER_LOG" >&2 || true
    die "timed out waiting for $url"
}

write_state() {
    local alias="$1"
    local model_path="$2"
    local pid="$3"
    local context="$4"
    local ngl="$5"
    local batch="$6"
    local threads="$7"
    local parallel="$8"
    local device="$9"

    {
        printf 'CURRENT_ALIAS=%q\n' "$alias"
        printf 'CURRENT_MODEL=%q\n' "$model_path"
        printf 'CURRENT_PID=%q\n' "$pid"
        printf 'CURRENT_PORT=%q\n' "$LLAMA_SERVER_PORT"
        printf 'CURRENT_LOG=%q\n' "$LLAMA_SERVER_LOG"
        printf 'CURRENT_CONTEXT=%q\n' "$context"
        printf 'CURRENT_NGL=%q\n' "$ngl"
        printf 'CURRENT_BATCH=%q\n' "$batch"
        printf 'CURRENT_THREADS=%q\n' "$threads"
        printf 'CURRENT_PARALLEL=%q\n' "$parallel"
        printf 'CURRENT_DEVICE=%q\n' "$device"
        printf 'CURRENT_STARTED_AT=%q\n' "$(iso_timestamp)"
    } >"$STATE_FILE"
}

start_server() {
    local alias="$1"
    local model_path="$2"
    local model_extra="${3:-}"
    local model_context="${4:-}"
    local model_ngl="${5:-}"
    local model_batch="${6:-}"
    local model_threads="${7:-}"
    local model_parallel="${8:-}"
    local model_device="${9:-}"
    shift 9 || true
    local -a cmd=()
    local -a extra_args=()
    local -a runtime_extra_args=()
    local pid
    local context="${model_context:-$LLAMA_SERVER_CONTEXT}"
    local ngl="${model_ngl:-$LLAMA_SERVER_NGL}"
    local batch="${model_batch:-$LLAMA_SERVER_BATCH}"
    local threads="${model_threads:-$LLAMA_SERVER_THREADS}"
    local device="${model_device:-$LLAMA_SERVER_DEVICE}"
    local parallel="${model_parallel:-$LLAMA_SERVER_PARALLEL}"
    local expected_device_backend

    probe_server_binary || die "${SELECTED_LLAMA_SERVER_MESSAGE}

${SELECTED_LLAMA_SERVER_GUIDANCE}"
    [[ -f "$model_path" ]] || die "model not found: $model_path"

    LLAMA_SERVER_BIN="$SELECTED_LLAMA_SERVER_BIN"
    expected_device_backend="$(infer_backend_from_device "$device")"
    if [[ "$SELECTED_LLAMA_SERVER_BACKEND" == "cpu" ]]; then
        ngl="0"
        device=""
    elif [[ "$SELECTED_LLAMA_SERVER_BACKEND" != "external" && -n "$expected_device_backend" && "$expected_device_backend" != "$SELECTED_LLAMA_SERVER_BACKEND" ]]; then
        die "configured device ${device} expects backend ${expected_device_backend}, but selected llama-server binary uses ${SELECTED_LLAMA_SERVER_BACKEND}. Clear the device override or build a matching runtime."
    fi

    if [[ -n "$model_extra" ]]; then
        mapfile -d '' -t extra_args < <(split_shell_words "$model_extra")
    fi
    if [[ -n "$LLAMA_SERVER_EXTRA_ARGS" ]]; then
        mapfile -d '' -t runtime_extra_args < <(split_shell_words "$LLAMA_SERVER_EXTRA_ARGS")
    fi

    cmd=(
        "$LLAMA_SERVER_BIN"
        -m "$model_path"
        -c "$context"
        -ngl "$ngl"
        -b "$batch"
        --threads "$threads"
        --port "$LLAMA_SERVER_PORT"
    )

    if [[ -n "$device" ]]; then
        cmd+=(--device "$device")
    fi

    if [[ -n "$parallel" ]] && [[ "$parallel" != "auto" ]]; then
        cmd+=(-np "$parallel")
    fi

    if ((${#extra_args[@]})); then
        cmd+=("${extra_args[@]}")
    fi
    if ((${#runtime_extra_args[@]})); then
        cmd+=("${runtime_extra_args[@]}")
    fi
    if (($#)); then
        cmd+=("$@")
    fi

    setsid "${cmd[@]}" >"$LLAMA_SERVER_LOG" 2>&1 < /dev/null &
    pid=$!
    disown "$pid" 2>/dev/null || true

    wait_for_health "$pid"
    write_state "$alias" "$model_path" "$pid" "$context" "$ngl" "$batch" "$threads" "${parallel:-auto}" "$device"

    if [[ -n "$SELECTED_LLAMA_SERVER_MESSAGE" ]]; then
        printf 'note: %s\n' "$SELECTED_LLAMA_SERVER_MESSAGE"
    fi
    printf 'started %s on port %s with pid %s\n' "$alias" "$LLAMA_SERVER_PORT" "$pid"
}

list_models() {
    local pid
    local current_model=""
    local alias
    local path
    local extra
    local context
    local ngl
    local batch
    local threads
    local parallel
    local device
    local notes
    local marker
    local status
    local preset
    local raw_line
    local -a fields=()

    [[ -f "$MODELS_FILE" ]] || die "model registry not found: $MODELS_FILE"

    pid="$(find_pid)"
    if [[ -n "$pid" ]]; then
        current_model="$(cmd_arg_from_pid "$pid" -m || true)"
    fi

    printf '  %-18s %-8s %-8s %s\n' "ALIAS" "STATUS" "PRESET" "MODEL"
    while IFS= read -r raw_line || [[ -n "$raw_line" ]]; do
        mapfile -d '' -t fields < <(split_tsv_record "$raw_line")
        alias="${fields[0]}"
        path="${fields[1]}"
        extra="${fields[2]}"
        context="${fields[3]}"
        ngl="${fields[4]}"
        batch="${fields[5]}"
        threads="${fields[6]}"
        parallel="${fields[7]}"
        device="${fields[8]}"
        notes="${fields[9]}"
        [[ -n "$alias" ]] || continue
        [[ "${alias:0:1}" == "#" ]] && continue
        marker=" "
        status="ok"
        preset="default"
        [[ -f "$path" ]] || status="missing"
        [[ "$path" == "$current_model" ]] && marker="*"
        if [[ -n "${extra:-}${context:-}${ngl:-}${batch:-}${threads:-}${parallel:-}${device:-}${notes:-}" ]]; then
            preset="custom"
        fi
        printf '%s %-18s %-8s %-8s %s\n' "$marker" "$alias" "$status" "$preset" "$path"
    done <"$MODELS_FILE"
}

show_model() {
    local resolved
    local -a fields=()
    local alias
    local model_path
    local model_extra
    local model_context
    local model_ngl
    local model_batch
    local model_threads
    local model_parallel
    local model_device
    local model_notes

    resolved="$(lookup_model "$1")" || die "unknown model alias: $1"
    mapfile -d '' -t fields < <(split_tsv_record "$resolved")
    alias="${fields[0]}"
    model_path="${fields[1]}"
    model_extra="${fields[2]}"
    model_context="${fields[3]}"
    model_ngl="${fields[4]}"
    model_batch="${fields[5]}"
    model_threads="${fields[6]}"
    model_parallel="${fields[7]}"
    model_device="${fields[8]}"
    model_notes="${fields[9]}"

    printf 'alias: %s\n' "$alias"
    printf 'model: %s\n' "$model_path"
    printf 'exists: %s\n' "$([[ -f "$model_path" ]] && printf yes || printf no)"
    printf 'extra_args: %s\n' "${model_extra:-}"
    printf 'context: %s\n' "${model_context:-default ($LLAMA_SERVER_CONTEXT)}"
    printf 'ngl: %s\n' "${model_ngl:-default ($LLAMA_SERVER_NGL)}"
    printf 'batch: %s\n' "${model_batch:-default ($LLAMA_SERVER_BATCH)}"
    printf 'threads: %s\n' "${model_threads:-default ($LLAMA_SERVER_THREADS)}"
    printf 'parallel: %s\n' "${model_parallel:-default (${LLAMA_SERVER_PARALLEL:-auto})}"
    printf 'device: %s\n' "${model_device:-default ($LLAMA_SERVER_DEVICE)}"
    printf 'notes: %s\n' "${model_notes:-}"
}

show_current() {
    local pid
    local model_path
    local alias
    local url="http://${LLAMA_SERVER_HOST}:${LLAMA_SERVER_PORT}/health"
    local active_parallel
    local active_mode

    pid="$(find_pid)"
    if [[ -z "$pid" ]]; then
        printf 'llama-server is not running on port %s\n' "$LLAMA_SERVER_PORT"
        printf 'configured_mode: %s\n' "$(configured_mode_name)"
        if [[ -n "${LLAMA_SERVER_PARALLEL:-}" ]]; then
            printf 'configured_parallel: %s\n' "$LLAMA_SERVER_PARALLEL"
        else
            printf 'configured_parallel: auto\n'
        fi
        return 0
    fi

    model_path="$(cmd_arg_from_pid "$pid" -m || true)"
    alias="$(lookup_alias_for_path "$model_path" || true)"
    [[ -n "$alias" ]] || alias="custom"
    active_parallel="$(active_parallel_value "$pid")"
    active_mode="$(active_mode_name "$active_parallel")"

    printf 'pid: %s\n' "$pid"
    printf 'alias: %s\n' "$alias"
    printf 'model: %s\n' "$model_path"
    printf 'log: %s\n' "$LLAMA_SERVER_LOG"
    printf 'configured_mode: %s\n' "$(configured_mode_name)"
    if [[ -n "${LLAMA_SERVER_PARALLEL:-}" ]]; then
        printf 'configured_parallel: %s\n' "$LLAMA_SERVER_PARALLEL"
    else
        printf 'configured_parallel: auto\n'
    fi
    printf 'active_mode: %s\n' "$active_mode"
    printf 'active_parallel: %s\n' "$active_parallel"
    printf 'active_context: %s\n' "$(cmd_arg_from_pid "$pid" -c || printf unknown)"
    printf 'active_ngl: %s\n' "$(cmd_arg_from_pid "$pid" -ngl || printf unknown)"
    printf 'active_batch: %s\n' "$(cmd_arg_from_pid "$pid" -b || printf unknown)"
    printf 'active_threads: %s\n' "$(cmd_arg_from_pid "$pid" --threads || printf unknown)"
    printf 'active_device: %s\n' "$(cmd_arg_from_pid "$pid" --device || printf unknown)"
    if curl -fsS "$url" >/dev/null 2>&1; then
        printf 'health: ok (%s)\n' "$url"
    else
        printf 'health: unavailable (%s)\n' "$url"
    fi
}

show_doctor() {
    local pid
    local model_path=""
    local alias="stopped"
    local url="http://${LLAMA_SERVER_HOST}:${LLAMA_SERVER_PORT}/health"
    local health="unavailable"
    local build_info=""
    local offload=""
    local kv_buffer=""
    local graph_splits=""
    local listening=""
    local binary_ok="no"
    local external_owner="no"
    local external_owner_unit=""
    local external_owner_message=""

    pid="$(find_pid)"
    if [[ -n "$pid" ]]; then
        model_path="$(cmd_arg_from_pid "$pid" -m || true)"
        alias="$(lookup_alias_for_path "$model_path" || true)"
        [[ -n "$alias" ]] || alias="custom"
        if curl -fsS "$url" >/dev/null 2>&1; then
            health="ok"
        fi
    fi

    if [[ -f "$LLAMA_SERVER_LOG" ]]; then
        build_info="$(grep -F 'build_info:' "$LLAMA_SERVER_LOG" | tail -n 1 | sed 's/^.*build_info: //' || true)"
        offload="$(grep -E 'offloaded [0-9]+/[0-9]+ layers to GPU' "$LLAMA_SERVER_LOG" | tail -n 1 | sed 's/^.*offloaded /offloaded /' || true)"
        kv_buffer="$(grep -E 'KV buffer size = ' "$LLAMA_SERVER_LOG" | tail -n 1 | sed 's/^.*KV buffer size = //' || true)"
        graph_splits="$(grep -E 'graph splits = ' "$LLAMA_SERVER_LOG" | tail -n 1 | sed 's/^.*graph splits = //' || true)"
        listening="$(grep -F 'server is listening on' "$LLAMA_SERVER_LOG" | tail -n 1 | sed 's/^.*server is listening on //' || true)"
    fi

    if [[ -n "$pid" ]] && ! pid_owned_by_manager "$pid"; then
        external_owner="yes"
        external_owner_unit="$(pid_systemd_unit "$pid" || true)"
        if [[ -n "$external_owner_unit" ]]; then
            external_owner_message="external systemd service appears to own port ${LLAMA_SERVER_PORT}; stop/disable ${external_owner_unit} or move one side to a different port"
        else
            external_owner_message="external llama-server process appears to own port ${LLAMA_SERVER_PORT}; stop/disable that service or move one side to a different port"
        fi
    fi

    if probe_server_binary; then
        binary_ok="yes"
    fi

    printf 'pid: %s\n' "${pid:-stopped}"
    printf 'alias: %s\n' "$alias"
    printf 'model: %s\n' "${model_path:-}"
    printf 'health: %s\n' "$health"
    printf 'host_os: %s\n' "$SELECTED_LLAMA_SERVER_HOST_OS"
    printf 'host_arch: %s\n' "$SELECTED_LLAMA_SERVER_HOST_ARCH"
    printf 'host_backends: %s\n' "$SELECTED_LLAMA_SERVER_HOST_BACKENDS"
    printf 'defaults_file: %s\n' "$DEFAULTS_FILE"
    printf 'registry_file: %s\n' "$MODELS_FILE"
    printf 'log: %s\n' "$LLAMA_SERVER_LOG"
    printf 'binary_ok: %s\n' "$binary_ok"
    printf 'binary: %s\n' "${SELECTED_LLAMA_SERVER_BIN:-}"
    printf 'binary_source: %s\n' "${SELECTED_LLAMA_SERVER_SOURCE:-none}"
    printf 'binary_backend: %s\n' "${SELECTED_LLAMA_SERVER_BACKEND:-none}"
    printf 'binary_status: %s\n' "${SELECTED_LLAMA_SERVER_STATUS:-unavailable}"
    printf 'binary_message: %s\n' "${SELECTED_LLAMA_SERVER_MESSAGE:-}"
    printf 'binary_guidance: %s\n' "${SELECTED_LLAMA_SERVER_GUIDANCE:-}"
    printf 'binary_label: %s\n' "${SELECTED_LLAMA_SERVER_LABEL:-}"
    printf 'external_owner: %s\n' "$external_owner"
    printf 'external_owner_unit: %s\n' "$external_owner_unit"
    printf 'external_owner_message: %s\n' "$external_owner_message"
    printf 'endpoint: http://%s:%s/v1\n' "$LLAMA_SERVER_HOST" "$LLAMA_SERVER_PORT"
    printf 'build_info: %s\n' "$build_info"
    printf 'offload: %s\n' "$offload"
    printf 'kv_buffer: %s\n' "$kv_buffer"
    printf 'graph_splits: %s\n' "$graph_splits"
    printf 'server: %s\n' "$listening"
}

show_mode() {
    local pid
    local active_parallel="stopped"

    pid="$(find_pid)"
    if [[ -n "$pid" ]]; then
        active_parallel="$(active_parallel_value "$pid")"
    fi

    printf 'configured_mode: %s\n' "$(configured_mode_name)"
    if [[ -n "${LLAMA_SERVER_PARALLEL:-}" ]]; then
        printf 'configured_parallel: %s\n' "$LLAMA_SERVER_PARALLEL"
    else
        printf 'configured_parallel: auto\n'
    fi
    printf 'active_parallel: %s\n' "$active_parallel"
    if [[ "$active_parallel" == "stopped" ]]; then
        printf 'active_mode: stopped\n'
    else
        printf 'active_mode: %s\n' "$(active_mode_name "$active_parallel")"
    fi
}

set_mode() {
    local mode="$1"
    local restart_after="${2:-}"

    case "$mode" in
        single)
            set_default_value "LLAMA_SERVER_PARALLEL" "1"
            LLAMA_SERVER_PARALLEL="1"
            ;;
        multi)
            set_default_value "LLAMA_SERVER_PARALLEL" ""
            LLAMA_SERVER_PARALLEL=""
            ;;
        *)
            die "unknown mode: $mode (expected single or multi)"
            ;;
    esac

    printf 'configured_mode: %s\n' "$(configured_mode_name)"
    if [[ -n "${LLAMA_SERVER_PARALLEL:-}" ]]; then
        printf 'configured_parallel: %s\n' "$LLAMA_SERVER_PARALLEL"
    else
        printf 'configured_parallel: auto\n'
    fi

    if [[ "$restart_after" == "--restart" ]]; then
        restart_model
    else
        printf 'note: restart the server to apply this mode\n'
    fi
}

switch_model() {
    local spec="$1"
    shift || true
    local resolved
    local alias
    local model_path
    local model_extra
    local model_context
    local model_ngl
    local model_batch
    local model_threads
    local model_parallel
    local model_device
    local model_notes
    local -a fields=()

    resolved="$(resolve_model "$spec")"
    mapfile -d '' -t fields < <(split_tsv_record "$resolved")
    alias="${fields[0]}"
    model_path="${fields[1]}"
    model_extra="${fields[2]}"
    model_context="${fields[3]}"
    model_ngl="${fields[4]}"
    model_batch="${fields[5]}"
    model_threads="${fields[6]}"
    model_parallel="${fields[7]}"
    model_device="${fields[8]}"
    model_notes="${fields[9]}"

    stop_server
    backup_log
    start_server "$alias" "$model_path" "$model_extra" "$model_context" "$model_ngl" "$model_batch" "$model_threads" "$model_parallel" "$model_device" "$@"
}

restart_model() {
    local spec="${1:-}"
    local pid
    local model_path
    local alias

    if [[ -n "$spec" ]]; then
        switch_model "$@"
        return 0
    fi

    pid="$(find_pid)"
    [[ -n "$pid" ]] || die "no running server and no model specified"

    model_path="$(cmd_arg_from_pid "$pid" -m || true)"
    alias="$(lookup_alias_for_path "$model_path" || true)"
    [[ -n "$alias" ]] || alias="$model_path"

    switch_model "$alias"
}

show_logs() {
    local lines="${1:-40}"
    tail -n "$lines" "$LLAMA_SERVER_LOG"
}

parse_add_options() {
    local alias="$1"
    local model_path="$2"
    shift 2 || true
    local extra=""
    local context=""
    local ngl=""
    local batch=""
    local threads=""
    local parallel=""
    local device=""
    local notes=""

    while (($#)); do
        case "$1" in
            --mmproj)
                [[ $# -ge 2 ]] || die "--mmproj requires a path"
                extra="$(trim_whitespace "${extra} --mmproj $2")"
                shift 2
                ;;
            --extra)
                [[ $# -ge 2 ]] || die "--extra requires a value"
                extra="$(trim_whitespace "${extra} $2")"
                shift 2
                ;;
            --context)
                [[ $# -ge 2 ]] || die "--context requires a value"
                context="$2"
                shift 2
                ;;
            --ngl)
                [[ $# -ge 2 ]] || die "--ngl requires a value"
                ngl="$2"
                shift 2
                ;;
            --batch)
                [[ $# -ge 2 ]] || die "--batch requires a value"
                batch="$2"
                shift 2
                ;;
            --threads)
                [[ $# -ge 2 ]] || die "--threads requires a value"
                threads="$2"
                shift 2
                ;;
            --parallel)
                [[ $# -ge 2 ]] || die "--parallel requires a value"
                parallel="$2"
                shift 2
                ;;
            --device)
                [[ $# -ge 2 ]] || die "--device requires a value"
                device="$2"
                shift 2
                ;;
            --notes)
                [[ $# -ge 2 ]] || die "--notes requires a value"
                notes="$2"
                shift 2
                ;;
            --)
                shift
                extra="$(trim_whitespace "${extra} $*")"
                break
                ;;
            *)
                die "unknown add option: $1"
                ;;
        esac
    done

    printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\n' \
        "$alias" "$model_path" "$extra" "$context" "$ngl" "$batch" "$threads" "$parallel" "$device" "$notes"
}

write_registry_line() {
    local alias="$1"
    local model_path="$2"
    local extra="$3"
    local context="$4"
    local ngl="$5"
    local batch="$6"
    local threads="$7"
    local parallel="$8"
    local device="$9"
    local notes="${10:-}"
    local -a fields=("$alias" "$model_path" "$extra" "$context" "$ngl" "$batch" "$threads" "$parallel" "$device" "$notes")

    while ((${#fields[@]} > 3)); do
        local last_index=$(( ${#fields[@]} - 1 ))
        if [[ -n "${fields[$last_index]}" ]]; then
            break
        fi
        unset 'fields[$last_index]'
    done

    local joined=""
    local field
    for field in "${fields[@]}"; do
        if [[ -n "$joined" ]]; then
            joined+=$'\t'
        fi
        joined+="$field"
    done
    printf '%s\n' "$joined"
}

add_model() {
    local alias="$1"
    local model_path="$2"
    shift 2 || true
    local parsed
    local extra
    local context
    local ngl
    local batch
    local threads
    local parallel
    local device
    local notes
    local tmp
    local existing_alias
    local raw_line
    local -a fields=()
    local line_alias
    local line_path
    local line_extra
    local line_context
    local line_ngl
    local line_batch
    local line_threads
    local line_parallel
    local line_device
    local line_notes
    local replaced=0

    alias="$(sanitize_alias "$alias")"
    [[ -n "$alias" ]] || die "alias resolved to empty value"

    model_path="$(canonicalize_path "$model_path")"
    [[ -f "$model_path" ]] || die "model not found: $model_path"

    parsed="$(parse_add_options "$alias" "$model_path" "$@")"
    mapfile -d '' -t fields < <(split_tsv_record "$parsed")
    existing_alias="${fields[0]}"
    model_path="${fields[1]}"
    extra="${fields[2]}"
    context="${fields[3]}"
    ngl="${fields[4]}"
    batch="${fields[5]}"
    threads="${fields[6]}"
    parallel="${fields[7]}"
    device="${fields[8]}"
    notes="${fields[9]}"

    ensure_models_file
    tmp="$(mktemp)"

    while IFS= read -r raw_line || [[ -n "$raw_line" ]]; do
        if [[ -z "$raw_line" ]] || [[ "${raw_line:0:1}" == "#" ]]; then
            printf '%s\n' "$raw_line" >>"$tmp"
            continue
        fi

        mapfile -d '' -t fields < <(split_tsv_record "$raw_line")
        line_alias="${fields[0]}"
        line_path="${fields[1]}"
        line_extra="${fields[2]}"
        line_context="${fields[3]}"
        line_ngl="${fields[4]}"
        line_batch="${fields[5]}"
        line_threads="${fields[6]}"
        line_parallel="${fields[7]}"
        line_device="${fields[8]}"
        line_notes="${fields[9]}"
        if [[ "$line_alias" == "$alias" ]]; then
            write_registry_line "$alias" "$model_path" "$extra" "$context" "$ngl" "$batch" "$threads" "$parallel" "$device" "$notes" >>"$tmp"
            replaced=1
        else
            printf '%s\n' "$raw_line" >>"$tmp"
        fi
    done <"$MODELS_FILE"

    if [[ "$replaced" -eq 0 ]]; then
        write_registry_line "$alias" "$model_path" "$extra" "$context" "$ngl" "$batch" "$threads" "$parallel" "$device" "$notes" >>"$tmp"
    fi

    mv "$tmp" "$MODELS_FILE"
    if [[ "$replaced" -eq 1 ]]; then
        printf 'updated %s in %s\n' "$alias" "$MODELS_FILE"
    else
        printf 'added %s to %s\n' "$alias" "$MODELS_FILE"
    fi
}

remove_model() {
    local alias="$1"
    local tmp
    local found=0
    local line_alias
    local line

    ensure_models_file
    tmp="$(mktemp)"

    while IFS= read -r line || [[ -n "$line" ]]; do
        if [[ -z "$line" ]] || [[ "${line:0:1}" == "#" ]]; then
            printf '%s\n' "$line" >>"$tmp"
            continue
        fi

        line_alias="${line%%$'\t'*}"
        if [[ "$line_alias" == "$alias" ]]; then
            found=1
            continue
        fi
        printf '%s\n' "$line" >>"$tmp"
    done <"$MODELS_FILE"

    [[ "$found" -eq 1 ]] || die "unknown model alias: $alias"
    mv "$tmp" "$MODELS_FILE"
    printf 'removed %s from %s\n' "$alias" "$MODELS_FILE"
}

guess_mmproj_for_model() {
    local model_path="$1"
    local dir
    local mmproj

    dir="$(dirname "$model_path")"
    mmproj="$(find "$dir" -maxdepth 1 -type f -iname '*mmproj*.gguf' | sort | head -n 1 || true)"
    if [[ -n "$mmproj" ]]; then
        printf '%s\n' "$mmproj"
    fi
}

discover_models() {
    local root="${1:-$HOME/models}"
    local model_path
    local basename
    local alias
    local imported
    local mmproj
    local extra

    [[ -d "$root" ]] || die "discover root not found: $root"

    printf '%-10s %-24s %-8s %s\n' "IMPORTED" "ALIAS" "MMPROJ" "MODEL"
    while IFS= read -r -d '' model_path; do
        basename="$(basename "$model_path")"
        if [[ "${basename,,}" == *mmproj* ]]; then
            continue
        fi

        alias="$(sanitize_alias "$basename")"
        imported="no"
        if lookup_alias_for_path "$(canonicalize_path "$model_path")" >/dev/null 2>&1; then
            imported="yes"
        fi

        mmproj="$(guess_mmproj_for_model "$model_path" || true)"
        extra="no"
        if [[ -n "$mmproj" ]]; then
            extra="yes"
        fi

        printf '%-10s %-24s %-8s %s\n' "$imported" "$alias" "$extra" "$(canonicalize_path "$model_path")"
    done < <(find "$root" -type f -name '*.gguf' -print0 | sort -z)
}



require_python3() {
    command_available python3 || die "python3 is required for this integration command"
}

upstream_api_base() {
    printf 'http://%s:%s/v1\n' "$LLAMA_SERVER_HOST" "$LLAMA_SERVER_PORT"
}

resolve_sync_target() {
    local spec="${1:-}"
    local resolved=""
    local pid=""
    local -a fields=()
    local alias=""
    local model_path=""
    local context=""
    local source=""

    if [[ -n "$spec" ]]; then
        resolved="$(resolve_model "$spec")"
        mapfile -d '' -t fields < <(split_tsv_record "$resolved")
        alias="${fields[0]}"
        model_path="${fields[1]}"
        context="${fields[3]}"
        source="explicit-target"
    else
        pid="$(find_pid)"
        if [[ -n "$pid" ]]; then
            model_path="$(cmd_arg_from_pid "$pid" -m || true)"
            [[ -n "$model_path" ]] || die "running llama-server on port $LLAMA_SERVER_PORT did not report a model path"
            alias="$(lookup_alias_for_path "$model_path" || true)"
            [[ -n "$alias" ]] || alias="custom"
            context="$(cmd_arg_from_pid "$pid" -c || true)"
            source="running-server"
        elif read_state_file && [[ -n "${CURRENT_MODEL:-}" ]]; then
            model_path="$CURRENT_MODEL"
            alias="${CURRENT_ALIAS:-custom}"
            context="${CURRENT_CONTEXT:-}"
            source="saved-state"
        else
            die "no running server and no saved model state; start or switch a model first"
        fi
    fi

    [[ -f "$model_path" ]] || die "model not found: $model_path"

    SYNC_TARGET_SOURCE="$source"
    SYNC_TARGET_ALIAS="$alias"
    SYNC_TARGET_MODEL_PATH="$(canonicalize_path "$model_path")"
    SYNC_TARGET_MODEL_NAME="$(basename "$SYNC_TARGET_MODEL_PATH")"
    if [[ -n "$alias" && "$alias" != "custom" ]]; then
        SYNC_TARGET_MODEL_ID="$alias"
    else
        SYNC_TARGET_MODEL_ID="$(sanitize_alias "$SYNC_TARGET_MODEL_PATH")"
    fi
    SYNC_TARGET_CONTEXT="${context:-$LLAMA_SERVER_CONTEXT}"
}

sync_glyphos() {
    [[ $# -le 1 ]] || die "sync-glyphos accepts at most one optional alias or path"
    local spec="${1:-}"
    local config_exists_before="no"
    local api_base
    local timeout_seconds

    resolve_sync_target "$spec"
    api_base="$(upstream_api_base)"
    timeout_seconds="$(trim_whitespace "${GLYPHOS_LLAMACPP_TIMEOUT_SECONDS:-300}")"
    [[ "$timeout_seconds" =~ ^[0-9]+$ ]] || die "GLYPHOS_LLAMACPP_TIMEOUT_SECONDS must be a positive integer"
    (( timeout_seconds >= 1 )) || die "GLYPHOS_LLAMACPP_TIMEOUT_SECONDS must be at least 1"
    [[ -f "$GLYPHOS_CONFIG_FILE" ]] && config_exists_before="yes"

    require_python3
    python3 "$APP_ROOT/scripts/integration_sync.py" glyphos         --config-file "$GLYPHOS_CONFIG_FILE"         --model-name "$SYNC_TARGET_MODEL_NAME"         --api-base "$api_base"         --timeout-seconds "$timeout_seconds"

    printf 'status: synced
'
    printf 'source: %s
' "$SYNC_TARGET_SOURCE"
    printf 'alias: %s
' "$SYNC_TARGET_ALIAS"
    printf 'model_path: %s
' "$SYNC_TARGET_MODEL_PATH"
    printf 'glyphos_model: %s
' "$SYNC_TARGET_MODEL_NAME"
    printf 'api_base: %s
' "$api_base"
    printf 'config_file: %s
' "$GLYPHOS_CONFIG_FILE"
    printf 'config_exists_before: %s
' "$config_exists_before"
    printf 'routing_preference: llamacpp
'
    printf 'timeout_seconds: %s
' "$timeout_seconds"
}

resolve_openclaw_config_file() {
    local profile="${1:-}"
    if [[ -z "$profile" || "$profile" == "main" ]]; then
        printf '%s\n' "$HOME/.openclaw/openclaw.json"
    else
        printf '%s\n' "$HOME/.openclaw-${profile}/openclaw.json"
    fi
}

opencode_preset_values() {
    local preset="${1:-balanced}"
    case "$preset" in
        balanced)
            printf '1800000\t60000\n'
            ;;
        long-run|longrun)
            printf '7200000\t300000\n'
            ;;
        *)
            die "unsupported opencode preset: $preset (expected balanced or long-run)"
            ;;
    esac
}

sync_opencode() {
    local preset="balanced"
    local spec=""
    local config_exists_before="no"
    local state_exists_before="no"
    local api_base
    local timeout_ms
    local chunk_timeout_ms
    local runtime_note=""

    while (($#)); do
        case "$1" in
            --preset)
                [[ $# -ge 2 ]] || die "--preset requires balanced or long-run"
                preset="$2"
                shift 2
                ;;
            *)
                [[ -z "$spec" ]] || die "sync-opencode accepts at most one optional alias or path"
                spec="$1"
                shift
                ;;
        esac
    done

    IFS=$'\t' read -r timeout_ms chunk_timeout_ms <<<"$(opencode_preset_values "$preset")"

    resolve_sync_target "$spec"
    api_base="$(upstream_api_base)"
    [[ -f "$OPENCODE_CONFIG_FILE" ]] && config_exists_before="yes"
    [[ -f "$OPENCODE_MODEL_STATE_FILE" ]] && state_exists_before="yes"
    if [[ "$preset" == "long-run" && "$(configured_mode_name)" != "single-client" ]]; then
        runtime_note="single-client recommended for long local reasoning sessions"
    fi
    require_python3
    python3 "$APP_ROOT/scripts/integration_sync.py" opencode \
        --config-file "$OPENCODE_CONFIG_FILE" \
        --state-file "$OPENCODE_MODEL_STATE_FILE" \
        --model-name "$SYNC_TARGET_MODEL_NAME" \
        --display-name "$SYNC_TARGET_MODEL_NAME" \
        --api-base "$api_base" \
        --timeout-ms "$timeout_ms" \
        --chunk-timeout-ms "$chunk_timeout_ms"

    printf 'status: synced\n'
    printf 'preset: %s\n' "$preset"
    printf 'source: %s\n' "$SYNC_TARGET_SOURCE"
    printf 'alias: %s\n' "$SYNC_TARGET_ALIAS"
    printf 'model_path: %s\n' "$SYNC_TARGET_MODEL_PATH"
    printf 'opencode_model: llamacpp/%s\n' "$SYNC_TARGET_MODEL_NAME"
    printf 'api_base: %s\n' "$api_base"
    printf 'timeout_ms: %s\n' "$timeout_ms"
    printf 'chunk_timeout_ms: %s\n' "$chunk_timeout_ms"
    printf 'runtime_note: %s\n' "$runtime_note"
    printf 'config_file: %s\n' "$OPENCODE_CONFIG_FILE"
    printf 'config_exists_before: %s\n' "$config_exists_before"
    printf 'state_file: %s\n' "$OPENCODE_MODEL_STATE_FILE"
    printf 'state_exists_before: %s\n' "$state_exists_before"
}

sync_openclaw() {
    local profile="$OPENCLAW_PROFILE"
    local spec=""
    local config_file
    local profile_label
    local config_exists_before="no"
    local api_base
    local api_key
    local context_window
    local max_tokens="4096"
    local workspace

    while (($#)); do
        case "$1" in
            --profile)
                [[ $# -ge 2 ]] || die "--profile requires a name"
                profile="$2"
                shift 2
                ;;
            *)
                [[ -z "$spec" ]] || die "sync-openclaw accepts at most one alias or path"
                spec="$1"
                shift
                ;;
        esac
    done

    resolve_sync_target "$spec"
    api_base="$(upstream_api_base)"
    api_key="$(trim_whitespace "${OPENCLAW_API_KEY:-llama-local}")"
    [[ -n "$api_key" ]] || api_key="llama-local"
    context_window="${SYNC_TARGET_CONTEXT:-$LLAMA_SERVER_CONTEXT}"
    [[ "$context_window" =~ ^[0-9]+$ ]] || context_window="$LLAMA_SERVER_CONTEXT"
    profile_label="${profile:-main}"
    config_file="$(resolve_openclaw_config_file "$profile")"
    [[ -f "$config_file" ]] && config_exists_before="yes"

    require_python3
    workspace="$(python3 "$APP_ROOT/scripts/integration_sync.py" openclaw \
        --config-file "$config_file" \
        --model-id "$SYNC_TARGET_MODEL_ID" \
        --display-name "$SYNC_TARGET_MODEL_NAME" \
        --alias "$SYNC_TARGET_ALIAS" \
        --api-base "$api_base" \
        --api-key "$api_key" \
        --context-window "$context_window" \
        --max-tokens "$max_tokens")"

    printf 'status: synced\n'
    printf 'source: %s\n' "$SYNC_TARGET_SOURCE"
    printf 'profile: %s\n' "$profile_label"
    printf 'alias: %s\n' "$SYNC_TARGET_ALIAS"
    printf 'model_path: %s\n' "$SYNC_TARGET_MODEL_PATH"
    printf 'openclaw_model: llamacpp/%s\n' "$SYNC_TARGET_MODEL_ID"
    printf 'api_base: %s\n' "$api_base"
    printf 'workspace: %s\n' "$workspace"
    printf 'config_file: %s\n' "$config_file"
    printf 'config_exists_before: %s\n' "$config_exists_before"
}

sync_claude() {
    [[ $# -le 1 ]] || die "sync-claude accepts at most one optional model id"
    local model_id="$(trim_whitespace "${1:-}")"
    local base_url
    local auth_token
    local api_key
    local api_key_source="unchanged"
    local settings_exists_before="no"

    if [[ -z "$model_id" ]]; then
        model_id="$(trim_whitespace "${CLAUDE_MODEL_ID:-}")"
    fi
    if [[ -z "$model_id" ]]; then
        resolve_sync_target ""
        model_id="$SYNC_TARGET_MODEL_ID"
    fi

    base_url="$(trim_whitespace "${CLAUDE_BASE_URL:-}")"
    if [[ -z "$base_url" ]]; then
        base_url="http://${CLAUDE_GATEWAY_HOST}:${CLAUDE_GATEWAY_PORT}"
    fi
    auth_token="$(trim_whitespace "${CLAUDE_AUTH_TOKEN:-${ANTHROPIC_AUTH_TOKEN:-}}")"
    api_key="$(trim_whitespace "${CLAUDE_API_KEY:-${ANTHROPIC_API_KEY:-}}")"
    if [[ -z "$api_key" && -n "$auth_token" ]]; then
        api_key="$auth_token"
        api_key_source="mirrored-from-auth-token"
    elif [[ -n "$api_key" ]]; then
        api_key_source="configured"
    fi
    [[ -f "$CLAUDE_SETTINGS_FILE" ]] && settings_exists_before="yes"

    require_python3
    python3 "$APP_ROOT/scripts/integration_sync.py" claude \
        --settings-file "$CLAUDE_SETTINGS_FILE" \
        --model-id "$model_id" \
        --base-url "$base_url" \
        --auth-token "$auth_token" \
        --api-key "$api_key"

    printf 'status: synced\n'
    printf 'model_id: %s\n' "$model_id"
    printf 'base_url: %s\n' "$base_url"
    printf 'settings_file: %s\n' "$CLAUDE_SETTINGS_FILE"
    printf 'settings_exists_before: %s\n' "$settings_exists_before"
    printf 'claude_auth: %s\n' "$([[ -n "$auth_token" ]] && printf configured || printf unchanged)"
    printf 'claude_api_key: %s\n' "$api_key_source"
}

claude_gateway_script() {
    local script="$APP_ROOT/scripts/claude_gateway.py"
    [[ -f "$script" ]] || die "Claude gateway script not found: $script"
    printf '%s\n' "$script"
}

claude_gateway_model_id() {
    local model_id
    model_id="$(trim_whitespace "${CLAUDE_MODEL_ID:-}")"
    if [[ -n "$model_id" ]]; then
        printf '%s\n' "$model_id"
        return 0
    fi
    resolve_sync_target ""
    printf '%s\n' "$SYNC_TARGET_MODEL_ID"
}

claude_gateway_url() {
    printf 'http://%s:%s\n' "$CLAUDE_GATEWAY_HOST" "$CLAUDE_GATEWAY_PORT"
}

claude_gateway_upstream_base() {
    upstream_api_base
}

claude_gateway_timeout_seconds() {
    local upstream_timeout_seconds
    upstream_timeout_seconds="$(trim_whitespace "${CLAUDE_GATEWAY_UPSTREAM_TIMEOUT_SECONDS:-1800}")"
    [[ "$upstream_timeout_seconds" =~ ^[0-9]+$ ]] || die "CLAUDE_GATEWAY_UPSTREAM_TIMEOUT_SECONDS must be a positive integer"
    (( upstream_timeout_seconds >= 1 )) || die "CLAUDE_GATEWAY_UPSTREAM_TIMEOUT_SECONDS must be at least 1"
    printf '%s
' "$upstream_timeout_seconds"
}

claude_gateway_pid() {
    [[ -f "$CLAUDE_GATEWAY_PID_FILE" ]] || return 1
    cat "$CLAUDE_GATEWAY_PID_FILE"
}

claude_gateway_listener_pid() {
    local pid=""

    if command_available lsof; then
        pid="$(lsof -tiTCP:"$CLAUDE_GATEWAY_PORT" -sTCP:LISTEN 2>/dev/null | head -n 1 || true)"
        [[ -n "$pid" ]] && { printf '%s\n' "$pid"; return 0; }
    fi

    if command_available ss; then
        pid="$(ss -ltnp "( sport = :$CLAUDE_GATEWAY_PORT )" 2>/dev/null | sed -n 's/.*pid=\([0-9]\+\).*/\1/p' | head -n 1 || true)"
        [[ -n "$pid" ]] && { printf '%s\n' "$pid"; return 0; }
    fi

    pid="$(pgrep -af 'claude_gateway.py' 2>/dev/null | awk -v port="$CLAUDE_GATEWAY_PORT" '$0 ~ ("--port " port "([[:space:]]|$)") { print $1; exit }' || true)"
    [[ -n "$pid" ]] && printf '%s\n' "$pid"
}

pid_matches_claude_gateway() {
    local pid="$1"
    local cmdline

    cmdline="$(pid_command_line "$pid")"
    [[ -n "$cmdline" ]] || return 1
    [[ "$cmdline" == *claude_gateway.py* ]] || return 1
    [[ "$cmdline" == *"--port ${CLAUDE_GATEWAY_PORT}"* ]] || return 1
    return 0
}

claude_gateway_health_ok() {
    curl -fsS "$(claude_gateway_url)/healthz" >/dev/null 2>&1
}

claude_gateway_detect_pid() {
    local pid=""

    pid="$(claude_gateway_pid 2>/dev/null || true)"
    if [[ -n "$pid" ]] && kill -0 "$pid" 2>/dev/null && pid_matches_claude_gateway "$pid"; then
        printf '%s\n' "$pid"
        return 0
    fi

    pid="$(claude_gateway_listener_pid 2>/dev/null || true)"
    if [[ -n "$pid" ]] && kill -0 "$pid" 2>/dev/null && pid_matches_claude_gateway "$pid"; then
        printf '%s\n' "$pid"
        return 0
    fi

    return 1
}

claude_gateway_running() {
    claude_gateway_health_ok
}

claude_gateway_wait_ready() {
    local pid="$1"
    local url="$(claude_gateway_url)/healthz"
    local waited

    for waited in $(seq 1 30); do
        if curl -fsS "$url" >/dev/null 2>&1; then
            return 0
        fi
        if ! kill -0 "$pid" 2>/dev/null; then
            tail -n 60 "$CLAUDE_GATEWAY_LOG" >&2 || true
            die "claude gateway exited during startup"
        fi
        sleep 1
    done
    tail -n 60 "$CLAUDE_GATEWAY_LOG" >&2 || true
    die "timed out waiting for $(claude_gateway_url)/healthz"
}

claude_gateway_start() {
    local script
    local pid=""
    local listener_pid=""
    local model_id=""
    local upstream_base
    local upstream_timeout_seconds
    local -a cmd=()
    require_python3
    script="$(claude_gateway_script)"
    upstream_base="$(claude_gateway_upstream_base)"
    upstream_timeout_seconds="$(claude_gateway_timeout_seconds)"
    model_id="$(claude_gateway_model_id 2>/dev/null || true)"
    mkdir -p "$(dirname "$CLAUDE_GATEWAY_LOG")" "$(dirname "$CLAUDE_GATEWAY_PID_FILE")"

    listener_pid="$(claude_gateway_listener_pid 2>/dev/null || true)"
    if claude_gateway_health_ok; then
        pid="$listener_pid"
        if [[ -z "$pid" ]]; then
            pid="$(claude_gateway_pid 2>/dev/null || true)"
        fi
        if [[ -n "$pid" ]]; then
            printf '%s\n' "$pid" > "$CLAUDE_GATEWAY_PID_FILE"
        fi
        printf 'status: running\n'
        printf 'pid: %s\n' "$pid"
        printf 'url: %s\n' "$(claude_gateway_url)"
        printf 'upstream_base: %s\n' "$upstream_base"
        printf 'model_id: %s\n' "$model_id"
        printf 'log: %s\n' "$CLAUDE_GATEWAY_LOG"
        return 0
    fi

    if [[ -n "$listener_pid" ]] && ! pid_matches_claude_gateway "$listener_pid"; then
        die "port ${CLAUDE_GATEWAY_PORT} is already occupied by another process"
    fi

    cmd=(python3 "$script" --host "$CLAUDE_GATEWAY_HOST" --port "$CLAUDE_GATEWAY_PORT" --upstream-base "$upstream_base" --upstream-timeout-seconds "$upstream_timeout_seconds")
    if [[ -n "$model_id" ]]; then
        cmd+=(--advertised-model-id "$model_id")
    fi

    setsid "${cmd[@]}" >"$CLAUDE_GATEWAY_LOG" 2>&1 < /dev/null &
    pid=$!
    disown "$pid" 2>/dev/null || true
    printf '%s\n' "$pid" > "$CLAUDE_GATEWAY_PID_FILE"
    claude_gateway_wait_ready "$pid"

    printf 'status: running\n'
    printf 'pid: %s\n' "$pid"
    printf 'url: %s\n' "$(claude_gateway_url)"
    printf 'upstream_base: %s\n' "$upstream_base"
    printf 'model_id: %s\n' "$model_id"
    printf 'log: %s\n' "$CLAUDE_GATEWAY_LOG"
}

claude_gateway_stop() {
    local pid
    pid="$(claude_gateway_detect_pid 2>/dev/null || true)"
    if [[ -z "$pid" ]]; then
        pid="$(claude_gateway_listener_pid 2>/dev/null || true)"
    fi
    if [[ -z "$pid" ]]; then
        rm -f "$CLAUDE_GATEWAY_PID_FILE"
        printf 'status: stopped\n'
        return 0
    fi
    kill -TERM "$pid" 2>/dev/null || true
    for _ in $(seq 1 15); do
        if ! kill -0 "$pid" 2>/dev/null; then
            rm -f "$CLAUDE_GATEWAY_PID_FILE"
            printf 'status: stopped\n'
            return 0
        fi
        sleep 1
    done
    die "claude gateway pid $pid did not stop"
}

claude_gateway_restart() {
    claude_gateway_stop >/dev/null 2>&1 || true
    claude_gateway_start
}

claude_gateway_status() {
    local running="no"
    local pid=""
    local model_id="$(claude_gateway_model_id 2>/dev/null || true)"
    local upstream_timeout_seconds="$(claude_gateway_timeout_seconds)"
    pid="$(claude_gateway_detect_pid 2>/dev/null || true)"
    if [[ -z "$pid" ]]; then
        pid="$(claude_gateway_listener_pid 2>/dev/null || true)"
    fi
    if claude_gateway_health_ok; then
        running="yes"
        if [[ -n "$pid" ]]; then
            printf '%s\n' "$pid" > "$CLAUDE_GATEWAY_PID_FILE"
        fi
    fi
    printf 'running: %s\n' "$running"
    printf 'pid: %s\n' "$pid"
    printf 'url: %s\n' "$(claude_gateway_url)"
    printf 'upstream_base: %s\n' "$(claude_gateway_upstream_base)"
    printf 'upstream_timeout_seconds: %s\n' "$upstream_timeout_seconds"
    printf 'model_id: %s\n' "$model_id"
    printf 'log: %s\n' "$CLAUDE_GATEWAY_LOG"
}

claude_gateway_logs() {
    local lines="${1:-100}"
    tail -n "$lines" "$CLAUDE_GATEWAY_LOG"
}

claude_gateway_command() {
    local action="${1:-status}"
    shift || true
    case "$action" in
        start) claude_gateway_start ;;
        stop) claude_gateway_stop ;;
        restart) claude_gateway_restart ;;
        status) claude_gateway_status ;;
        logs) claude_gateway_logs "$@" ;;
        help|-h|--help)
            printf '%s\n' 'Usage: llama-model claude-gateway start|stop|restart|status|logs'
            ;;
        *) die "unknown claude-gateway action: $action" ;;
    esac
}

dashboard_systemctl_available() {
    if [[ -n "${LLAMA_MODEL_SYSTEMCTL_BIN:-}" ]]; then
        [[ -x "$LLAMA_MODEL_SYSTEMCTL_BIN" ]]
        return $?
    fi
    command_available systemctl
}

dashboard_systemctl() {
    if [[ -n "${LLAMA_MODEL_SYSTEMCTL_BIN:-}" ]]; then
        "$LLAMA_MODEL_SYSTEMCTL_BIN" --user "$@"
    else
        systemctl --user "$@"
    fi
}

dashboard_journalctl_available() {
    if [[ -n "${LLAMA_MODEL_JOURNALCTL_BIN:-}" ]]; then
        [[ -x "$LLAMA_MODEL_JOURNALCTL_BIN" ]]
        return $?
    fi
    command_available journalctl
}

dashboard_journalctl() {
    if [[ -n "${LLAMA_MODEL_JOURNALCTL_BIN:-}" ]]; then
        "$LLAMA_MODEL_JOURNALCTL_BIN" "$@"
    else
        journalctl "$@"
    fi
}

dashboard_service_dir_writable() {
    local target="$DASHBOARD_SERVICE_UNIT_DIR"

    while [[ ! -e "$target" ]]; do
        target="$(dirname "$target")"
    done

    [[ -d "$target" && -w "$target" ]]
}

dashboard_service_manager_reachable() {
    dashboard_systemctl_available || return 1
    dashboard_systemctl show-environment >/dev/null 2>&1
}

dashboard_service_installed() {
    [[ -f "$DASHBOARD_SERVICE_UNIT_FILE" ]]
}

dashboard_service_enabled() {
    dashboard_service_installed && dashboard_service_manager_reachable && dashboard_systemctl is-enabled "$DASHBOARD_SERVICE_NAME" >/dev/null 2>&1
}

dashboard_service_active() {
    dashboard_service_installed && dashboard_service_manager_reachable && dashboard_systemctl is-active "$DASHBOARD_SERVICE_NAME" >/dev/null 2>&1
}

dashboard_service_unit_text() {
    cat <<EOF
[Unit]
Description=LLM Model Manager Dashboard
After=default.target

[Service]
Type=simple
ExecStart=%h/.local/bin/llama-model-web --no-browser --require-bind --host ${DASHBOARD_SERVICE_HOST} --port ${DASHBOARD_SERVICE_PORT}
Environment=LLAMA_MODEL_WEB_SERVICE=1
Restart=on-failure
RestartSec=3

[Install]
WantedBy=default.target
EOF
}

dashboard_service_status() {
    local supported="no"
    local manager_reachable="no"
    local installable="no"
    local installed="no"
    local enabled="no"
    local active="no"
    local logs_available="no"
    local status="unavailable"
    local message="Background dashboard service is available only on systems with systemd user services."

    if dashboard_systemctl_available; then
        supported="yes"
        if dashboard_journalctl_available; then
            logs_available="yes"
        fi
        if dashboard_service_dir_writable; then
            installable="yes"
        fi
        if dashboard_service_manager_reachable; then
            manager_reachable="yes"
            message="The dashboard normally runs on demand and does not stay resident. Install the optional background service only if you want it available at all times."
        else
            message="systemd user services are installed but the user service manager is not reachable in this session."
        fi
        if dashboard_service_installed; then
            installed="yes"
        fi
        if [[ "$manager_reachable" == "yes" ]]; then
            if dashboard_service_enabled; then
                enabled="yes"
            fi
            if dashboard_service_active; then
                active="yes"
            fi
        fi
        if [[ "$installed" == "yes" ]]; then
            if [[ "$active" == "yes" ]]; then
                status="running"
                message="Background dashboard service is running."
            else
                status="stopped"
                if [[ "$enabled" == "yes" ]]; then
                    message="Background dashboard service is installed and enabled at login, but not currently running."
                else
                    message="Background dashboard service is installed but stopped."
                fi
            fi
        elif [[ "$manager_reachable" == "yes" ]]; then
            status="not-installed"
            message="The dashboard normally runs on demand and does not stay resident. Install the optional background service only if you want it available at all times."
        fi
    fi

    printf 'supported: %s\n' "$supported"
    printf 'manager_reachable: %s\n' "$manager_reachable"
    printf 'installable: %s\n' "$installable"
    printf 'installed: %s\n' "$installed"
    printf 'enabled: %s\n' "$enabled"
    printf 'active: %s\n' "$active"
    printf 'logs_available: %s\n' "$logs_available"
    printf 'status: %s\n' "$status"
    printf 'unit: %s\n' "$DASHBOARD_SERVICE_NAME"
    printf 'unit_file: %s\n' "$DASHBOARD_SERVICE_UNIT_FILE"
    printf 'url: %s\n' "$DASHBOARD_SERVICE_URL"
    printf 'host: %s\n' "$DASHBOARD_SERVICE_HOST"
    printf 'port: %s\n' "$DASHBOARD_SERVICE_PORT"
    printf 'message: %s\n' "$message"
}

dashboard_service_require_support() {
    dashboard_systemctl_available || die "Background dashboard service is available only on systems with systemd user services"
    dashboard_service_manager_reachable || die "systemd user service manager is not reachable in this session"
    dashboard_service_dir_writable || die "dashboard service unit directory is not writable: $DASHBOARD_SERVICE_UNIT_DIR"
}

dashboard_service_require_installed_bin() {
    [[ -x "$DASHBOARD_SERVICE_INSTALLED_BIN" ]] || die "installed dashboard launcher not found: $DASHBOARD_SERVICE_INSTALLED_BIN"
}

dashboard_service_install() {
    dashboard_service_require_support
    dashboard_service_require_installed_bin
    mkdir -p "$DASHBOARD_SERVICE_UNIT_DIR"
    dashboard_service_unit_text >"$DASHBOARD_SERVICE_UNIT_FILE"
    chmod 0644 "$DASHBOARD_SERVICE_UNIT_FILE"
    dashboard_systemctl daemon-reload
    printf 'installed %s\n' "$DASHBOARD_SERVICE_UNIT_FILE"
}

dashboard_service_enable() {
    dashboard_service_require_support
    dashboard_service_installed || die "dashboard service is not installed"
    dashboard_systemctl enable "$DASHBOARD_SERVICE_NAME"
    printf 'enabled %s\n' "$DASHBOARD_SERVICE_NAME"
}

dashboard_service_disable() {
    dashboard_service_require_support
    dashboard_service_installed || die "dashboard service is not installed"
    dashboard_systemctl disable "$DASHBOARD_SERVICE_NAME"
    printf 'disabled %s\n' "$DASHBOARD_SERVICE_NAME"
}

dashboard_service_start() {
    dashboard_service_require_support
    dashboard_service_installed || die "dashboard service is not installed"
    dashboard_systemctl start "$DASHBOARD_SERVICE_NAME"
    printf 'started %s\n' "$DASHBOARD_SERVICE_NAME"
}

dashboard_service_stop() {
    dashboard_service_require_support
    dashboard_service_installed || die "dashboard service is not installed"
    dashboard_systemctl stop "$DASHBOARD_SERVICE_NAME"
    printf 'stopped %s\n' "$DASHBOARD_SERVICE_NAME"
}

dashboard_service_restart() {
    dashboard_service_require_support
    dashboard_service_installed || die "dashboard service is not installed"
    dashboard_systemctl restart "$DASHBOARD_SERVICE_NAME"
    printf 'restarted %s\n' "$DASHBOARD_SERVICE_NAME"
}

dashboard_service_logs() {
    local lines="${1:-100}"
    dashboard_service_require_support
    dashboard_journalctl_available || die "journalctl is required to read dashboard service logs"
    dashboard_journalctl --user -u "$DASHBOARD_SERVICE_NAME" -n "$lines" --no-pager
}

dashboard_service_uninstall() {
    if dashboard_service_manager_reachable && dashboard_service_installed; then
        dashboard_systemctl disable --now "$DASHBOARD_SERVICE_NAME" >/dev/null 2>&1 || true
        dashboard_systemctl reset-failed "$DASHBOARD_SERVICE_NAME" >/dev/null 2>&1 || true
    fi
    dashboard_service_installed || die "dashboard service is not installed"
    rm -f "$DASHBOARD_SERVICE_UNIT_FILE"
    if dashboard_service_manager_reachable; then
        dashboard_systemctl daemon-reload
    fi
    printf 'removed %s\n' "$DASHBOARD_SERVICE_UNIT_FILE"
}

dashboard_service_command() {
    local action="${1:-status}"
    shift || true

    case "$action" in
        install) dashboard_service_install "$@" ;;
        enable) dashboard_service_enable "$@" ;;
        disable) dashboard_service_disable "$@" ;;
        start) dashboard_service_start "$@" ;;
        stop) dashboard_service_stop "$@" ;;
        restart) dashboard_service_restart "$@" ;;
        status) dashboard_service_status ;;
        logs) dashboard_service_logs "$@" ;;
        uninstall|remove) dashboard_service_uninstall ;;
        help|-h|--help)
            printf '%s\n' 'Usage: llama-model dashboard-service install|enable|disable|start|stop|restart|status|logs|uninstall'
            ;;
        *) die "unknown dashboard-service action: $action" ;;
    esac
}

main() {
    local cmd="${1:-}"

    case "$cmd" in
        list)
            shift
            list_models "$@"
            ;;
        show)
            shift
            [[ $# -ge 1 ]] || die "show requires a model alias"
            show_model "$@"
            ;;
        add)
            shift
            [[ $# -ge 2 ]] || die "add requires an alias and model path"
            add_model "$@"
            ;;
        remove)
            shift
            [[ $# -ge 1 ]] || die "remove requires a model alias"
            remove_model "$@"
            ;;
        discover)
            shift
            discover_models "$@"
            ;;
        current)
            shift
            show_current "$@"
            ;;
        doctor)
            shift
            show_doctor "$@"
            ;;
        build-runtime)
            shift
            build_runtime "$@"
            ;;
        mode)
            shift
            show_mode "$@"
            ;;
        set-mode)
            shift
            [[ $# -ge 1 ]] || die "set-mode requires single or multi"
            set_mode "$@"
            ;;
        switch)
            shift
            [[ $# -ge 1 ]] || die "switch requires a model alias or path"
            switch_model "$@"
            ;;
        restart)
            shift
            restart_model "$@"
            ;;
        sync-opencode)
            shift
            sync_opencode "$@"
            ;;
        sync-openclaw)
            shift
            sync_openclaw "$@"
            ;;
        sync-claude)
            shift
            sync_claude "$@"
            ;;
        sync-glyphos)
            shift
            sync_glyphos "$@"
            ;;
        claude-gateway)
            shift
            claude_gateway_command "$@"
            ;;
        stop)
            shift
            stop_server
            printf 'stopped llama-server on port %s\n' "$LLAMA_SERVER_PORT"
            ;;
        logs)
            shift
            show_logs "$@"
            ;;
        dashboard-service)
            shift
            dashboard_service_command "$@"
            ;;
        help|-h|--help|"")
            usage
            ;;
        *)
            die "unknown command: $cmd"
            ;;
    esac
}

if [[ "${BASH_SOURCE[0]}" == "$0" ]]; then
    main "$@"
fi
