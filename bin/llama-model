#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
APP_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
INSTALLED_APP_ROOT="${XDG_DATA_HOME:-$HOME/.local/share}/llama-model-manager"
if [[ ! -d "$APP_ROOT/web" ]] && [[ -d "$INSTALLED_APP_ROOT" ]]; then
    APP_ROOT="$INSTALLED_APP_ROOT"
fi

DEFAULT_LLAMA_SERVER_BIN="$HOME/.local/bin/llama-server"
if command -v llama-server >/dev/null 2>&1; then
    DEFAULT_LLAMA_SERVER_BIN="$(command -v llama-server)"
fi

CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/llama-server"
STATE_DIR="${XDG_STATE_HOME:-$HOME/.local/state}/llama-server"
DEFAULTS_FILE="${LLAMA_DEFAULTS_FILE:-$CONFIG_DIR/defaults.env}"
MODELS_FILE="${LLAMA_MODELS_FILE:-$CONFIG_DIR/models.tsv}"
STATE_FILE="${LLAMA_STATE_FILE:-$STATE_DIR/current.env}"
LLAMA_SERVER_RUNTIME_DIR="${LLAMA_SERVER_RUNTIME_DIR:-$APP_ROOT/runtime}"
LLAMA_CPP_REPO_URL="${LLAMA_CPP_REPO_URL:-https://github.com/ggml-org/llama.cpp.git}"
LLAMA_CPP_REF="${LLAMA_CPP_REF:-b8851}"

LLAMA_SERVER_BIN="$DEFAULT_LLAMA_SERVER_BIN"
LLAMA_SERVER_HOST="127.0.0.1"
LLAMA_SERVER_PORT="8081"
LLAMA_SERVER_DEVICE=""
LLAMA_SERVER_CONTEXT="128000"
LLAMA_SERVER_NGL="999"
LLAMA_SERVER_BATCH="128"
LLAMA_SERVER_THREADS="16"
LLAMA_SERVER_PARALLEL=""
GGML_CUDA_ENABLE_UNIFIED_MEMORY="${GGML_CUDA_ENABLE_UNIFIED_MEMORY:-}"
LLAMA_SERVER_LOG="$HOME/models/llama-server.log"
LLAMA_SERVER_WAIT_SECONDS="300"
LLAMA_SERVER_EXTRA_ARGS=""
LLAMA_MODEL_AUTO_FIT="${LLAMA_MODEL_AUTO_FIT:-1}"

DASHBOARD_SERVICE_NAME="llama-model-web.service"
DASHBOARD_SERVICE_UNIT_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/systemd/user"
DASHBOARD_SERVICE_UNIT_FILE="$DASHBOARD_SERVICE_UNIT_DIR/$DASHBOARD_SERVICE_NAME"
DASHBOARD_SERVICE_INSTALLED_BIN="$HOME/.local/bin/llama-model-web"
DASHBOARD_SERVICE_HOST="${LLAMA_MODEL_WEB_HOST:-127.0.0.1}"
DASHBOARD_SERVICE_PORT="${LLAMA_MODEL_WEB_PORT:-8765}"
DASHBOARD_SERVICE_URL="http://${DASHBOARD_SERVICE_HOST}:${DASHBOARD_SERVICE_PORT}/"
OPENCODE_CONFIG_FILE="${OPENCODE_CONFIG_FILE:-${XDG_CONFIG_HOME:-$HOME/.config}/opencode/opencode.json}"
OPENCODE_MODEL_STATE_FILE="${OPENCODE_MODEL_STATE_FILE:-${XDG_STATE_HOME:-$HOME/.local/state}/opencode/model.json}"
OPENCLAW_PROFILE="${OPENCLAW_PROFILE:-}"
OPENCLAW_API_KEY="${OPENCLAW_API_KEY:-llama-local}"
CLAUDE_SETTINGS_FILE="${CLAUDE_SETTINGS_FILE:-$HOME/.claude/settings.json}"
CLAUDE_GATEWAY_HOST="${CLAUDE_GATEWAY_HOST:-127.0.0.1}"
CLAUDE_GATEWAY_PORT="${CLAUDE_GATEWAY_PORT:-4000}"
CLAUDE_GATEWAY_LOG="${CLAUDE_GATEWAY_LOG:-$HOME/models/claude-gateway.log}"
CLAUDE_GATEWAY_UPSTREAM_TIMEOUT_SECONDS="${CLAUDE_GATEWAY_UPSTREAM_TIMEOUT_SECONDS:-1800}"
CLAUDE_GATEWAY_PID_FILE="${CLAUDE_GATEWAY_PID_FILE:-$STATE_DIR/claude-gateway.pid}"
CLAUDE_BASE_URL="${CLAUDE_BASE_URL:-}"
CLAUDE_MODEL_ID="${CLAUDE_MODEL_ID:-}"
CLAUDE_AUTH_TOKEN="${CLAUDE_AUTH_TOKEN:-}"
CLAUDE_API_KEY="${CLAUDE_API_KEY:-}"
GLYPHOS_CONFIG_FILE="${GLYPHOS_CONFIG_FILE:-$HOME/.glyphos/config.yaml}"
GLYPHOS_LLAMACPP_TIMEOUT_SECONDS="${GLYPHOS_LLAMACPP_TIMEOUT_SECONDS:-${LMM_GATEWAY_TIMEOUT_SECONDS:-3600}}"
LLAMA_MODEL_GATEWAY_HOST="${LLAMA_MODEL_GATEWAY_HOST:-127.0.0.1}"
LLAMA_MODEL_GATEWAY_PORT="${LLAMA_MODEL_GATEWAY_PORT:-4010}"
LLAMA_MODEL_GATEWAY_LOG="${LLAMA_MODEL_GATEWAY_LOG:-$HOME/models/lmm-gateway.log}"
LLAMA_MODEL_GATEWAY_PID_FILE="${LLAMA_MODEL_GATEWAY_PID_FILE:-$STATE_DIR/lmm-gateway.pid}"
LLAMA_MODEL_HARNESS_MODE="${LLAMA_MODEL_HARNESS_MODE:-routed}"
LLAMA_MODEL_AUTOSTART_GATEWAY_ON_SYNC="${LLAMA_MODEL_AUTOSTART_GATEWAY_ON_SYNC:-1}"
LLAMA_MODEL_SYNC_OPENCODE="${LLAMA_MODEL_SYNC_OPENCODE:-1}"
LLAMA_MODEL_SYNC_CLAUDE="${LLAMA_MODEL_SYNC_CLAUDE:-0}"
LLAMA_MODEL_SYNC_OPENCLAW="${LLAMA_MODEL_SYNC_OPENCLAW:-0}"
LLAMA_MODEL_SYNC_GLYPHOS="${LLAMA_MODEL_SYNC_GLYPHOS:-0}"

PHASE0_SCHEMA_VERSION=1
REMOTE_MODELS_FILE="$STATE_DIR/remote-models.json"
DOWNLOAD_JOBS_FILE="$STATE_DIR/download-jobs.json"
VALIDATION_RESULTS_FILE="$STATE_DIR/validation-results.json"
HOST_CAPABILITY_FILE="$STATE_DIR/host-capability.json"
RUNTIME_PROFILES_FILE="$CONFIG_DIR/runtime-profiles.json"
LLAMA_MODEL_WEB_HOST="${LLAMA_MODEL_WEB_HOST:-$DASHBOARD_SERVICE_HOST}"
LLAMA_MODEL_WEB_PORT="${LLAMA_MODEL_WEB_PORT:-$DASHBOARD_SERVICE_PORT}"

expand_user_path_literal() {
    local value="$1"

    case "$value" in
        '$HOME')
            printf '%s\n' "$HOME"
            ;;
        '$HOME'/*)
            printf '%s/%s\n' "$HOME" "${value#\$HOME/}"
            ;;
        '${HOME}')
            printf '%s\n' "$HOME"
            ;;
        '${HOME}'/*)
            printf '%s/%s\n' "$HOME" "${value#\$\{HOME\}/}"
            ;;
        "~")
            printf '%s\n' "$HOME"
            ;;
        "~"/*)
            printf '%s/%s\n' "$HOME" "${value#\~/}"
            ;;
        *)
            printf '%s\n' "$value"
            ;;
    esac
}

if [[ -f "$DEFAULTS_FILE" ]]; then
    # User-tunable runtime defaults live here, not in the wrapper itself.
    # shellcheck disable=SC1090
    source "$DEFAULTS_FILE"
fi

LLAMA_SERVER_LOG="$(expand_user_path_literal "$LLAMA_SERVER_LOG")"
CLAUDE_GATEWAY_LOG="$(expand_user_path_literal "$CLAUDE_GATEWAY_LOG")"
CLAUDE_GATEWAY_PID_FILE="$(expand_user_path_literal "$CLAUDE_GATEWAY_PID_FILE")"
CLAUDE_SETTINGS_FILE="$(expand_user_path_literal "$CLAUDE_SETTINGS_FILE")"
GLYPHOS_CONFIG_FILE="$(expand_user_path_literal "$GLYPHOS_CONFIG_FILE")"
OPENCODE_CONFIG_FILE="$(expand_user_path_literal "$OPENCODE_CONFIG_FILE")"
OPENCODE_MODEL_STATE_FILE="$(expand_user_path_literal "$OPENCODE_MODEL_STATE_FILE")"
LLAMA_MODEL_GATEWAY_LOG="$(expand_user_path_literal "$LLAMA_MODEL_GATEWAY_LOG")"
LLAMA_MODEL_GATEWAY_PID_FILE="$(expand_user_path_literal "$LLAMA_MODEL_GATEWAY_PID_FILE")"

REQUESTED_LLAMA_SERVER_BIN="${LLAMA_SERVER_BIN:-}"
mkdir -p "$STATE_DIR"

SELECTED_LLAMA_SERVER_BIN=""
SELECTED_LLAMA_SERVER_SOURCE=""
SELECTED_LLAMA_SERVER_BACKEND=""
SELECTED_LLAMA_SERVER_STATUS=""
SELECTED_LLAMA_SERVER_MESSAGE=""
SELECTED_LLAMA_SERVER_GUIDANCE=""
SELECTED_LLAMA_SERVER_HOST_OS=""
SELECTED_LLAMA_SERVER_HOST_ARCH=""
SELECTED_LLAMA_SERVER_HOST_BACKENDS=""
SELECTED_LLAMA_SERVER_LABEL=""
SELECTED_LLAMA_SERVER_BUNDLE_MANIFEST=""
SELECTED_LLAMA_SERVER_PATH_KIND=""
BUNDLE_VALIDATE_REASON=""
BUNDLE_VALIDATE_BACKEND=""
BUNDLE_VALIDATE_LABEL=""
BUNDLE_VALIDATE_MANIFEST=""
EXTERNAL_VALIDATE_REASON=""
BUNDLED_SELECTION_FAILURE_REASON=""
ADD_FORCE_MMPROJ="0"

usage() {
    cat <<'EOF'
Usage:
  llama-model list
  llama-model show <alias>
  llama-model add <alias> <path> [--mmproj <path>] [--extra "<args>"] [--context N] [--ngl N] [--batch N] [--threads N] [--parallel auto|N] [--device NAME] [--notes TEXT]
  llama-model remove <alias>
  llama-model discover [root]
  llama-model current
  llama-model doctor
  llama-model build-runtime [--backend auto|cpu|cuda|vulkan|metal] [--ref REF]
  llama-model mode
  llama-model set-mode <single|multi> [--restart]
  llama-model switch <alias|/path/to/model.gguf> [extra llama-server args...]
  llama-model restart [alias|/path/to/model.gguf] [extra llama-server args...]
  llama-model sync-opencode [--mode routed|direct] [--preset balanced|long-run] [alias|/path/to/model.gguf]
  llama-model sync-openclaw [--mode routed|direct] [--profile NAME] [alias|/path/to/model.gguf]
  llama-model sync-claude [model-id]
  llama-model sync-glyphos [alias|/path/to/model.gguf]
  llama-model context-mcp status|build
  llama-model update-check [--component lmm|llamacpp|all] [--json]
  llama-model gateway start|stop|restart|status|logs
  llama-model claude-gateway start|stop|restart|status|logs
  llama-model download-jobs
  llama-model download-cancel <job_id>
  llama-model download-retry <job_id>
  llama-model stop
  llama-model logs [lines]
  llama-model dashboard-service install|enable|disable|start|stop|restart|status|logs|uninstall
  llama-model handoff status [--json]

Examples:
  llama-model list
  llama-model show gemma4-e4b-q8
  llama-model add gemma4-e4b-q8 /models/Gemma-4-E4B-Q8_K_P.gguf --mmproj /models/mmproj-Gemma-4-E4B-f16.gguf
  llama-model discover ~/models
  llama-model build-runtime --backend auto
  llama-model mode
  llama-model set-mode single --restart
  llama-model switch qwen35-9b-q8
  llama-model sync-opencode --preset balanced
  llama-model sync-opencode --preset long-run
  llama-model sync-opencode --mode direct
  llama-model sync-openclaw --profile lmm-eval qwen35-9b-q8
  llama-model gateway start
  llama-model sync-claude qwen35-9b-q8
  llama-model claude-gateway start
  llama-model sync-glyphos
  llama-model context-mcp build
  llama-model update-check
  llama-model switch /absolute/path/to/model.gguf --no-warmup
  llama-model dashboard-service status
  llama-model dashboard-service install
  llama-model download-jobs

Registry format:
  alias<TAB>model_path<TAB>extra_args<TAB>context<TAB>ngl<TAB>batch<TAB>threads<TAB>parallel<TAB>device<TAB>notes

Older 3-column files remain supported.

Notes:
  - Bundled llama.cpp binaries are backend-, platform-, and architecture-specific.
  - llama-model only auto-accepts bundled binaries that pass an explicit compatibility check.
  - If no safe binary is available, run: llama-model build-runtime
  - opencode, OpenClaw, Claude Code, and GlyphOS keep their own client settings.
  - sync-opencode and sync-openclaw default to the LMM routed gateway. Use --mode direct to bypass Context + GlyphOS and call llama.cpp directly.
  - sync-claude and sync-glyphos align those settings with the active llama-model runtime.
  - context-mcp build repairs the bundled Context MCP dist/index.js used by routed-full gateway mode.
  - Download lifecycle commands use the llama-model-web API when available at http://${LLAMA_MODEL_WEB_HOST:-127.0.0.1}:${LLAMA_MODEL_WEB_PORT:-8765}.
EOF
}

die() {
    printf 'error: %s\n' "$*" >&2
    exit 1
}

timestamp() {
    date +%Y%m%dT%H%M%S
}

iso_timestamp() {
    if date --iso-8601=seconds >/dev/null 2>&1; then
        date --iso-8601=seconds
    else
        date '+%Y-%m-%dT%H:%M:%S%z'
    fi
}

ensure_phase0_store_files() {
    mkdir -p "$STATE_DIR"
    if [[ ! -f "$REMOTE_MODELS_FILE" ]]; then
        cat >"$REMOTE_MODELS_FILE" <<EOF
{
  "schema_version": ${PHASE0_SCHEMA_VERSION},
  "provider": "huggingface",
  "query": "",
  "fetched_at": "",
  "items": []
}
EOF
    fi
    if [[ ! -f "$DOWNLOAD_JOBS_FILE" ]]; then
        cat >"$DOWNLOAD_JOBS_FILE" <<EOF
{
  "schema_version": ${PHASE0_SCHEMA_VERSION},
  "updated_at": "",
  "items": []
}
EOF
    fi
    if [[ ! -f "$VALIDATION_RESULTS_FILE" ]]; then
        cat >"$VALIDATION_RESULTS_FILE" <<EOF
{
  "schema_version": ${PHASE0_SCHEMA_VERSION},
  "items": []
}
EOF
    fi
}

write_runtime_profiles_store() {
    mkdir -p "$CONFIG_DIR"
    command_available python3 || return 0
    python3 - "$LLAMA_SERVER_RUNTIME_DIR" "$RUNTIME_PROFILES_FILE" <<'PY'
import json
import os
import sys
from pathlib import Path

runtime_dir = Path(sys.argv[1])
root = runtime_dir / "llama-server"
out_path = Path(sys.argv[2])

def parse_env_file(path: Path) -> dict[str, str]:
    data: dict[str, str] = {}
    try:
        raw = path.read_text(encoding="utf-8")
    except OSError:
        return data
    for line in raw.splitlines():
        line = line.strip()
        if not line or line.startswith("#") or "=" not in line:
            continue
        key, value = line.split("=", 1)
        value = value.strip().strip('"').strip("'")
        data[key.strip()] = value
    return data

items: list[dict[str, str]] = []
if root.is_dir():
    for compat in sorted(root.glob("*/llama-server.compat.env")):
        meta = parse_env_file(compat)
        profile_id = compat.parent.name
        items.append({
            "id": profile_id,
            "os": meta.get("LLAMA_BUNDLE_OS", ""),
            "arch": meta.get("LLAMA_BUNDLE_ARCH", ""),
            "backend": meta.get("LLAMA_BUNDLE_BACKEND", ""),
            "label": meta.get("LLAMA_BUNDLE_LABEL", profile_id),
            "source_ref": meta.get("LLAMA_BUNDLE_SOURCE_REF", ""),
            "built_at": meta.get("LLAMA_BUNDLE_BUILT_AT", ""),
            "binary_path": str((compat.parent / "llama-server").resolve()),
            "manifest_path": str(compat.resolve()),
        })

payload = {"schema_version": 1, "items": items}
out_path.write_text(json.dumps(payload, indent=2) + "\n", encoding="utf-8")
PY
}

write_host_capability_store() {
    mkdir -p "$STATE_DIR"
    command_available python3 || return 0
    python3 - \
        "$HOST_CAPABILITY_FILE" \
        "$SELECTED_LLAMA_SERVER_HOST_OS" \
        "$SELECTED_LLAMA_SERVER_HOST_ARCH" \
        "$SELECTED_LLAMA_SERVER_HOST_BACKENDS" \
        "$SELECTED_LLAMA_SERVER_BACKEND" \
        "$binary_ok" \
        "$SELECTED_LLAMA_SERVER_BIN" \
        "$SELECTED_LLAMA_SERVER_SOURCE" \
        "$SELECTED_LLAMA_SERVER_STATUS" \
        "$SELECTED_LLAMA_SERVER_LABEL" \
        "$SELECTED_LLAMA_SERVER_MESSAGE" \
        "$SELECTED_LLAMA_SERVER_BUNDLE_MANIFEST" \
        "$(detect_system_available_mib || printf 0)" \
        "$(system_memory_report || printf '0 B')" <<'PY'
import json
import sys

out_path = sys.argv[1]
host_os = sys.argv[2]
host_arch = sys.argv[3]
host_backends_raw = sys.argv[4]
backend = sys.argv[5]
binary_ok = sys.argv[6]
bin_path = sys.argv[7]
bin_source = sys.argv[8]
bin_status = sys.argv[9]
bin_label = sys.argv[10]
bin_message = sys.argv[11]
manifest_path = sys.argv[12]
memory_mib_raw = sys.argv[13]
memory_human_raw = sys.argv[14]
try:
    memory_bytes = max(0, int(memory_mib_raw)) * 1024 * 1024
except ValueError:
    memory_bytes = 0

host_backends = [part.strip().lower() for part in (host_backends_raw or "").split(",") if part.strip()]
preferred_backend = (backend or "").strip().lower()
if not preferred_backend:
    preferred_backend = "cuda" if "cuda" in host_backends else (host_backends[0] if host_backends else "")

payload = {
    "schema_version": 1,
    "host_os": host_os,
    "host_arch": host_arch,
    "host_backends": host_backends,
    "preferred_backend": preferred_backend,
    "memory_bytes": memory_bytes,
    "memory_human": memory_human_raw if memory_bytes else "0 B",
    "binary_ok": binary_ok or "unknown",
    "selected_binary": {
        "path": bin_path or "",
        "source": bin_source or "none",
        "backend": (backend or "").strip().lower(),
        "status": bin_status or "unavailable",
        "label": bin_label or "",
        "message": bin_message or "",
        "manifest_path": manifest_path or "",
    },
}

with open(out_path, "w", encoding="utf-8") as handle:
    json.dump(payload, handle, indent=2)
    handle.write("\n")
PY
}

write_phase0_contract_stores() {
    ensure_phase0_store_files
    write_runtime_profiles_store || true
    write_host_capability_store || true
}

web_api_post_json() {
    local path="$1"
    local json_payload="$2"
    local url="http://${LLAMA_MODEL_WEB_HOST}:${LLAMA_MODEL_WEB_PORT}${path}"

    if command_available curl; then
        curl -fsS --max-time 2 -H "Content-Type: application/json" -d "$json_payload" "$url" 2>/dev/null
        return $?
    fi

    if command_available python3; then
        python3 - "$url" "$json_payload" <<'PY'
import sys
import urllib.request

url = sys.argv[1]
payload = sys.argv[2].encode("utf-8")
req = urllib.request.Request(url, data=payload, headers={"Content-Type": "application/json"})
with urllib.request.urlopen(req, timeout=2) as resp:
    sys.stdout.write(resp.read().decode("utf-8"))
PY
        return $?
    fi

    return 1
}

print_job_payload() {
    local note="${1:-}"
    local json_payload

    command_available python3 || die "python3 is required for download lifecycle commands"
    json_payload="$(cat)"
    python3 - "$note" "$json_payload" <<'PY'
import json
import sys

note = sys.argv[1]
try:
    data = json.loads(sys.argv[2] or "{}")
except json.JSONDecodeError:
    data = {}
job = data.get("job", data) if isinstance(data, dict) else {}
if not isinstance(job, dict):
    job = {}

def emit(key, value):
    value = "" if value is None else value
    print(f"{key}: {value}")

emit("id", job.get("id", ""))
emit("status", job.get("status", ""))
emit("repo_id", job.get("repo_id", ""))
emit("artifact_name", job.get("artifact_name", ""))
emit("error", job.get("error", ""))
if note:
    emit("note", note)
PY
}

download_jobs() {
    ensure_phase0_store_files
    if ! command_available python3; then
        printf 'no jobs\n'
        return 0
    fi
    python3 - "$DOWNLOAD_JOBS_FILE" <<'PY'
import json
import sys

path = sys.argv[1]
try:
    with open(path, "r", encoding="utf-8") as handle:
        payload = json.load(handle)
except Exception:
    print("no jobs")
    raise SystemExit(0)

items = payload.get("items", [])
if not isinstance(items, list):
    items = []

jobs = [item for item in items if isinstance(item, dict)]
if not jobs:
    print("no jobs")
    raise SystemExit(0)

print(f"{'ID':<12} {'STATUS':<10} REPO ARTIFACT")
for job in jobs:
    job_id = str(job.get("id", ""))
    status = str(job.get("status", ""))
    repo = str(job.get("repo_id", ""))
    artifact = str(job.get("artifact_name", ""))
    print(f"{job_id:<12} {status:<10} {repo} {artifact}")
PY
}

download_cancel_local() {
    local job_id="$1"
    ensure_phase0_store_files
    command_available python3 || die "python3 is required for download lifecycle commands"
    python3 - "$DOWNLOAD_JOBS_FILE" "$job_id" <<'PY'
import json
import sys
from datetime import datetime, timezone

path = sys.argv[1]
job_id = sys.argv[2]

def iso_now():
    return datetime.now(timezone.utc).isoformat()

try:
    with open(path, "r", encoding="utf-8") as handle:
        payload = json.load(handle)
except Exception:
    payload = None

if not isinstance(payload, dict):
    print(f"Download job not found: {job_id}", file=sys.stderr)
    raise SystemExit(1)

items = payload.get("items", [])
if not isinstance(items, list):
    items = []

target = None
for entry in items:
    if isinstance(entry, dict) and str(entry.get("id", "")) == job_id:
        target = entry
        break

if target is None:
    print(f"Download job not found: {job_id}", file=sys.stderr)
    raise SystemExit(1)

target["cancel_requested"] = True
target["status"] = "cancelled"
target["error"] = "Download was cancelled by operator."
target["completed_at"] = iso_now()
payload["updated_at"] = iso_now()

with open(path, "w", encoding="utf-8") as handle:
    json.dump(payload, handle, indent=2)
    handle.write("\n")

print(json.dumps({"job": target}))
PY
}

download_retry_local() {
    local job_id="$1"
    ensure_phase0_store_files
    command_available python3 || die "python3 is required for download lifecycle commands"
    python3 - "$DOWNLOAD_JOBS_FILE" "$job_id" <<'PY'
import json
import sys
from datetime import datetime, timezone
from uuid import uuid4

path = sys.argv[1]
job_id = sys.argv[2]

def iso_now():
    return datetime.now(timezone.utc).isoformat()

def new_id():
    return uuid4().hex[:12]

try:
    with open(path, "r", encoding="utf-8") as handle:
        payload = json.load(handle)
except Exception:
    payload = None

if not isinstance(payload, dict):
    print(f"Download job not found: {job_id}", file=sys.stderr)
    raise SystemExit(1)

items = payload.get("items", [])
if not isinstance(items, list):
    items = []

source = None
for entry in items:
    if isinstance(entry, dict) and str(entry.get("id", "")) == job_id:
        source = entry
        break

if source is None:
    print(f"Download job not found: {job_id}", file=sys.stderr)
    raise SystemExit(1)

job = dict(source)
job["id"] = new_id()
job["status"] = "queued"
job["cancel_requested"] = False
job["bytes_downloaded"] = 0
job["progress"] = 0.0
job["error"] = ""
job["verification_summary"] = ""
job["mmproj_verification_summary"] = ""
job["local_path"] = ""
job["mmproj_local_path"] = ""
job["imported_alias"] = ""
job["notes"] = ""
job["created_at"] = iso_now()
job.pop("started_at", None)
job.pop("completed_at", None)

items.insert(0, job)
payload["items"] = items
payload["updated_at"] = iso_now()

with open(path, "w", encoding="utf-8") as handle:
    json.dump(payload, handle, indent=2)
    handle.write("\n")

print(json.dumps({"job": job}))
PY
}

download_cancel() {
    local job_id="$1"
    local payload
    payload="$(web_api_post_json "/api/downloads/cancel" "$(printf '{\"id\":\"%s\"}' "$job_id")" || true)"
    if [[ -n "$payload" ]]; then
        printf '%s' "$payload" | print_job_payload "cancelled via llama-model-web API"
        return 0
    fi
    if ! payload="$(download_cancel_local "$job_id")"; then
        return $?
    fi
    printf '%s' "$payload" | print_job_payload ""
}

download_retry() {
    local job_id="$1"
    local payload
    payload="$(web_api_post_json "/api/downloads/retry" "$(printf '{\"id\":\"%s\"}' "$job_id")" || true)"
    if [[ -n "$payload" ]]; then
        printf '%s' "$payload" | print_job_payload "retried via llama-model-web API"
        return 0
    fi
    if ! payload="$(download_retry_local "$job_id")"; then
        return $?
    fi
    printf '%s' "$payload" | print_job_payload ""
}

ensure_models_file() {
    mkdir -p "$CONFIG_DIR"
    if [[ ! -f "$MODELS_FILE" ]]; then
        cat >"$MODELS_FILE" <<'EOF'
# alias<TAB>model_path<TAB>extra_args<TAB>context<TAB>ngl<TAB>batch<TAB>threads<TAB>parallel<TAB>device<TAB>notes
EOF
    fi
}

trim_whitespace() {
    local value="$1"
    value="${value#"${value%%[![:space:]]*}"}"
    value="${value%"${value##*[![:space:]]}"}"
    printf '%s\n' "$value"
}

toggle_enabled() {
    local value
    value="$(trim_whitespace "${1:-0}")"
    value="${value,,}"
    case "$value" in
        1|yes|true|on|enabled) return 0 ;;
        *) return 1 ;;
    esac
}

normalize_os() {
    local raw="${1:-}"
    raw="${raw,,}"
    case "$raw" in
        linux) printf 'linux\n' ;;
        darwin|macos|mac|osx) printf 'darwin\n' ;;
        *) printf '%s\n' "$raw" ;;
    esac
}

normalize_arch() {
    local raw="${1:-}"
    raw="${raw,,}"
    case "$raw" in
        amd64|x86_64) printf 'x86_64\n' ;;
        arm64|aarch64) printf 'arm64\n' ;;
        *) printf '%s\n' "$raw" ;;
    esac
}

detect_host_os() {
    if [[ -n "${LLAMA_HOST_OS:-}" ]]; then
        normalize_os "$LLAMA_HOST_OS"
    else
        normalize_os "$(uname -s)"
    fi
}

detect_host_arch() {
    if [[ -n "${LLAMA_HOST_ARCH:-}" ]]; then
        normalize_arch "$LLAMA_HOST_ARCH"
    else
        normalize_arch "$(uname -m)"
    fi
}

command_available() {
    command -v "$1" >/dev/null 2>&1
}

cuda_unified_memory_enabled() {
    case "${GGML_CUDA_ENABLE_UNIFIED_MEMORY:-}" in
        1|true|TRUE|yes|YES|on|ON)
            return 0
            ;;
        *)
            return 1
            ;;
    esac
}

cuda_unified_memory_mode() {
    if cuda_unified_memory_enabled; then
        printf 'enabled\n'
    else
        printf 'disabled\n'
    fi
}

active_cuda_unified_memory_value() {
    local pid="${1:-}"

    if [[ -n "$pid" ]] && read_state_file && [[ "${CURRENT_PID:-}" == "$pid" ]]; then
        printf '%s\n' "${CURRENT_CUDA_UNIFIED_MEMORY:-$(cuda_unified_memory_mode)}"
        return 0
    fi
    cuda_unified_memory_mode
}

active_auto_fit_override_reason() {
    local pid="${1:-}"

    if [[ -n "$pid" ]] && read_state_file && [[ "${CURRENT_PID:-}" == "$pid" ]]; then
        printf '%s\n' "${CURRENT_AUTO_FIT_OVERRIDE_REASON:-}"
    fi
}

read_state_file() {
    [[ -f "$STATE_FILE" ]] || return 1
    # shellcheck disable=SC1090
    source "$STATE_FILE"
}

clear_state_file() {
    rm -f "$STATE_FILE"
}

managed_state_pid() {
    if read_state_file && [[ -n "${CURRENT_PID:-}" ]]; then
        if kill -0 "$CURRENT_PID" 2>/dev/null && pid_matches_managed_server "$CURRENT_PID"; then
            printf '%s
' "$CURRENT_PID"
            return 0
        fi
    fi
    return 1
}

pid_command_line() {
    local pid="$1"

    if [[ -r "/proc/$pid/cmdline" ]]; then
        tr '\0' ' ' <"/proc/$pid/cmdline"
        return 0
    fi

    ps -o command= -p "$pid" 2>/dev/null || true
}

pid_matches_managed_server() {
    local pid="$1"
    local cmdline

    cmdline="$(pid_command_line "$pid")"
    [[ -n "$cmdline" ]] || return 1
    [[ "$cmdline" == *llama-server* ]] || return 1
    [[ "$cmdline" == *"--port ${LLAMA_SERVER_PORT}"* ]] || return 1
    return 0
}

state_value() {
    local key="$1"

    read_state_file || return 1
    case "$key" in
        -m) printf '%s\n' "${CURRENT_MODEL:-}" ;;
        -c) printf '%s\n' "${CURRENT_CONTEXT:-}" ;;
        -ngl) printf '%s\n' "${CURRENT_NGL:-}" ;;
        -b) printf '%s\n' "${CURRENT_BATCH:-}" ;;
        --threads) printf '%s\n' "${CURRENT_THREADS:-}" ;;
        --device) printf '%s\n' "${CURRENT_DEVICE:-}" ;;
        -np) printf '%s\n' "${CURRENT_PARALLEL:-}" ;;
        *) return 1 ;;
    esac
}

port_is_listening() {
    if command_available ss; then
        ss -ltn "( sport = :$LLAMA_SERVER_PORT )" 2>/dev/null | grep -q LISTEN
        return $?
    fi

    if command_available lsof; then
        lsof -nP -iTCP:"$LLAMA_SERVER_PORT" -sTCP:LISTEN >/dev/null 2>&1
        return $?
    fi

    if command_available netstat; then
        netstat -an 2>/dev/null | grep -E "[\.\:]${LLAMA_SERVER_PORT}[[:space:]].*LISTEN" >/dev/null
        return $?
    fi

    return 1
}

raw_cmd_arg_from_pid() {
    local pid="$1"
    local key="$2"
    local -a args=()
    local i
    local cmdline

    if [[ -r "/proc/$pid/cmdline" ]]; then
        mapfile -d '' -t args <"/proc/$pid/cmdline"
    else
        cmdline="$(pid_command_line "$pid")"
        [[ -n "$cmdline" ]] || return 1
        mapfile -d '' -t args < <(split_shell_words "$cmdline")
    fi

    for ((i = 0; i < ${#args[@]}; i++)); do
        if [[ "${args[i]}" == "$key" ]] && (( i + 1 < ${#args[@]} )); then
            printf '%s\n' "${args[i + 1]}"
            return 0
        fi
        if [[ "${args[i]}" == "$key="* ]]; then
            printf '%s\n' "${args[i]#*=}"
            return 0
        fi
    done

    return 1
}

llama_server_process_rows() {
    local line
    local pid
    local cmdline
    local port
    local model
    local context
    local ngl

    command_available pgrep || return 0
    while IFS= read -r line; do
        [[ -n "$line" ]] || continue
        pid="${line%% *}"
        [[ "$pid" =~ ^[0-9]+$ ]] || continue
        cmdline="$(pid_command_line "$pid")"
        [[ "$cmdline" == *llama-server* ]] || continue
        port="$(raw_cmd_arg_from_pid "$pid" --port || true)"
        model="$(raw_cmd_arg_from_pid "$pid" -m || raw_cmd_arg_from_pid "$pid" --model || true)"
        context="$(raw_cmd_arg_from_pid "$pid" -c || raw_cmd_arg_from_pid "$pid" --ctx-size || true)"
        ngl="$(raw_cmd_arg_from_pid "$pid" -ngl || raw_cmd_arg_from_pid "$pid" --n-gpu-layers || true)"
        printf 'pid=%s port=%s context=%s ngl=%s model=%s\n' \
            "$pid" "${port:-unknown}" "${context:-unknown}" "${ngl:-unknown}" "${model:-unknown}"
    done < <(pgrep -af '(^|/)llama-server([[:space:]]|$)' 2>/dev/null || true)
}

gpu_memory_report() {
    local line
    local total
    local used
    local free
    local name

    if [[ -n "${LLAMA_GPU_MEMORY_REPORT:-}" ]]; then
        printf '%s\n' "$LLAMA_GPU_MEMORY_REPORT"
        return 0
    fi

    command_available nvidia-smi || return 1
    line="$(nvidia-smi --query-gpu=memory.total,memory.used,memory.free,name --format=csv,noheader,nounits 2>/dev/null | head -n 1 || true)"
    [[ -n "$line" ]] || return 1
    IFS=',' read -r total used free name <<<"$line"
    total="$(trim_whitespace "${total:-}")"
    used="$(trim_whitespace "${used:-}")"
    free="$(trim_whitespace "${free:-}")"
    name="$(trim_whitespace "${name:-GPU}")"
    [[ "$total" =~ ^[0-9]+$ && "$used" =~ ^[0-9]+$ && "$free" =~ ^[0-9]+$ ]] || return 1
    awk -v total="$total" -v used="$used" -v free="$free" -v name="$name" \
        'BEGIN { printf "%s: %.1f GiB used / %.1f GiB total (%.1f GiB free)", name, used / 1024, total / 1024, free / 1024 }'
}

safe_context_for_gpu_mib() {
    local total_mib="${1:-0}"

    [[ "$total_mib" =~ ^[0-9]+$ ]] || total_mib=0
    if (( total_mib <= 8192 )); then
        printf '16384\n'
    elif (( total_mib <= 12288 )); then
        printf '32768\n'
    elif (( total_mib <= 24576 )); then
        printf '65536\n'
    else
        printf '131072\n'
    fi
}

detect_gpu_total_mib() {
    local line
    local total

    if [[ -n "${LLAMA_GPU_TOTAL_MIB:-}" && "${LLAMA_GPU_TOTAL_MIB}" =~ ^[0-9]+$ ]]; then
        printf '%s\n' "$LLAMA_GPU_TOTAL_MIB"
        return 0
    fi

    command_available nvidia-smi || return 1
    line="$(nvidia-smi --query-gpu=memory.total --format=csv,noheader,nounits 2>/dev/null | head -n 1 || true)"
    total="$(trim_whitespace "$line")"
    [[ "$total" =~ ^[0-9]+$ ]] || return 1
    printf '%s\n' "$total"
}

detect_system_total_mib() {
    local value

    if [[ -n "${LLAMA_SYSTEM_TOTAL_MIB:-}" && "${LLAMA_SYSTEM_TOTAL_MIB}" =~ ^[0-9]+$ ]]; then
        printf '%s\n' "$LLAMA_SYSTEM_TOTAL_MIB"
        return 0
    fi

    [[ -r /proc/meminfo ]] || return 1
    value="$(awk '/^MemTotal:/ { printf "%d", $2 / 1024; exit }' /proc/meminfo)"
    [[ "$value" =~ ^[0-9]+$ ]] || return 1
    printf '%s\n' "$value"
}

detect_system_available_mib() {
    local value

    if [[ -n "${LLAMA_SYSTEM_AVAILABLE_MIB:-}" && "${LLAMA_SYSTEM_AVAILABLE_MIB}" =~ ^[0-9]+$ ]]; then
        printf '%s\n' "$LLAMA_SYSTEM_AVAILABLE_MIB"
        return 0
    fi

    [[ -r /proc/meminfo ]] || return 1
    value="$(awk '/^MemAvailable:/ { printf "%d", $2 / 1024; exit }' /proc/meminfo)"
    [[ "$value" =~ ^[0-9]+$ ]] || return 1
    printf '%s\n' "$value"
}

system_memory_report() {
    local total
    local available

    if [[ -n "${LLAMA_SYSTEM_MEMORY_REPORT:-}" ]]; then
        printf '%s\n' "$LLAMA_SYSTEM_MEMORY_REPORT"
        return 0
    fi

    total="$(detect_system_total_mib || true)"
    available="$(detect_system_available_mib || true)"
    [[ "$total" =~ ^[0-9]+$ && "$available" =~ ^[0-9]+$ ]] || return 1
    awk -v total="$total" -v available="$available" \
        'BEGIN { printf "RAM: %.1f GiB available / %.1f GiB total", available / 1024, total / 1024 }'
}

autofit_memory_posture() {
    local gpu_total_mib="${1:-0}"
    local system_available_mib="${2:-0}"

    [[ "$gpu_total_mib" =~ ^[0-9]+$ ]] || gpu_total_mib=0
    [[ "$system_available_mib" =~ ^[0-9]+$ ]] || system_available_mib=0

    if (( gpu_total_mib <= 0 )); then
        if (( system_available_mib >= 32768 )); then
            printf 'cpu-fit\n'
        elif (( system_available_mib >= 16384 )); then
            printf 'ram-risk\n'
        else
            printf 'no-fit\n'
        fi
    elif (( gpu_total_mib >= 16384 )); then
        printf 'gpu-fit\n'
    elif (( system_available_mib >= 32768 )); then
        printf 'hybrid-fit\n'
    elif (( system_available_mib >= 16384 )); then
        printf 'ram-risk\n'
    else
        printf 'no-fit\n'
    fi
}

autofit_memory_guidance() {
    case "${1:-}" in
        gpu-fit)
            printf 'GPU-fit: enough VRAM for a GPU-heavy posture; still lower context if KV cache allocation fails.\n'
            ;;
        hybrid-fit)
            printf 'Hybrid-fit: VRAM is tight but system RAM is available for partial CPU/GPU offload; expect slower runs but better startup stability.\n'
            ;;
        cpu-fit)
            printf 'CPU-fit: no GPU memory signal is available, but system RAM can carry CPU execution; expect much slower runs than GPU offload.\n'
            ;;
        ram-risk)
            printf 'RAM-risk: partial offload may run, but limited available system RAM can swap or stall; prefer smaller models, lower context, or fewer GPU layers.\n'
            ;;
        no-fit)
            printf 'No-fit: both VRAM and available system RAM are tight; avoid aggressive launches and use a smaller model/context.\n'
            ;;
        *)
            printf '\n'
            ;;
    esac
}

hybrid_ngl_for_system_memory() {
    local system_available_mib="${1:-0}"

    [[ "$system_available_mib" =~ ^[0-9]+$ ]] || system_available_mib=0
    if (( system_available_mib >= 32768 )); then
        printf '24\n'
    elif (( system_available_mib >= 16384 )); then
        printf '12\n'
    else
        printf '0\n'
    fi
}

STARTUP_FAILURE_CATEGORY=""
STARTUP_FAILURE_SUMMARY=""
STARTUP_FAILURE_ACTION=""

classify_startup_log_text() {
    local text="$1"
    local lower

    lower="${text,,}"
    STARTUP_FAILURE_CATEGORY="unknown"
    STARTUP_FAILURE_SUMMARY="llama-server exited before becoming healthy."
    STARTUP_FAILURE_ACTION="inspect the latest llama-server log and verify model, port, backend, and runtime settings."

    if [[ "$lower" == *"mismatch between text model"* && "$lower" == *"mmproj"* ]]; then
        STARTUP_FAILURE_CATEGORY="mmproj-mismatch"
        STARTUP_FAILURE_SUMMARY="the selected multimodal projector does not match the text model."
        STARTUP_FAILURE_ACTION="select the matching mmproj for this model family or remove --mmproj for a text-only launch."
    elif [[ "$lower" == *"failed to allocate buffer for kv cache"* ]]; then
        STARTUP_FAILURE_CATEGORY="kv-cache-oom"
        STARTUP_FAILURE_SUMMARY="llama-server ran out of GPU memory while allocating the KV cache."
        STARTUP_FAILURE_ACTION="lower context, set parallel to 1, or reduce GPU layer count before restarting."
    elif [[ "$lower" == *"cudamalloc failed: out of memory"* || "$lower" == *"out of memory"* ]]; then
        STARTUP_FAILURE_CATEGORY="cuda-oom"
        STARTUP_FAILURE_SUMMARY="llama-server ran out of GPU memory while loading model buffers."
        STARTUP_FAILURE_ACTION="lower GPU layer count, close competing GPU llama-server processes, or lower context."
    elif [[ "$lower" == *"couldn't bind http server socket"* || "$lower" == *"address already in use"* ]]; then
        STARTUP_FAILURE_CATEGORY="port-in-use"
        STARTUP_FAILURE_SUMMARY="llama-server could not bind the configured HTTP port."
        STARTUP_FAILURE_ACTION="choose another port or stop the existing process that owns this port."
    elif [[ "$lower" == *"host cuda compute capability could not be detected"* ]]; then
        STARTUP_FAILURE_CATEGORY="cuda-detect-failed"
        STARTUP_FAILURE_SUMMARY="CUDA capability detection failed for this host."
        STARTUP_FAILURE_ACTION="check the NVIDIA driver, run nvidia-smi, set LLAMA_HOST_CUDA_CC, or build/use a CPU runtime."
    fi
}

classify_startup_log_file() {
    local log_file="$1"
    local text=""

    if [[ -f "$log_file" ]]; then
        text="$(tail -n 120 "$log_file" 2>/dev/null || true)"
    fi
    classify_startup_log_text "$text"
}

startup_failure_message() {
    local log_file="$1"
    local requested_context="${2:-}"

    classify_startup_log_file "$log_file"
    [[ "$STARTUP_FAILURE_CATEGORY" != "unknown" ]] || return 1
    printf 'startup_category: %s\n' "$STARTUP_FAILURE_CATEGORY"
    printf 'startup diagnosis: %s\n' "$STARTUP_FAILURE_SUMMARY"
    if [[ -n "$requested_context" ]]; then
        printf 'requested_context: %s\n' "$requested_context"
    fi
    printf 'suggested_fix: %s\n' "$STARTUP_FAILURE_ACTION"
}

model_family_token() {
    local path="$1"
    local name

    name="$(basename "$path")"
    name="${name,,}"
    name="${name//_/-}"
    name="${name//./-}"

    if [[ "$name" =~ qwen3-5-([0-9]+b) ]]; then
        printf 'qwen3.5-%s\n' "${BASH_REMATCH[1]}"
        return 0
    fi
    if [[ "$name" =~ qwen35-([0-9]+b) ]]; then
        printf 'qwen3.5-%s\n' "${BASH_REMATCH[1]}"
        return 0
    fi
    if [[ "$name" =~ gemma-4-(e[0-9]+b) || "$name" =~ gemma4-(e[0-9]+b) ]]; then
        printf 'gemma4-%s\n' "${BASH_REMATCH[1]}"
        return 0
    fi
    if [[ "$name" =~ (^|[^a-z0-9])(e?[0-9]+b)([^a-z0-9]|$) ]]; then
        printf '%s\n' "${BASH_REMATCH[2]}"
        return 0
    fi

    return 1
}

mmproj_matches_model_filename() {
    local model_path="$1"
    local mmproj_path="$2"
    local model_token=""
    local mmproj_token=""

    model_token="$(model_family_token "$model_path" || true)"
    mmproj_token="$(model_family_token "$mmproj_path" || true)"
    [[ -n "$model_token" && -n "$mmproj_token" ]] || return 0
    [[ "$model_token" == "$mmproj_token" ]]
}

extra_mmproj_path() {
    local extra="$1"
    local -a tokens=()
    local i

    [[ -n "$extra" ]] || return 1
    mapfile -d '' -t tokens < <(split_shell_words "$extra")
    for ((i = 0; i < ${#tokens[@]}; i++)); do
        if [[ "${tokens[i]}" == "--mmproj" ]] && (( i + 1 < ${#tokens[@]} )); then
            printf '%s\n' "${tokens[i + 1]}"
            return 0
        fi
    done
    return 1
}

strip_mmproj_from_extra() {
    local extra="$1"
    local -a tokens=()
    local -a kept=()
    local i
    local joined=""
    local quoted=""

    [[ -n "$extra" ]] || return 0
    mapfile -d '' -t tokens < <(split_shell_words "$extra")
    for ((i = 0; i < ${#tokens[@]}; i++)); do
        if [[ "${tokens[i]}" == "--mmproj" ]] && (( i + 1 < ${#tokens[@]} )); then
            ((i++))
            continue
        fi
        kept+=("${tokens[i]}")
    done
    for token in "${kept[@]}"; do
        printf -v quoted '%q' "$token"
        joined="${joined:+$joined }$quoted"
    done
    printf '%s\n' "$joined"
}

validate_mmproj_for_model() {
    local model_path="$1"
    local extra="$2"
    local force="${3:-0}"
    local require="${4:-0}"
    local mmproj=""

    mmproj="$(extra_mmproj_path "$extra" || true)"
    if [[ -z "$mmproj" ]]; then
        if [[ "$require" == "1" ]]; then
            die "--require-mmproj was set, but no --mmproj is configured for this model"
        fi
        return 0
    fi
    if [[ ! -f "$mmproj" ]]; then
        die "mmproj not found: $mmproj"
    fi
    if ! mmproj_matches_model_filename "$model_path" "$mmproj"; then
        if [[ "$force" == "1" ]]; then
            printf 'warning: mmproj filename family does not match model; continuing because --force-mmproj was supplied\n' >&2
            return 0
        fi
        die "mmproj appears to target a different model family: $(basename "$mmproj") for $(basename "$model_path") (use --force-mmproj to override)"
    fi
}

split_shell_words() {
    local raw="$1"
    local item
    local -a fallback_words=()

    [[ -n "$raw" ]] || return 0

    if command_available python3; then
        while IFS= read -r -d '' item; do
            printf '%s\0' "$item"
        done < <(
            python3 -c 'import shlex, sys; sys.stdout.buffer.write(b"".join(part.encode("utf-8") + b"\0" for part in shlex.split(sys.argv[1])))' "$raw"
        )
        return 0
    fi

    read -r -a fallback_words <<<"$raw"
    for item in "${fallback_words[@]}"; do
        printf '%s\0' "$item"
    done
}

split_tsv_record() {
    local raw="${1-}"

    if command_available python3; then
        python3 -c '
import sys
parts = sys.argv[1].split("\t")
parts.extend([""] * (10 - len(parts)))
sys.stdout.buffer.write(b"".join(part.encode("utf-8") + b"\0" for part in parts[:10]))
' "$raw"
        return 0
    fi

    # Fallback: shell splitting does not preserve empty tab fields reliably.
    printf '%s\0' "$raw" "" "" "" "" "" "" "" "" ""
}

canonicalize_path() {
    local target="$1"
    local dir
    local base

    if command_available realpath; then
        realpath "$target"
        return 0
    fi

    if [[ -d "$target" ]]; then
        (cd "$target" && pwd -P)
        return 0
    fi

    dir="$(dirname "$target")"
    base="$(basename "$target")"
    (cd "$dir" && printf '%s/%s\n' "$(pwd -P)" "$base")
}

host_has_cuda_runtime() {
    case "${LLAMA_HOST_CUDA_AVAILABLE:-}" in
        1|true|yes) return 0 ;;
        0|false|no) return 1 ;;
    esac

    if command_available nvidia-smi && nvidia-smi -L >/dev/null 2>&1; then
        return 0
    fi
    [[ -e /dev/nvidiactl || -d /proc/driver/nvidia ]] && return 0
    return 1
}

host_has_vulkan_runtime() {
    case "${LLAMA_HOST_VULKAN_AVAILABLE:-}" in
        1|true|yes) return 0 ;;
        0|false|no) return 1 ;;
    esac

    if command_available vulkaninfo && vulkaninfo --summary >/dev/null 2>&1; then
        return 0
    fi
    if command_available ldconfig && ldconfig -p 2>/dev/null | grep -q 'libvulkan\.so'; then
        return 0
    fi
    return 1
}

host_has_metal_runtime() {
    case "${LLAMA_HOST_METAL_AVAILABLE:-}" in
        1|true|yes) return 0 ;;
        0|false|no) return 1 ;;
    esac

    [[ "$(detect_host_os)" == "darwin" ]] || return 1
    if command_available system_profiler; then
        system_profiler SPDisplaysDataType 2>/dev/null | grep -qi 'metal' && return 0
    fi
    return 0
}

detect_host_backends() {
    local normalized=""
    local entry

    if [[ -n "${LLAMA_HOST_BACKENDS:-}" ]]; then
        for entry in ${LLAMA_HOST_BACKENDS//,/ }; do
            entry="$(trim_whitespace "$entry")"
            [[ -n "$entry" ]] || continue
            case "$entry" in
                cpu|cuda|vulkan|metal)
                    if [[ ",$normalized," != *",$entry,"* ]]; then
                        normalized="${normalized:+$normalized,}$entry"
                    fi
                    ;;
            esac
        done
    fi

    if [[ -z "$normalized" ]]; then
        normalized="cpu"
        if host_has_cuda_runtime; then
            normalized+=",cuda"
        fi
        if host_has_vulkan_runtime; then
            normalized+=",vulkan"
        fi
        if host_has_metal_runtime; then
            normalized+=",metal"
        fi
    elif [[ ",$normalized," != *",cpu,"* ]]; then
        normalized="cpu,$normalized"
    fi

    printf '%s\n' "$normalized"
}

host_has_backend() {
    local backend="$1"
    [[ ",$SELECTED_LLAMA_SERVER_HOST_BACKENDS," == *",$backend,"* ]]
}

infer_backend_from_device() {
    local device="${1:-}"
    device="${device,,}"
    case "$device" in
        cuda*) printf 'cuda\n' ;;
        vulkan*|vk*) printf 'vulkan\n' ;;
        metal*) printf 'metal\n' ;;
        *) printf '\n' ;;
    esac
}

is_cuda_cc_value() {
    local value="${1:-}"
    value="${value//[[:space:]]/}"
    [[ "$value" =~ ^[0-9]+([.][0-9]+)?$ ]]
}

cc_to_int() {
    local value="${1:-}"
    local major=0
    local minor=0

    value="${value//[[:space:]]/}"
    is_cuda_cc_value "$value" || return 1
    IFS='.' read -r major minor <<<"$value"
    major="${major:-0}"
    minor="${minor:-0}"
    printf '%d%02d\n' "$major" "$minor"
}

detect_host_cuda_cc() {
    local cc

    if [[ -n "${LLAMA_HOST_CUDA_CC:-}" ]]; then
        if is_cuda_cc_value "$LLAMA_HOST_CUDA_CC"; then
            printf '%s\n' "$LLAMA_HOST_CUDA_CC"
            return 0
        fi
        return 1
    fi

    if command_available nvidia-smi; then
        cc="$(nvidia-smi --query-gpu=compute_cap --format=csv,noheader 2>/dev/null | head -n 1 | tr -d '[:space:]' || true)"
        if is_cuda_cc_value "$cc"; then
            printf '%s\n' "$cc"
            return 0
        fi
    fi

    return 1
}

manifest_value() {
    local file="$1"
    local key="$2"
    local line

    [[ -f "$file" ]] || return 1
    line="$(grep -E "^${key}=" "$file" | tail -n 1 || true)"
    [[ -n "$line" ]] || return 1
    line="${line#*=}"
    line="${line%\"}"
    line="${line#\"}"
    line="${line%\'}"
    line="${line#\'}"
    printf '%s\n' "$line"
}

binary_file_info() {
    file -bL "$1" 2>/dev/null || true
}

binary_platform_matches_host() {
    local binary="$1"
    local info

    info="$(binary_file_info "$binary")"
    if [[ -z "$info" ]] || [[ "$info" == *"script"* ]] || [[ "$info" == *"text executable"* ]]; then
        return 0
    fi

    case "$SELECTED_LLAMA_SERVER_HOST_OS" in
        linux)
            [[ "$info" == *ELF* ]] || return 1
            ;;
        darwin)
            [[ "$info" == *Mach-O* ]] || return 1
            ;;
    esac

    case "$SELECTED_LLAMA_SERVER_HOST_ARCH" in
        x86_64)
            [[ "$info" == *x86-64* || "$info" == *x86_64* ]] || return 1
            ;;
        arm64)
            [[ "$info" == *arm64* || "$info" == *aarch64* ]] || return 1
            ;;
    esac

    return 0
}

binary_dynamic_links_resolve() {
    local binary="$1"
    local info
    local output

    info="$(binary_file_info "$binary")"
    if [[ -z "$info" ]] || [[ "$info" == *"script"* ]] || [[ "$info" == *"text executable"* ]]; then
        return 0
    fi

    case "$SELECTED_LLAMA_SERVER_HOST_OS" in
        linux)
            if command_available ldd; then
                output="$(ldd "$binary" 2>&1 || true)"
                [[ "$output" != *"not found"* ]] || return 1
            fi
            ;;
        darwin)
            if command_available otool; then
                output="$(otool -L "$binary" 2>&1 || true)"
                [[ "$output" != *"not found"* ]] || return 1
            fi
            ;;
    esac

    return 0
}

bundle_manifest_for_binary() {
    printf '%s.compat.env\n' "$1"
}

validate_cuda_bundle() {
    local manifest="$1"
    local exact_cc
    local min_cc
    local max_cc
    local host_cc
    local host_cc_int
    local candidate

    exact_cc="$(manifest_value "$manifest" LLAMA_BUNDLE_CUDA_CC || true)"
    min_cc="$(manifest_value "$manifest" LLAMA_BUNDLE_CUDA_CC_MIN || true)"
    max_cc="$(manifest_value "$manifest" LLAMA_BUNDLE_CUDA_CC_MAX || true)"

    if [[ -z "$exact_cc" && -z "$min_cc" && -z "$max_cc" ]]; then
        BUNDLE_VALIDATE_REASON="bundled CUDA binary is missing compute-capability metadata"
        return 1
    fi

    host_cc="$(detect_host_cuda_cc || true)"
    if [[ -z "$host_cc" ]]; then
        BUNDLE_VALIDATE_REASON="host CUDA compute capability could not be detected"
        return 1
    fi

    host_cc_int="$(cc_to_int "$host_cc")" || {
        BUNDLE_VALIDATE_REASON="host CUDA compute capability could not be parsed"
        return 1
    }
    if [[ -n "$exact_cc" ]]; then
        for candidate in ${exact_cc//,/ }; do
            local candidate_int=""
            candidate_int="$(cc_to_int "$candidate" || true)"
            if [[ -n "$candidate_int" && "$candidate_int" == "$host_cc_int" ]]; then
                return 0
            fi
        done
        BUNDLE_VALIDATE_REASON="bundled CUDA binary targets compute capability ${exact_cc}, host reports ${host_cc}"
        return 1
    fi

    if [[ -n "$min_cc" ]]; then
        local min_cc_int=""
        min_cc_int="$(cc_to_int "$min_cc" || true)"
        [[ -n "$min_cc_int" ]] || {
            BUNDLE_VALIDATE_REASON="bundled CUDA binary has invalid minimum compute-capability metadata"
            return 1
        }
        if (( host_cc_int < min_cc_int )); then
            BUNDLE_VALIDATE_REASON="bundled CUDA binary requires compute capability >= ${min_cc}, host reports ${host_cc}"
            return 1
        fi
    fi
    if [[ -n "$max_cc" ]]; then
        local max_cc_int=""
        max_cc_int="$(cc_to_int "$max_cc" || true)"
        [[ -n "$max_cc_int" ]] || {
            BUNDLE_VALIDATE_REASON="bundled CUDA binary has invalid maximum compute-capability metadata"
            return 1
        }
        if (( host_cc_int > max_cc_int )); then
            BUNDLE_VALIDATE_REASON="bundled CUDA binary requires compute capability <= ${max_cc}, host reports ${host_cc}"
            return 1
        fi
    fi

    return 0
}

validate_bundled_binary() {
    local binary="$1"
    local manifest
    local bundle_os
    local bundle_arch
    local bundle_backend
    local bundle_label

    BUNDLE_VALIDATE_REASON=""
    BUNDLE_VALIDATE_BACKEND=""
    BUNDLE_VALIDATE_LABEL=""
    BUNDLE_VALIDATE_MANIFEST=""

    [[ -x "$binary" ]] || {
        BUNDLE_VALIDATE_REASON="bundled binary not executable: $binary"
        return 1
    }

    manifest="$(bundle_manifest_for_binary "$binary")"
    [[ -f "$manifest" ]] || {
        BUNDLE_VALIDATE_REASON="bundled binary is missing ${manifest##*/}"
        return 1
    }

    bundle_os="$(normalize_os "$(manifest_value "$manifest" LLAMA_BUNDLE_OS || true)")"
    bundle_arch="$(normalize_arch "$(manifest_value "$manifest" LLAMA_BUNDLE_ARCH || true)")"
    bundle_backend="$(trim_whitespace "$(manifest_value "$manifest" LLAMA_BUNDLE_BACKEND || true)")"
    bundle_label="$(trim_whitespace "$(manifest_value "$manifest" LLAMA_BUNDLE_LABEL || true)")"

    [[ -n "$bundle_os" && -n "$bundle_arch" && -n "$bundle_backend" ]] || {
        BUNDLE_VALIDATE_REASON="bundled manifest is missing required OS/arch/backend fields"
        return 1
    }

    [[ "$bundle_os" == "$SELECTED_LLAMA_SERVER_HOST_OS" ]] || {
        BUNDLE_VALIDATE_REASON="bundled binary targets ${bundle_os}, host is ${SELECTED_LLAMA_SERVER_HOST_OS}"
        return 1
    }
    [[ "$bundle_arch" == "$SELECTED_LLAMA_SERVER_HOST_ARCH" ]] || {
        BUNDLE_VALIDATE_REASON="bundled binary targets ${bundle_arch}, host is ${SELECTED_LLAMA_SERVER_HOST_ARCH}"
        return 1
    }

    case "$bundle_backend" in
        cpu|cuda|vulkan|metal) ;;
        *)
            BUNDLE_VALIDATE_REASON="bundled binary declares unsupported backend: ${bundle_backend}"
            return 1
            ;;
    esac

    if [[ "$bundle_backend" != "cpu" ]] && ! host_has_backend "$bundle_backend"; then
        BUNDLE_VALIDATE_REASON="host does not expose the required ${bundle_backend} runtime"
        return 1
    fi

    binary_platform_matches_host "$binary" || {
        BUNDLE_VALIDATE_REASON="bundled binary format does not match this host"
        return 1
    }
    binary_dynamic_links_resolve "$binary" || {
        BUNDLE_VALIDATE_REASON="bundled binary has unresolved dynamic library dependencies"
        return 1
    }

    if [[ "$bundle_backend" == "cuda" ]]; then
        validate_cuda_bundle "$manifest" || return 1
    fi

    BUNDLE_VALIDATE_BACKEND="$bundle_backend"
    BUNDLE_VALIDATE_LABEL="${bundle_label:-$bundle_backend}"
    BUNDLE_VALIDATE_MANIFEST="$manifest"
    return 0
}

validate_external_binary() {
    local binary="$1"

    EXTERNAL_VALIDATE_REASON=""
    [[ -x "$binary" ]] || {
        EXTERNAL_VALIDATE_REASON="binary not executable: $binary"
        return 1
    }
    binary_platform_matches_host "$binary" || {
        EXTERNAL_VALIDATE_REASON="binary format does not match host ${SELECTED_LLAMA_SERVER_HOST_OS}/${SELECTED_LLAMA_SERVER_HOST_ARCH}"
        return 1
    }
    binary_dynamic_links_resolve "$binary" || {
        EXTERNAL_VALIDATE_REASON="binary has unresolved dynamic library dependencies"
        return 1
    }
    return 0
}

runtime_build_guidance() {
    cat <<EOF
Run \`llama-model build-runtime\` to fetch ${LLAMA_CPP_REPO_URL} and compile a host-specific llama-server build. Bundled binaries are backend-, platform-, and architecture-specific. If you need CUDA, Vulkan, or Metal, build that backend locally or point LLAMA_SERVER_BIN at your own compatible install.
EOF
}

select_binary_record() {
    SELECTED_LLAMA_SERVER_BIN="$1"
    SELECTED_LLAMA_SERVER_SOURCE="$2"
    SELECTED_LLAMA_SERVER_BACKEND="$3"
    SELECTED_LLAMA_SERVER_STATUS="$4"
    SELECTED_LLAMA_SERVER_MESSAGE="$5"
    SELECTED_LLAMA_SERVER_GUIDANCE="$6"
    SELECTED_LLAMA_SERVER_LABEL="${7:-}"
    SELECTED_LLAMA_SERVER_BUNDLE_MANIFEST="${8:-}"
}

list_bundled_binaries() {
    local runtime_root="$LLAMA_SERVER_RUNTIME_DIR/llama-server"
    [[ -d "$runtime_root" ]] || return 0
    find "$runtime_root" -mindepth 2 -maxdepth 2 -type f -name 'llama-server' -print0 | sort -z
}

bundled_binary_preference_order() {
    local requested_backend="$1"
    local order=""
    local backend

    for backend in "$requested_backend" metal cuda vulkan cpu; do
        [[ -n "$backend" ]] || continue
        if [[ ",$order," != *",$backend,"* ]]; then
            order="${order:+$order,}$backend"
        fi
    done
    printf '%s\n' "$order"
}

select_compatible_bundled_binary() {
    local requested_backend="$1"
    local order
    local backend
    local candidate

    BUNDLED_SELECTION_FAILURE_REASON=""
    order="$(bundled_binary_preference_order "$requested_backend")"
    for backend in ${order//,/ }; do
        while IFS= read -r -d '' candidate; do
            if validate_bundled_binary "$candidate" && [[ "$BUNDLE_VALIDATE_BACKEND" == "$backend" ]]; then
                select_binary_record \
                    "$candidate" \
                    "bundled" \
                    "$BUNDLE_VALIDATE_BACKEND" \
                    "compatible" \
                    "validated bundled ${BUNDLE_VALIDATE_LABEL} binary" \
                    "" \
                    "$BUNDLE_VALIDATE_LABEL" \
                    "$BUNDLE_VALIDATE_MANIFEST"
                if [[ "$BUNDLE_VALIDATE_BACKEND" == "cpu" && -n "$BUNDLED_SELECTION_FAILURE_REASON" ]]; then
                    SELECTED_LLAMA_SERVER_SOURCE="bundled-cpu-fallback"
                    SELECTED_LLAMA_SERVER_STATUS="fallback"
                    SELECTED_LLAMA_SERVER_MESSAGE="${BUNDLED_SELECTION_FAILURE_REASON}; using validated bundled CPU fallback instead"
                fi
                return 0
            elif [[ -z "$BUNDLED_SELECTION_FAILURE_REASON" && -n "$BUNDLE_VALIDATE_REASON" ]]; then
                BUNDLED_SELECTION_FAILURE_REASON="$BUNDLE_VALIDATE_REASON"
            fi
        done < <(list_bundled_binaries)
    done

    return 1
}

probe_server_binary() {
    local requested_backend
    local fallback_note=""
    local configured_path="${REQUESTED_LLAMA_SERVER_BIN:-}"
    local default_path="$DEFAULT_LLAMA_SERVER_BIN"
    local runtime_root

    SELECTED_LLAMA_SERVER_HOST_OS="$(detect_host_os)"
    SELECTED_LLAMA_SERVER_HOST_ARCH="$(detect_host_arch)"
    SELECTED_LLAMA_SERVER_HOST_BACKENDS="$(detect_host_backends)"
    SELECTED_LLAMA_SERVER_BIN=""
    SELECTED_LLAMA_SERVER_SOURCE=""
    SELECTED_LLAMA_SERVER_BACKEND=""
    SELECTED_LLAMA_SERVER_STATUS=""
    SELECTED_LLAMA_SERVER_MESSAGE=""
    SELECTED_LLAMA_SERVER_GUIDANCE=""
    SELECTED_LLAMA_SERVER_LABEL=""
    SELECTED_LLAMA_SERVER_BUNDLE_MANIFEST=""
    SELECTED_LLAMA_SERVER_PATH_KIND=""

    requested_backend="$(infer_backend_from_device "${LLAMA_SERVER_DEVICE:-}")"
    runtime_root="$(canonicalize_path "$LLAMA_SERVER_RUNTIME_DIR" 2>/dev/null || printf '%s\n' "$LLAMA_SERVER_RUNTIME_DIR")"

    if [[ -n "$configured_path" ]]; then
        SELECTED_LLAMA_SERVER_PATH_KIND="configured"
        if [[ -x "$configured_path" ]]; then
            if [[ -n "$runtime_root" ]] && [[ "$(canonicalize_path "$configured_path" 2>/dev/null || printf '%s\n' "$configured_path")" == "$runtime_root"* ]]; then
                if validate_bundled_binary "$configured_path"; then
                    select_binary_record \
                        "$configured_path" \
                        "bundled" \
                        "$BUNDLE_VALIDATE_BACKEND" \
                        "compatible" \
                        "validated configured bundled ${BUNDLE_VALIDATE_LABEL} binary" \
                        "" \
                        "$BUNDLE_VALIDATE_LABEL" \
                        "$BUNDLE_VALIDATE_MANIFEST"
                    return 0
                fi
                fallback_note="configured bundled binary rejected: ${BUNDLE_VALIDATE_REASON}"
            else
                if validate_external_binary "$configured_path"; then
                    select_binary_record \
                        "$configured_path" \
                        "external" \
                        "external" \
                        "external-unvalidated" \
                        "using external llama-server binary; backend compatibility must be managed by the installer" \
                        "" \
                        "external install"
                    return 0
                fi
                fallback_note="configured binary rejected: ${EXTERNAL_VALIDATE_REASON}"
            fi
        else
            fallback_note="configured binary not found: ${configured_path}"
        fi
    elif [[ -x "$default_path" ]]; then
        SELECTED_LLAMA_SERVER_PATH_KIND="default"
        if validate_external_binary "$default_path"; then
            select_binary_record \
                "$default_path" \
                "external" \
                "external" \
                "external-unvalidated" \
                "using installed llama-server from PATH; backend compatibility must be managed by the installer" \
                "" \
                "external install"
            return 0
        fi
        fallback_note="default installed binary rejected: ${EXTERNAL_VALIDATE_REASON}"
    fi

    if select_compatible_bundled_binary "$requested_backend"; then
        if [[ -n "$fallback_note" && "$SELECTED_LLAMA_SERVER_BACKEND" == "cpu" ]]; then
            SELECTED_LLAMA_SERVER_SOURCE="bundled-cpu-fallback"
            SELECTED_LLAMA_SERVER_STATUS="fallback"
            SELECTED_LLAMA_SERVER_MESSAGE="${fallback_note}; using validated bundled CPU fallback instead"
        elif [[ -n "$fallback_note" ]]; then
            SELECTED_LLAMA_SERVER_MESSAGE="${fallback_note}; using validated bundled ${SELECTED_LLAMA_SERVER_BACKEND} binary instead"
        fi
        return 0
    fi

    select_binary_record \
        "" \
        "none" \
        "none" \
        "unavailable" \
        "${fallback_note:-${BUNDLED_SELECTION_FAILURE_REASON:-no compatible llama-server binary found}}" \
        "$(runtime_build_guidance)"
    return 1
}

detect_primary_build_backend() {
    local requested="${1:-auto}"

    if [[ "$requested" != "auto" ]]; then
        printf '%s\n' "$requested"
        return 0
    fi

    if [[ ",$SELECTED_LLAMA_SERVER_HOST_BACKENDS," == *",metal,"* ]]; then
        printf 'metal\n'
    elif [[ ",$SELECTED_LLAMA_SERVER_HOST_BACKENDS," == *",cuda,"* ]]; then
        printf 'cuda\n'
    elif [[ ",$SELECTED_LLAMA_SERVER_HOST_BACKENDS," == *",vulkan,"* ]]; then
        printf 'vulkan\n'
    else
        printf 'cpu\n'
    fi
}

build_job_count() {
    if command_available nproc; then
        nproc
    elif command_available sysctl; then
        sysctl -n hw.logicalcpu 2>/dev/null || printf '4\n'
    else
        printf '4\n'
    fi
}

is_interactive_session() {
    [[ -t 0 && -t 1 ]]
}

confirm_prompt() {
    local prompt="$1"
    local default="${2:-Y}"
    local reply

    if ! is_interactive_session; then
        return 1
    fi

    if [[ "$default" == "Y" ]]; then
        printf '%s [Y/n] ' "$prompt"
    else
        printf '%s [y/N] ' "$prompt"
    fi

    read -r reply || return 1
    reply="${reply,,}"
    if [[ -z "$reply" ]]; then
        [[ "$default" == "Y" ]]
        return
    fi
    [[ "$reply" == "y" || "$reply" == "yes" ]]
}

detect_package_manager() {
    if command_available apt-get; then
        printf 'apt-get\n'
    elif command_available dnf; then
        printf 'dnf\n'
    elif command_available pacman; then
        printf 'pacman\n'
    elif command_available zypper; then
        printf 'zypper\n'
    elif command_available brew; then
        printf 'brew\n'
    else
        printf 'none\n'
    fi
}

dependency_key_label() {
    case "$1" in
        git) printf 'git\n' ;;
        cmake) printf 'cmake\n' ;;
        compiler) printf 'C++ compiler\n' ;;
        cuda_toolkit) printf 'CUDA toolkit (nvcc)\n' ;;
        vulkan_sdk) printf 'Vulkan SDK tools\n' ;;
        xcode_tools) printf 'Xcode Command Line Tools\n' ;;
        *) printf '%s\n' "$1" ;;
    esac
}

missing_build_dependencies() {
    local backend="$1"
    local host_os="${SELECTED_LLAMA_SERVER_HOST_OS:-$(detect_host_os)}"

    if ! command_available git; then
        printf 'git\n'
    fi
    if ! command_available cmake; then
        printf 'cmake\n'
    fi

    if [[ "$host_os" == "darwin" ]]; then
        if ! command_available xcrun; then
            printf 'xcode_tools\n'
        fi
    elif ! command_available c++ && ! command_available clang++ && ! command_available g++; then
        printf 'compiler\n'
    fi

    case "$backend" in
        cuda)
            command_available nvcc || printf 'cuda_toolkit\n'
            ;;
        vulkan)
            if ! command_available glslc && ! command_available glslangValidator; then
                printf 'vulkan_sdk\n'
            fi
            ;;
        metal)
            command_available xcrun || printf 'xcode_tools\n'
            ;;
    esac
}

append_unique_words() {
    local package_string="$1"
    shift
    local item
    local existing

    for item in $package_string; do
        [[ -n "$item" ]] || continue
        existing=0
        for word in "$@"; do
            if [[ "$word" == "$item" ]]; then
                existing=1
                break
            fi
        done
        if [[ "$existing" -eq 0 ]]; then
            printf '%s\n' "$item"
        fi
    done
}

packages_for_manager_key() {
    local manager="$1"
    local key="$2"

    case "$manager:$key" in
        apt-get:git|dnf:git|pacman:git|zypper:git|brew:git)
            printf 'git\n'
            ;;
        apt-get:cmake|dnf:cmake|pacman:cmake|zypper:cmake|brew:cmake)
            printf 'cmake\n'
            ;;
        apt-get:compiler)
            printf 'build-essential\n'
            ;;
        dnf:compiler|zypper:compiler)
            printf 'gcc-c++ make\n'
            ;;
        pacman:compiler)
            printf 'base-devel\n'
            ;;
        apt-get:cuda_toolkit)
            printf 'nvidia-cuda-toolkit\n'
            ;;
        dnf:cuda_toolkit|zypper:cuda_toolkit)
            printf 'cuda-toolkit\n'
            ;;
        pacman:cuda_toolkit)
            printf 'cuda\n'
            ;;
        apt-get:vulkan_sdk)
            printf 'vulkan-tools glslang-tools libvulkan-dev\n'
            ;;
        dnf:vulkan_sdk)
            printf 'vulkan-tools glslang\n'
            ;;
        pacman:vulkan_sdk)
            printf 'vulkan-tools shaderc\n'
            ;;
        zypper:vulkan_sdk)
            printf 'vulkan-tools glslang\n'
            ;;
        brew:vulkan_sdk)
            printf 'vulkan-tools shaderc\n'
            ;;
        *)
            printf '\n'
            ;;
    esac
}

preview_dependency_install_commands() {
    local manager="$1"
    shift
    local key
    local package_string
    local -a packages=()
    local pkg
    local prefix=""

    if [[ "$manager" == "none" ]]; then
        return 1
    fi

    for key in "$@"; do
        if [[ "$key" == "xcode_tools" ]]; then
            printf 'xcode-select --install\n'
            continue
        fi

        package_string="$(packages_for_manager_key "$manager" "$key")"
        if [[ -z "$package_string" ]]; then
            continue
        fi
        while IFS= read -r pkg; do
            [[ -n "$pkg" ]] || continue
            packages+=("$pkg")
        done < <(append_unique_words "$package_string" "${packages[@]}")
    done

    if ((${#packages[@]} == 0)); then
        return 0
    fi

    case "$manager" in
        apt-get)
            prefix="$( [[ "$EUID" -eq 0 ]] && printf '' || printf 'sudo ' )"
            printf '%sapt-get update\n' "$prefix"
            printf '%sapt-get install -y %s\n' "$prefix" "${packages[*]}"
            ;;
        dnf)
            prefix="$( [[ "$EUID" -eq 0 ]] && printf '' || printf 'sudo ' )"
            printf '%sdnf install -y %s\n' "$prefix" "${packages[*]}"
            ;;
        pacman)
            prefix="$( [[ "$EUID" -eq 0 ]] && printf '' || printf 'sudo ' )"
            printf '%spacman -Sy --needed --noconfirm %s\n' "$prefix" "${packages[*]}"
            ;;
        zypper)
            prefix="$( [[ "$EUID" -eq 0 ]] && printf '' || printf 'sudo ' )"
            printf '%szypper --non-interactive install %s\n' "$prefix" "${packages[*]}"
            ;;
        brew)
            printf 'brew install %s\n' "${packages[*]}"
            ;;
    esac
}

ensure_sudo_if_needed() {
    local manager="$1"

    case "$manager" in
        apt-get|dnf|pacman|zypper)
            if [[ "$EUID" -ne 0 ]] && ! command_available sudo; then
                die "sudo is required to install build dependencies with ${manager}"
            fi
            ;;
    esac
}

run_dependency_install_commands() {
    local manager="$1"
    shift
    local key
    local package_string
    local -a packages=()
    local pkg

    ensure_sudo_if_needed "$manager"

    for key in "$@"; do
        if [[ "$key" == "xcode_tools" ]]; then
            if command_available xcode-select && xcode-select -p >/dev/null 2>&1; then
                continue
            fi
            command_available xcode-select || die "xcode-select is not available on this host"
            xcode-select --install || true
            printf 'Complete the Xcode Command Line Tools installation, then rerun llama-model build-runtime.\n'
            return 1
        fi

        package_string="$(packages_for_manager_key "$manager" "$key")"
        if [[ -z "$package_string" ]]; then
            continue
        fi
        while IFS= read -r pkg; do
            [[ -n "$pkg" ]] || continue
            packages+=("$pkg")
        done < <(append_unique_words "$package_string" "${packages[@]}")
    done

    if ((${#packages[@]} == 0)); then
        return 0
    fi

    case "$manager" in
        apt-get)
            if [[ "$EUID" -eq 0 ]]; then
                apt-get update
                apt-get install -y "${packages[@]}"
            else
                sudo apt-get update
                sudo apt-get install -y "${packages[@]}"
            fi
            ;;
        dnf)
            if [[ "$EUID" -eq 0 ]]; then
                dnf install -y "${packages[@]}"
            else
                sudo dnf install -y "${packages[@]}"
            fi
            ;;
        pacman)
            if [[ "$EUID" -eq 0 ]]; then
                pacman -Sy --needed --noconfirm "${packages[@]}"
            else
                sudo pacman -Sy --needed --noconfirm "${packages[@]}"
            fi
            ;;
        zypper)
            if [[ "$EUID" -eq 0 ]]; then
                zypper --non-interactive install "${packages[@]}"
            else
                sudo zypper --non-interactive install "${packages[@]}"
            fi
            ;;
        brew)
            brew install "${packages[@]}"
            ;;
        *)
            return 1
            ;;
    esac
}

install_missing_build_dependencies() {
    local backend="$1"
    shift
    local -a missing=("$@")
    local manager
    local preview=""
    local key

    manager="$(detect_package_manager)"
    if [[ "$manager" == "none" ]]; then
        return 1
    fi

    preview="$(preview_dependency_install_commands "$manager" "${missing[@]}" || true)"
    if [[ -z "$preview" ]]; then
        return 1
    fi

    printf 'Missing build dependencies for backend %s:\n' "$backend"
    for key in "${missing[@]}"; do
        printf '  - %s\n' "$(dependency_key_label "$key")"
    done
    printf '\nProposed install commands:\n%s\n' "$preview"

    case "${LLAMA_AUTO_INSTALL_DEPS:-prompt}" in
        1|true|yes)
            ;;
        0|false|no)
            return 1
            ;;
        *)
            confirm_prompt "Install the missing build dependencies now?" "Y" || return 1
            ;;
    esac

    run_dependency_install_commands "$manager" "${missing[@]}"
}

ensure_build_dependencies() {
    local backend="$1"
    local -a missing=()
    local summary=""
    local key

    mapfile -t missing < <(missing_build_dependencies "$backend")
    if ((${#missing[@]} == 0)); then
        return 0
    fi

    install_missing_build_dependencies "$backend" "${missing[@]}" || true
    mapfile -t missing < <(missing_build_dependencies "$backend")
    if ((${#missing[@]} == 0)); then
        return 0
    fi

    for key in "${missing[@]}"; do
        summary="${summary:+$summary, }$(dependency_key_label "$key")"
    done
    die "missing build dependencies for backend ${backend}: ${summary}. Install them and rerun llama-model build-runtime --backend ${backend}."
}

sync_llama_cpp_source() {
    local ref="$1"
    local src_root="$LLAMA_SERVER_RUNTIME_DIR/src"
    local src_dir="$src_root/llama.cpp"

    mkdir -p "$src_root"
    if [[ ! -d "$src_dir/.git" ]]; then
        git clone "$LLAMA_CPP_REPO_URL" "$src_dir" >/dev/null
    fi

    git -C "$src_dir" fetch --tags origin >/dev/null
    if git -C "$src_dir" rev-parse --verify "$ref^{commit}" >/dev/null 2>&1; then
        git -C "$src_dir" checkout --detach "$ref" >/dev/null
    else
        git -C "$src_dir" checkout --detach "origin/$ref" >/dev/null 2>&1 \
            || die "unable to resolve llama.cpp ref: $ref"
    fi

    printf '%s\n' "$src_dir"
}

write_bundle_manifest() {
    local binary="$1"
    local backend="$2"
    local ref="$3"
    local manifest
    local label
    local cuda_cc=""

    case "$backend" in
        cpu) label="CPU" ;;
        cuda) label="NVIDIA CUDA" ;;
        vulkan) label="Vulkan" ;;
        metal) label="Apple Metal" ;;
        *) label="$backend" ;;
    esac

    if [[ "$backend" == "cuda" ]]; then
        cuda_cc="$(detect_host_cuda_cc || true)"
        [[ -n "$cuda_cc" ]] || die "unable to detect CUDA compute capability for this host; set LLAMA_HOST_CUDA_CC or build cpu instead"
    fi

    manifest="$(bundle_manifest_for_binary "$binary")"
    {
        printf 'LLAMA_BUNDLE_OS=%s\n' "$SELECTED_LLAMA_SERVER_HOST_OS"
        printf 'LLAMA_BUNDLE_ARCH=%s\n' "$SELECTED_LLAMA_SERVER_HOST_ARCH"
        printf 'LLAMA_BUNDLE_BACKEND=%s\n' "$backend"
        printf 'LLAMA_BUNDLE_LABEL=%s\n' "$label"
        printf 'LLAMA_BUNDLE_SOURCE_REF=%s\n' "$ref"
        printf 'LLAMA_BUNDLE_BUILT_AT=%s\n' "$(iso_timestamp)"
        if [[ -n "$cuda_cc" ]]; then
            printf 'LLAMA_BUNDLE_CUDA_CC=%s\n' "$cuda_cc"
        fi
    } >"$manifest"
}

locate_built_llama_server() {
    local build_dir="$1"
    find "$build_dir" -type f -name 'llama-server' -perm -u+x | sort | head -n 1
}

build_runtime_backend() {
    local src_dir="$1"
    local backend="$2"
    local ref="$3"
    local jobs="$4"
    local build_dir="$LLAMA_SERVER_RUNTIME_DIR/build/${SELECTED_LLAMA_SERVER_HOST_OS}-${SELECTED_LLAMA_SERVER_HOST_ARCH}-${backend}"
    local install_dir="$LLAMA_SERVER_RUNTIME_DIR/llama-server/${SELECTED_LLAMA_SERVER_HOST_OS}-${SELECTED_LLAMA_SERVER_HOST_ARCH}-${backend}"
    local -a cmake_args=()
    local binary=""

    rm -rf "$build_dir"
    mkdir -p "$build_dir" "$install_dir"

    if command_available ninja; then
        cmake_args+=(-G Ninja)
    fi

    cmake_args+=(-DCMAKE_BUILD_TYPE=Release)
    case "$backend" in
        cpu)
            cmake_args+=(-DGGML_CUDA=OFF -DGGML_VULKAN=OFF -DGGML_METAL=OFF)
            ;;
        cuda)
            cmake_args+=(-DGGML_CUDA=ON -DGGML_VULKAN=OFF -DGGML_METAL=OFF)
            ;;
        vulkan)
            cmake_args+=(-DGGML_CUDA=OFF -DGGML_VULKAN=ON -DGGML_METAL=OFF)
            ;;
        metal)
            cmake_args+=(-DGGML_CUDA=OFF -DGGML_VULKAN=OFF -DGGML_METAL=ON)
            ;;
        *)
            die "unsupported build backend: $backend"
            ;;
    esac

    cmake -S "$src_dir" -B "$build_dir" "${cmake_args[@]}" >/dev/null
    cmake --build "$build_dir" --target llama-server -j "$jobs" >/dev/null

    binary="$(locate_built_llama_server "$build_dir")"
    [[ -n "$binary" ]] || die "llama-server binary was not produced for backend ${backend}"

    install -m 0755 "$binary" "$install_dir/llama-server"
    write_bundle_manifest "$install_dir/llama-server" "$backend" "$ref"
    printf 'built %s runtime at %s\n' "$backend" "$install_dir/llama-server"
}

build_runtime() {
    local backend="auto"
    local ref="$LLAMA_CPP_REF"
    local primary_backend
    local src_dir
    local jobs
    local target
    local built_any=0
    local targets=""

    while (($#)); do
        case "$1" in
            --backend)
                [[ $# -ge 2 ]] || die "--backend requires a value"
                backend="$2"
                shift 2
                ;;
            --ref)
                [[ $# -ge 2 ]] || die "--ref requires a value"
                ref="$2"
                shift 2
                ;;
            *)
                die "unknown build-runtime option: $1"
                ;;
        esac
    done

    case "$backend" in
        auto|cpu|cuda|vulkan|metal) ;;
        *)
            die "unsupported backend: $backend (expected auto, cpu, cuda, vulkan, or metal)"
            ;;
    esac

    SELECTED_LLAMA_SERVER_HOST_OS="$(detect_host_os)"
    SELECTED_LLAMA_SERVER_HOST_ARCH="$(detect_host_arch)"
    SELECTED_LLAMA_SERVER_HOST_BACKENDS="$(detect_host_backends)"
    primary_backend="$(detect_primary_build_backend "$backend")"
    jobs="${LLAMA_BUILD_JOBS:-$(build_job_count)}"

    ensure_build_dependencies "$primary_backend"
    ensure_build_dependencies cpu
    mkdir -p "$LLAMA_SERVER_RUNTIME_DIR"
    src_dir="$(sync_llama_cpp_source "$ref")"

    for target in "$primary_backend" cpu; do
        if [[ ",$targets," == *",$target,"* ]]; then
            continue
        fi
        targets="${targets:+$targets,}$target"
        build_runtime_backend "$src_dir" "$target" "$ref" "$jobs"
        built_any=1
    done

    [[ "$built_any" -eq 1 ]] || die "no runtime builds were produced"
    printf 'runtime_dir: %s\n' "$LLAMA_SERVER_RUNTIME_DIR"
    printf 'host: %s/%s (%s)\n' "$SELECTED_LLAMA_SERVER_HOST_OS" "$SELECTED_LLAMA_SERVER_HOST_ARCH" "$SELECTED_LLAMA_SERVER_HOST_BACKENDS"
}

sanitize_alias() {
    local raw="$1"
    raw="${raw##*/}"
    raw="${raw%.gguf}"
    raw="$(printf '%s' "$raw" | tr '[:upper:]' '[:lower:]' | sed -E 's/[^a-z0-9]+/-/g; s/^-+//; s/-+$//; s/-+/-/g')"
    printf '%s\n' "$raw"
}

find_pid() {
    local pid
    local pattern="${LLAMA_SERVER_BIN:-}"

    if read_state_file && [[ -n "${CURRENT_PID:-}" ]]; then
        if kill -0 "$CURRENT_PID" 2>/dev/null && pid_matches_managed_server "$CURRENT_PID"; then
            printf '%s\n' "$CURRENT_PID"
            return 0
        fi
    fi

    if [[ -z "$pattern" ]]; then
        pattern='(^|/)llama-server([[:space:]]|$)'
    fi

    pid="$(
        pgrep -af "$pattern" 2>/dev/null \
            | awk -v port="$LLAMA_SERVER_PORT" '$0 ~ ("--port " port "([[:space:]]|$)") { print $1; exit }' \
            || true
    )"
    printf '%s\n' "$pid"
}

pid_cgroup_text() {
    local pid="$1"

    if [[ -r "/proc/$pid/cgroup" ]]; then
        cat "/proc/$pid/cgroup"
    fi
}

systemd_unit_from_cgroup_text() {
    local text="$1"
    local unit

    unit="$(printf '%s
' "$text" | grep -oE '[A-Za-z0-9_.@-]+\.service' | tail -n 1 || true)"
    [[ -n "$unit" ]] && printf '%s
' "$unit"
}

pid_systemd_unit() {
    local pid="$1"
    local cgroup_text

    cgroup_text="$(pid_cgroup_text "$pid")"
    [[ -n "$cgroup_text" ]] || return 1
    systemd_unit_from_cgroup_text "$cgroup_text"
}

pid_owned_by_manager() {
    local pid="$1"
    local managed_pid=""

    managed_pid="$(managed_state_pid 2>/dev/null || true)"
    [[ -n "$managed_pid" && "$managed_pid" == "$pid" ]]
}

cmd_arg_from_pid() {
    local pid="$1"
    local key="$2"

    if read_state_file && [[ "${CURRENT_PID:-}" == "$pid" ]] && state_value "$key" >/dev/null 2>&1; then
        state_value "$key"
        return 0
    fi

    raw_cmd_arg_from_pid "$pid" "$key"
}

lookup_model() {
    local needle="$1"
    local raw_line
    local -a fields=()
    local alias
    local path
    local extra
    local context
    local ngl
    local batch
    local threads
    local parallel
    local device
    local notes

    [[ -f "$MODELS_FILE" ]] || die "model registry not found: $MODELS_FILE"

    while IFS= read -r raw_line || [[ -n "$raw_line" ]]; do
        mapfile -d '' -t fields < <(split_tsv_record "$raw_line")
        alias="${fields[0]}"
        path="${fields[1]}"
        extra="${fields[2]}"
        context="${fields[3]}"
        ngl="${fields[4]}"
        batch="${fields[5]}"
        threads="${fields[6]}"
        parallel="${fields[7]}"
        device="${fields[8]}"
        notes="${fields[9]}"
        [[ -n "$alias" ]] || continue
        [[ "${alias:0:1}" == "#" ]] && continue
        if [[ "$alias" == "$needle" ]]; then
            printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\n' \
                "$alias" "$path" "${extra:-}" "${context:-}" "${ngl:-}" "${batch:-}" "${threads:-}" "${parallel:-}" "${device:-}" "${notes:-}"
            return 0
        fi
    done <"$MODELS_FILE"

    return 1
}

lookup_alias_for_path() {
    local needle="$1"
    local raw_line
    local -a fields=()
    local alias
    local path

    [[ -f "$MODELS_FILE" ]] || return 1

    while IFS= read -r raw_line || [[ -n "$raw_line" ]]; do
        mapfile -d '' -t fields < <(split_tsv_record "$raw_line")
        alias="${fields[0]}"
        path="${fields[1]}"
        [[ -n "$alias" ]] || continue
        [[ "${alias:0:1}" == "#" ]] && continue
        if [[ "$path" == "$needle" ]]; then
            printf '%s\n' "$alias"
            return 0
        fi
    done <"$MODELS_FILE"

    return 1
}

configured_mode_name() {
    if [[ "${LLAMA_SERVER_PARALLEL:-}" == "1" ]]; then
        printf 'single-client\n'
    else
        printf 'multi-client\n'
    fi
}

active_parallel_value() {
    local pid="$1"
    local active_parallel

    active_parallel="$(cmd_arg_from_pid "$pid" -np || true)"
    if [[ -n "$active_parallel" ]]; then
        printf '%s\n' "$active_parallel"
    else
        printf 'auto\n'
    fi
}

active_mode_name() {
    local active_parallel="$1"

    if [[ "$active_parallel" == "1" ]]; then
        printf 'single-client\n'
    else
        printf 'multi-client\n'
    fi
}

ensure_defaults_file() {
    mkdir -p "$CONFIG_DIR"
    [[ -f "$DEFAULTS_FILE" ]] || : >"$DEFAULTS_FILE"
}

set_default_value() {
    local key="$1"
    local value="$2"
    local tmp

    ensure_defaults_file
    tmp="$(mktemp)"
    awk -v key="$key" -v value="$value" '
        BEGIN { updated = 0 }
        $0 ~ ("^" key "=") {
            print key "=" value
            updated = 1
            next
        }
        { print }
        END {
            if (!updated) {
                print key "=" value
            }
        }
    ' "$DEFAULTS_FILE" >"$tmp"
    mv "$tmp" "$DEFAULTS_FILE"
}

resolve_model() {
    local spec="$1"
    local resolved

    if [[ -f "$spec" ]]; then
        printf 'custom\t%s\t\t\t\t\t\t\t\t\n' "$(canonicalize_path "$spec")"
        return 0
    fi

    if resolved="$(lookup_model "$spec")"; then
        printf '%s\n' "$resolved"
        return 0
    fi

    die "unknown model alias or path: $spec"
}

backup_log() {
    local backup_path

    [[ -s "$LLAMA_SERVER_LOG" ]] || return 0
    backup_path="${LLAMA_SERVER_LOG}.pre-switch-$(timestamp)"
    cp -a "$LLAMA_SERVER_LOG" "$backup_path"
    printf 'backed up log to %s\n' "$backup_path"
}

stop_server() {
    local pid
    local waited

    pid="$(find_pid)"
    if [[ -z "$pid" ]]; then
        clear_state_file
        return 0
    fi

    kill -INT "$pid" 2>/dev/null || true
    for waited in $(seq 1 30); do
        if ! kill -0 "$pid" 2>/dev/null; then
            wait_for_port_release
            clear_state_file
            return 0
        fi
        sleep 1
    done

    kill -TERM "$pid" 2>/dev/null || true
    for waited in $(seq 1 10); do
        if ! kill -0 "$pid" 2>/dev/null; then
            wait_for_port_release
            clear_state_file
            return 0
        fi
        sleep 1
    done

    die "server pid $pid did not stop"
}

wait_for_port_release() {
    local waited

    for waited in $(seq 1 30); do
        if ! port_is_listening; then
            return 0
        fi
        sleep 1
    done

    die "port $LLAMA_SERVER_PORT did not become free"
}

wait_for_health() {
    local pid="$1"
    local requested_context="${2:-}"
    local waited
    local url="http://${LLAMA_SERVER_HOST}:${LLAMA_SERVER_PORT}/health"

    for ((waited = 0; waited < LLAMA_SERVER_WAIT_SECONDS; waited++)); do
        if curl -fsS "$url" >/dev/null 2>&1; then
            return 0
        fi

        if ! kill -0 "$pid" 2>/dev/null; then
            tail -n 60 "$LLAMA_SERVER_LOG" >&2 || true
            startup_failure_message "$LLAMA_SERVER_LOG" "$requested_context" >&2 || true
            return 1
        fi

        sleep 1
    done

    tail -n 60 "$LLAMA_SERVER_LOG" >&2 || true
    startup_failure_message "$LLAMA_SERVER_LOG" "$requested_context" >&2 || true
    return 2
}

write_state() {
    local alias="$1"
    local model_path="$2"
    local pid="$3"
    local context="$4"
    local ngl="$5"
    local batch="$6"
    local threads="$7"
    local parallel="$8"
    local device="$9"
    local cuda_unified_memory="${10:-$(cuda_unified_memory_mode)}"
    local auto_fit_override_reason="${11:-}"

    {
        printf 'CURRENT_ALIAS=%q\n' "$alias"
        printf 'CURRENT_MODEL=%q\n' "$model_path"
        printf 'CURRENT_PID=%q\n' "$pid"
        printf 'CURRENT_PORT=%q\n' "$LLAMA_SERVER_PORT"
        printf 'CURRENT_LOG=%q\n' "$LLAMA_SERVER_LOG"
        printf 'CURRENT_CONTEXT=%q\n' "$context"
        printf 'CURRENT_NGL=%q\n' "$ngl"
        printf 'CURRENT_BATCH=%q\n' "$batch"
        printf 'CURRENT_THREADS=%q\n' "$threads"
        printf 'CURRENT_PARALLEL=%q\n' "$parallel"
        printf 'CURRENT_DEVICE=%q\n' "$device"
        printf 'CURRENT_CUDA_UNIFIED_MEMORY=%q\n' "$cuda_unified_memory"
        printf 'CURRENT_AUTO_FIT_OVERRIDE_REASON=%q\n' "$auto_fit_override_reason"
        printf 'CURRENT_STARTED_AT=%q\n' "$(iso_timestamp)"
    } >"$STATE_FILE"
}

start_server() {
    local alias="$1"
    local model_path="$2"
    local model_extra="${3:-}"
    local model_context="${4:-}"
    local model_ngl="${5:-}"
    local model_batch="${6:-}"
    local model_threads="${7:-}"
    local model_parallel="${8:-}"
    local model_device="${9:-}"
    shift 9 || true
    local -a cmd=()
    local -a extra_args=()
    local -a runtime_extra_args=()
    local -a passthrough_args=()
    local pid
    local context="${model_context:-$LLAMA_SERVER_CONTEXT}"
    local ngl="${model_ngl:-$LLAMA_SERVER_NGL}"
    local batch="${model_batch:-$LLAMA_SERVER_BATCH}"
    local threads="${model_threads:-$LLAMA_SERVER_THREADS}"
    local device="${model_device:-$LLAMA_SERVER_DEVICE}"
    local parallel="${model_parallel:-$LLAMA_SERVER_PARALLEL}"
    local expected_device_backend
    local auto_fit="${LLAMA_MODEL_AUTO_FIT:-1}"
    local require_mmproj="0"
    local force_mmproj="0"
    local attempt=1
    local max_attempts=3
    local gpu_total=""
    local system_available=""
    local fit_posture=""
    local fit_guidance=""
    local hybrid_ngl=""
    local recommended_context=""
    local competing_rows=""
    local cuda_unified_memory="$(cuda_unified_memory_mode)"
    local auto_fit_override_reason=""
    local exit_status=0

    while (($#)); do
        case "$1" in
            --auto-fit)
                auto_fit="1"
                shift
                ;;
            --no-auto-fit)
                auto_fit="0"
                shift
                ;;
            --require-mmproj)
                require_mmproj="1"
                shift
                ;;
            --force-mmproj)
                force_mmproj="1"
                shift
                ;;
            --)
                shift
                passthrough_args+=("$@")
                break
                ;;
            *)
                passthrough_args+=("$1")
                shift
                ;;
        esac
    done

    probe_server_binary || die "${SELECTED_LLAMA_SERVER_MESSAGE}

${SELECTED_LLAMA_SERVER_GUIDANCE}"
    [[ -f "$model_path" ]] || die "model not found: $model_path"

    LLAMA_SERVER_BIN="$SELECTED_LLAMA_SERVER_BIN"
    expected_device_backend="$(infer_backend_from_device "$device")"
    if [[ "$SELECTED_LLAMA_SERVER_BACKEND" == "cpu" ]]; then
        ngl="0"
        device=""
    elif [[ "$SELECTED_LLAMA_SERVER_BACKEND" != "external" && -n "$expected_device_backend" && "$expected_device_backend" != "$SELECTED_LLAMA_SERVER_BACKEND" ]]; then
        die "configured device ${device} expects backend ${expected_device_backend}, but selected llama-server binary uses ${SELECTED_LLAMA_SERVER_BACKEND}. Clear the device override or build a matching runtime."
    fi

    validate_mmproj_for_model "$model_path" "$model_extra" "$force_mmproj" "$require_mmproj"

    if [[ -n "$model_extra" ]]; then
        mapfile -d '' -t extra_args < <(split_shell_words "$model_extra")
    fi
    if [[ -n "$LLAMA_SERVER_EXTRA_ARGS" ]]; then
        mapfile -d '' -t runtime_extra_args < <(split_shell_words "$LLAMA_SERVER_EXTRA_ARGS")
    fi

    mkdir -p "$(dirname "$LLAMA_SERVER_LOG")"

    if [[ "$SELECTED_LLAMA_SERVER_BACKEND" == "cuda" || "$device" == cuda* ]]; then
        gpu_total="$(detect_gpu_total_mib || true)"
        system_available="$(detect_system_available_mib || true)"
        fit_posture="$(autofit_memory_posture "$gpu_total" "$system_available")"
        fit_guidance="$(autofit_memory_guidance "$fit_posture")"
        hybrid_ngl="$(hybrid_ngl_for_system_memory "$system_available")"
        if [[ "$auto_fit" == "1" && "$fit_posture" != "gpu-fit" && -n "$fit_guidance" ]]; then
            printf 'auto_fit_posture: %s\n' "$fit_posture"
            printf 'auto_fit_tradeoff: %s\n' "$fit_guidance"
        fi
        if [[ -n "$gpu_total" ]]; then
            recommended_context="$(safe_context_for_gpu_mib "$gpu_total")"
            if [[ "$context" =~ ^[0-9]+$ && "$recommended_context" =~ ^[0-9]+$ && "$context" -gt "$recommended_context" ]]; then
                if cuda_unified_memory_enabled; then
                    auto_fit_override_reason="unified-memory"
                    printf 'preflight_status: unified-memory-risk\n'
                    printf 'preflight_reason: requested context %s exceeds the normal VRAM-safe heuristic for %s MiB, but GGML_CUDA_ENABLE_UNIFIED_MEMORY=1 is enabled so the launch will be attempted\n' "$context" "$gpu_total"
                    printf 'recommended_context: %s\n' "$recommended_context"
                    printf 'performance_warning: CUDA unified memory may be substantially slower on discrete GPUs\n'
                    if [[ -z "$parallel" || "$parallel" == "auto" ]]; then
                        parallel="1"
                        printf 'auto_fit: parallel auto -> 1 to preserve a single context budget while unified memory is enabled\n'
                    fi
                elif [[ "$auto_fit" == "1" ]]; then
                    printf 'auto_fit: context %s -> %s based on detected GPU memory (%s MiB)\n' "$context" "$recommended_context" "$gpu_total"
                    context="$recommended_context"
                    if [[ -z "$parallel" || "$parallel" == "auto" ]]; then
                        parallel="1"
                        printf 'auto_fit: parallel auto -> 1 to preserve a single context budget\n'
                    fi
                else
                    printf 'preflight_status: risky\n' >&2
                    printf 'preflight_reason: requested context %s is high for detected GPU memory (%s MiB)\n' "$context" "$gpu_total" >&2
                    printf 'recommended_context: %s\n' "$recommended_context" >&2
                fi
            fi
        fi
        competing_rows="$(llama_server_process_rows | grep -v "port=${LLAMA_SERVER_PORT} " || true)"
        if [[ -n "$competing_rows" && "$auto_fit" == "1" && "$gpu_total" =~ ^[0-9]+$ && "$gpu_total" -le 12288 && "$ngl" =~ ^[0-9]+$ ]]; then
            if [[ "$hybrid_ngl" =~ ^[0-9]+$ && "$hybrid_ngl" -gt 0 && "$ngl" -gt "$hybrid_ngl" ]]; then
                printf 'auto_fit: detected another llama-server using GPU memory; GPU layers %s -> %s for safer hybrid CPU/GPU offload\n' "$ngl" "$hybrid_ngl"
                printf 'auto_fit_tradeoff: system RAM will carry more model state; expect slower runs than full GPU offload\n'
                ngl="$hybrid_ngl"
            elif [[ "$hybrid_ngl" =~ ^[0-9]+$ && "$hybrid_ngl" -le 0 ]]; then
                printf 'preflight_status: memory-risk\n' >&2
                printf 'preflight_reason: another llama-server is using GPU memory and available system RAM is not enough for a safer hybrid downshift\n' >&2
            else
                printf 'preflight_status: gpu-pressure\n' >&2
                printf 'preflight_reason: another llama-server is using GPU memory; current GPU layer count is already within the RAM-aware hybrid target\n' >&2
            fi
        elif [[ -n "$competing_rows" ]]; then
            printf 'preflight_status: gpu-pressure\n' >&2
            printf 'preflight_reason: another llama-server process is already running; inspect llama-model doctor before using aggressive context/offload settings\n' >&2
        fi
    fi

    while :; do
        cmd=(
            "$LLAMA_SERVER_BIN"
            -m "$model_path"
            -c "$context"
            -ngl "$ngl"
            -b "$batch"
            --threads "$threads"
            --port "$LLAMA_SERVER_PORT"
        )

        if [[ -n "$device" ]]; then
            cmd+=(--device "$device")
        fi

        if [[ -n "$parallel" ]] && [[ "$parallel" != "auto" ]]; then
            cmd+=(-np "$parallel")
        fi

        if ((${#extra_args[@]})); then
            cmd+=("${extra_args[@]}")
        fi
        if ((${#runtime_extra_args[@]})); then
            cmd+=("${runtime_extra_args[@]}")
        fi
        if ((${#passthrough_args[@]})); then
            cmd+=("${passthrough_args[@]}")
        fi

        if cuda_unified_memory_enabled; then
            env GGML_CUDA_ENABLE_UNIFIED_MEMORY=1 setsid "${cmd[@]}" >"$LLAMA_SERVER_LOG" 2>&1 < /dev/null &
        else
            setsid "${cmd[@]}" >"$LLAMA_SERVER_LOG" 2>&1 < /dev/null &
        fi
        pid=$!
        disown "$pid" 2>/dev/null || true

        if wait_for_health "$pid" "$context"; then
            write_state "$alias" "$model_path" "$pid" "$context" "$ngl" "$batch" "$threads" "${parallel:-auto}" "$device" "$cuda_unified_memory" "$auto_fit_override_reason"
            post_switch_client_sync "$alias" "$model_path" "$context"

            if [[ -n "$SELECTED_LLAMA_SERVER_MESSAGE" ]]; then
                printf 'note: %s\n' "$SELECTED_LLAMA_SERVER_MESSAGE"
            fi
            printf 'started %s on port %s with pid %s\n' "$alias" "$LLAMA_SERVER_PORT" "$pid"
            return 0
        else
            exit_status=$?
        fi

        if kill -0 "$pid" 2>/dev/null; then
            kill -TERM "$pid" 2>/dev/null || true
        fi

        if [[ "$auto_fit" != "1" || "$attempt" -ge "$max_attempts" ]]; then
            if [[ "$exit_status" -eq 2 ]]; then
                die "timed out waiting for http://${LLAMA_SERVER_HOST}:${LLAMA_SERVER_PORT}/health"
            fi
            die "llama-server exited during startup"
        fi

        case "$STARTUP_FAILURE_CATEGORY" in
            kv-cache-oom)
                if [[ "$context" =~ ^[0-9]+$ && "$context" -gt 32768 ]]; then
                    printf 'auto_fit: retrying after KV-cache OOM with context %s -> 32768\n' "$context"
                    context="32768"
                elif [[ -z "$parallel" || "$parallel" == "auto" || "$parallel" != "1" ]]; then
                    printf 'auto_fit: retrying after KV-cache OOM with parallel %s -> 1\n' "${parallel:-auto}"
                    parallel="1"
                elif [[ "$ngl" =~ ^[0-9]+$ && "$hybrid_ngl" =~ ^[0-9]+$ && "$hybrid_ngl" -gt 0 && "$ngl" -gt "$hybrid_ngl" ]]; then
                    printf 'auto_fit: retrying after KV-cache OOM with GPU layers %s -> %s for hybrid CPU/GPU offload\n' "$ngl" "$hybrid_ngl"
                    printf 'auto_fit_tradeoff: system RAM improves startup headroom here, but generation will be slower than full GPU offload\n'
                    ngl="$hybrid_ngl"
                else
                    die "llama-server exited during startup"
                fi
                ;;
            cuda-oom)
                if [[ "$ngl" =~ ^[0-9]+$ && "$hybrid_ngl" =~ ^[0-9]+$ && "$hybrid_ngl" -gt 0 && "$ngl" -gt "$hybrid_ngl" ]]; then
                    printf 'auto_fit: retrying after CUDA OOM with GPU layers %s -> %s for hybrid CPU/GPU offload\n' "$ngl" "$hybrid_ngl"
                    printf 'auto_fit_tradeoff: system RAM improves startup headroom here, but generation will be slower than full GPU offload\n'
                    ngl="$hybrid_ngl"
                elif [[ "$context" =~ ^[0-9]+$ && "$context" -gt 32768 ]]; then
                    printf 'auto_fit: retrying after CUDA OOM with context %s -> 32768\n' "$context"
                    context="32768"
                else
                    die "llama-server exited during startup"
                fi
                ;;
            mmproj-mismatch)
                if [[ "$require_mmproj" == "1" ]]; then
                    die "llama-server exited during startup"
                fi
                model_extra="$(strip_mmproj_from_extra "$model_extra")"
                extra_args=()
                if [[ -n "$model_extra" ]]; then
                    mapfile -d '' -t extra_args < <(split_shell_words "$model_extra")
                fi
                printf 'auto_fit: retrying without --mmproj after projector mismatch (text-only launch)\n'
                ;;
            *)
                die "llama-server exited during startup"
                ;;
        esac

        attempt=$((attempt + 1))
    done
}

list_models() {
    local pid
    local current_model=""
    local alias
    local path
    local extra
    local context
    local ngl
    local batch
    local threads
    local parallel
    local device
    local notes
    local marker
    local status
    local preset
    local raw_line
    local -a fields=()

    [[ -f "$MODELS_FILE" ]] || die "model registry not found: $MODELS_FILE"

    pid="$(find_pid)"
    if [[ -n "$pid" ]]; then
        current_model="$(cmd_arg_from_pid "$pid" -m || true)"
    fi

    printf '  %-18s %-8s %-8s %s\n' "ALIAS" "STATUS" "PRESET" "MODEL"
    while IFS= read -r raw_line || [[ -n "$raw_line" ]]; do
        mapfile -d '' -t fields < <(split_tsv_record "$raw_line")
        alias="${fields[0]}"
        path="${fields[1]}"
        extra="${fields[2]}"
        context="${fields[3]}"
        ngl="${fields[4]}"
        batch="${fields[5]}"
        threads="${fields[6]}"
        parallel="${fields[7]}"
        device="${fields[8]}"
        notes="${fields[9]}"
        [[ -n "$alias" ]] || continue
        [[ "${alias:0:1}" == "#" ]] && continue
        marker=" "
        status="ok"
        preset="default"
        [[ -f "$path" ]] || status="missing"
        [[ "$path" == "$current_model" ]] && marker="*"
        if [[ -n "${extra:-}${context:-}${ngl:-}${batch:-}${threads:-}${parallel:-}${device:-}${notes:-}" ]]; then
            preset="custom"
        fi
        printf '%s %-18s %-8s %-8s %s\n' "$marker" "$alias" "$status" "$preset" "$path"
    done <"$MODELS_FILE"
}

show_model() {
    local resolved
    local -a fields=()
    local alias
    local model_path
    local model_extra
    local model_context
    local model_ngl
    local model_batch
    local model_threads
    local model_parallel
    local model_device
    local model_notes

    resolved="$(lookup_model "$1")" || die "unknown model alias: $1"
    mapfile -d '' -t fields < <(split_tsv_record "$resolved")
    alias="${fields[0]}"
    model_path="${fields[1]}"
    model_extra="${fields[2]}"
    model_context="${fields[3]}"
    model_ngl="${fields[4]}"
    model_batch="${fields[5]}"
    model_threads="${fields[6]}"
    model_parallel="${fields[7]}"
    model_device="${fields[8]}"
    model_notes="${fields[9]}"

    printf 'alias: %s\n' "$alias"
    printf 'model: %s\n' "$model_path"
    printf 'exists: %s\n' "$([[ -f "$model_path" ]] && printf yes || printf no)"
    printf 'extra_args: %s\n' "${model_extra:-}"
    printf 'context: %s\n' "${model_context:-default ($LLAMA_SERVER_CONTEXT)}"
    printf 'ngl: %s\n' "${model_ngl:-default ($LLAMA_SERVER_NGL)}"
    printf 'batch: %s\n' "${model_batch:-default ($LLAMA_SERVER_BATCH)}"
    printf 'threads: %s\n' "${model_threads:-default ($LLAMA_SERVER_THREADS)}"
    printf 'parallel: %s\n' "${model_parallel:-default (${LLAMA_SERVER_PARALLEL:-auto})}"
    printf 'device: %s\n' "${model_device:-default ($LLAMA_SERVER_DEVICE)}"
    printf 'notes: %s\n' "${model_notes:-}"
}

show_current() {
    local pid
    local model_path
    local alias
    local url="http://${LLAMA_SERVER_HOST}:${LLAMA_SERVER_PORT}/health"
    local active_parallel
    local active_mode
    local cuda_unified_memory
    local auto_fit_override_reason

    pid="$(find_pid)"
    if [[ -z "$pid" ]]; then
        printf 'llama-server is not running on port %s\n' "$LLAMA_SERVER_PORT"
        printf 'configured_mode: %s\n' "$(configured_mode_name)"
        if [[ -n "${LLAMA_SERVER_PARALLEL:-}" ]]; then
            printf 'configured_parallel: %s\n' "$LLAMA_SERVER_PARALLEL"
        else
            printf 'configured_parallel: auto\n'
        fi
        printf 'cuda_unified_memory: %s\n' "$(cuda_unified_memory_mode)"
        return 0
    fi

    model_path="$(cmd_arg_from_pid "$pid" -m || true)"
    alias="$(lookup_alias_for_path "$model_path" || true)"
    [[ -n "$alias" ]] || alias="custom"
    active_parallel="$(active_parallel_value "$pid")"
    active_mode="$(active_mode_name "$active_parallel")"
    cuda_unified_memory="$(active_cuda_unified_memory_value "$pid")"
    auto_fit_override_reason="$(active_auto_fit_override_reason "$pid")"

    printf 'pid: %s\n' "$pid"
    printf 'alias: %s\n' "$alias"
    printf 'model: %s\n' "$model_path"
    printf 'log: %s\n' "$LLAMA_SERVER_LOG"
    printf 'configured_mode: %s\n' "$(configured_mode_name)"
    if [[ -n "${LLAMA_SERVER_PARALLEL:-}" ]]; then
        printf 'configured_parallel: %s\n' "$LLAMA_SERVER_PARALLEL"
    else
        printf 'configured_parallel: auto\n'
    fi
    printf 'active_mode: %s\n' "$active_mode"
    printf 'active_parallel: %s\n' "$active_parallel"
    printf 'active_context: %s\n' "$(cmd_arg_from_pid "$pid" -c || printf unknown)"
    printf 'active_ngl: %s\n' "$(cmd_arg_from_pid "$pid" -ngl || printf unknown)"
    printf 'active_batch: %s\n' "$(cmd_arg_from_pid "$pid" -b || printf unknown)"
    printf 'active_threads: %s\n' "$(cmd_arg_from_pid "$pid" --threads || printf unknown)"
    printf 'active_device: %s\n' "$(cmd_arg_from_pid "$pid" --device || printf unknown)"
    printf 'cuda_unified_memory: %s\n' "$cuda_unified_memory"
    if [[ -n "$auto_fit_override_reason" ]]; then
        printf 'auto_fit_override_reason: %s\n' "$auto_fit_override_reason"
    fi
    if curl -fsS "$url" >/dev/null 2>&1; then
        printf 'health: ok (%s)\n' "$url"
    else
        printf 'health: unavailable (%s)\n' "$url"
    fi
}

show_doctor() {
    local pid
    local model_path=""
    local alias="stopped"
    local url="http://${LLAMA_SERVER_HOST}:${LLAMA_SERVER_PORT}/health"
    local health="unavailable"
    local build_info=""
    local offload=""
    local kv_buffer=""
    local graph_splits=""
    local listening=""
    local binary_ok="no"
    local external_owner="no"
    local external_owner_unit=""
    local external_owner_message=""
    local startup_category=""
    local startup_diagnosis=""
    local startup_suggested_fix=""
    local gpu_memory=""
    local system_memory=""
    local gpu_total_mib=""
    local system_available_mib=""
    local fit_posture=""
    local fit_guidance=""
    local gpu_process_rows=""
    local gpu_process_count="0"
    local gpu_processes=""
    local cuda_unified_memory="$(cuda_unified_memory_mode)"
    local auto_fit_override_reason=""
    local installed_web_launcher="no"
    local installed_web_app="no"
    local installed_gateway_script="no"
    local bundled_glyphos="no"
    local bundled_glyphos_importable="no"
    local bundled_glyphos_import_error=""
    local context_mode_mcp="no"
    local context_mode_mcp_dist="no"
    local install_ok="yes"
    local install_guidance=""
    local dashboard_api_reachable="no"
    local dashboard_api_glyphos_telemetry="unknown"
    local dashboard_api_glyphos_install_detail="unknown"
    local dashboard_api_glyphos_error=""
    local dashboard_api_context_glyphos_status="unknown"
    local dashboard_api_glyphos_config="unknown"
    local dashboard_api_guidance=""
    local dashboard_state_json=""
    local gateway_status_text=""
    local gateway_running="unknown"
    local gateway_health="unknown"
    local gateway_url="$(lmm_gateway_api_base)"
    local gateway_backend_api_base="$(upstream_api_base)"
    local gateway_mode_default
    local legacy_opencode_gateway_default="no"
    local harness_mode_configured="yes"
    local route_state="routed"
    local route_guidance=""
    local stale_opencode_providers=""

    pid="$(find_pid)"
    if [[ -n "$pid" ]]; then
        model_path="$(cmd_arg_from_pid "$pid" -m || true)"
        alias="$(lookup_alias_for_path "$model_path" || true)"
        [[ -n "$alias" ]] || alias="custom"
        cuda_unified_memory="$(active_cuda_unified_memory_value "$pid")"
        auto_fit_override_reason="$(active_auto_fit_override_reason "$pid")"
        if curl -fsS "$url" >/dev/null 2>&1; then
            health="ok"
        fi
    fi

    if [[ -f "$LLAMA_SERVER_LOG" ]]; then
        build_info="$(grep -F 'build_info:' "$LLAMA_SERVER_LOG" | tail -n 1 | sed 's/^.*build_info: //' || true)"
        offload="$(grep -E 'offloaded [0-9]+/[0-9]+ layers to GPU' "$LLAMA_SERVER_LOG" | tail -n 1 | sed 's/^.*offloaded /offloaded /' || true)"
        kv_buffer="$(grep -E 'KV buffer size = ' "$LLAMA_SERVER_LOG" | tail -n 1 | sed 's/^.*KV buffer size = //' || true)"
        graph_splits="$(grep -E 'graph splits = ' "$LLAMA_SERVER_LOG" | tail -n 1 | sed 's/^.*graph splits = //' || true)"
        listening="$(grep -F 'server is listening on' "$LLAMA_SERVER_LOG" | tail -n 1 | sed 's/^.*server is listening on //' || true)"
        classify_startup_log_file "$LLAMA_SERVER_LOG"
        if [[ "$STARTUP_FAILURE_CATEGORY" != "unknown" ]]; then
            startup_category="$STARTUP_FAILURE_CATEGORY"
            startup_diagnosis="$STARTUP_FAILURE_SUMMARY"
            startup_suggested_fix="$STARTUP_FAILURE_ACTION"
        fi
    fi

    gpu_memory="$(gpu_memory_report || true)"
    system_memory="$(system_memory_report || true)"
    gpu_total_mib="$(detect_gpu_total_mib || true)"
    system_available_mib="$(detect_system_available_mib || true)"
    fit_posture="$(autofit_memory_posture "$gpu_total_mib" "$system_available_mib")"
    fit_guidance="$(autofit_memory_guidance "$fit_posture")"
    gpu_process_rows="$(llama_server_process_rows || true)"
    if [[ -n "$gpu_process_rows" ]]; then
        gpu_process_count="$(printf '%s\n' "$gpu_process_rows" | grep -c . || true)"
        gpu_processes="$(printf '%s\n' "$gpu_process_rows" | awk 'NF { printf "%s%s", sep, $0; sep="; " }')"
    fi

    if [[ -n "$pid" ]] && ! pid_owned_by_manager "$pid"; then
        external_owner="yes"
        external_owner_unit="$(pid_systemd_unit "$pid" || true)"
        if [[ -n "$external_owner_unit" ]]; then
            external_owner_message="external systemd service appears to own port ${LLAMA_SERVER_PORT}; stop/disable ${external_owner_unit} or move one side to a different port"
        else
            external_owner_message="external llama-server process appears to own port ${LLAMA_SERVER_PORT}; stop/disable that service or move one side to a different port"
        fi
    fi

    if probe_server_binary; then
        binary_ok="yes"
    fi

    [[ -x "$HOME/.local/bin/llama-model-web" ]] && installed_web_launcher="yes"
    [[ -f "$INSTALLED_APP_ROOT/web/app.py" ]] && installed_web_app="yes"
    [[ -f "$INSTALLED_APP_ROOT/scripts/glyphos_openai_gateway.py" ]] && installed_gateway_script="yes"
    [[ -d "$INSTALLED_APP_ROOT/integrations/public-glyphos-ai-compute/glyphos_ai" ]] && bundled_glyphos="yes"
    gateway_mode_default="$(normalize_harness_mode "$LLAMA_MODEL_HARNESS_MODE")"
    if [[ -f "$DEFAULTS_FILE" ]]; then
        if grep -Eq '^[[:space:]]*(export[[:space:]]+)?LLAMA_MODEL_OPENCODE_GATEWAY_BASE_URL=' "$DEFAULTS_FILE"; then
            legacy_opencode_gateway_default="yes"
        fi
        if ! grep -Eq '^[[:space:]]*(export[[:space:]]+)?LLAMA_MODEL_HARNESS_MODE=' "$DEFAULTS_FILE"; then
            harness_mode_configured="no"
        fi
    else
        harness_mode_configured="no"
    fi
    if [[ -f "$OPENCODE_CONFIG_FILE" ]]; then
        stale_opencode_providers="$(python3 - "$OPENCODE_CONFIG_FILE" "$gateway_url" "$gateway_backend_api_base" "$gateway_mode_default" <<'PY' 2>/dev/null || true
import json
import sys
from urllib.parse import urlparse

path, gateway_url, backend_url, route_mode = sys.argv[1:5]
try:
    data = json.load(open(path, encoding="utf-8"))
except Exception:
    print("unreadable")
    raise SystemExit(0)
providers = data.get("provider") if isinstance(data, dict) else {}
if not isinstance(providers, dict):
    print("")
    raise SystemExit(0)
selected = str(data.get("model") or "")
selected_provider = selected.split("/", 1)[0] if "/" in selected else ""
gateway = urlparse(gateway_url).netloc
backend = urlparse(backend_url).netloc
stale = []
for name, provider in providers.items():
    if not isinstance(provider, dict):
        continue
    options = provider.get("options")
    if not isinstance(options, dict):
        continue
    base = str(options.get("baseURL") or options.get("baseUrl") or "")
    netloc = urlparse(base).netloc
    if netloc.endswith(":8080") or (route_mode == "routed" and name == selected_provider and netloc == backend):
        stale.append(str(name))
    elif route_mode == "routed" and name == "llamacpp" and netloc and netloc != gateway:
        stale.append(str(name))
print(",".join(sorted(set(stale))))
PY
)"
    fi
    if [[ "$legacy_opencode_gateway_default" == "yes" || -n "$stale_opencode_providers" ]]; then
        route_state="mixed-legacy"
        route_guidance="Run install.sh to migrate defaults, then run llama-model sync-opencode and llama-model sync-openclaw to align harnesses with the routed gateway."
    elif [[ "$gateway_mode_default" == "direct" ]]; then
        route_state="direct"
        route_guidance="Direct mode is active; harnesses bypass the LMM gateway and Context + GlyphOS until LLAMA_MODEL_HARNESS_MODE=routed or --mode routed is used."
    elif [[ "$harness_mode_configured" == "no" ]]; then
        route_state="routed-default-missing"
        route_guidance="LLAMA_MODEL_HARNESS_MODE is not written in defaults.env; rerun install.sh to persist routed gateway defaults."
    else
        route_state="routed"
    fi
    if gateway_status_text="$(lmm_gateway_status 2>/dev/null)"; then
        gateway_running="$(printf '%s\n' "$gateway_status_text" | awk -F': ' '/^running: / { print $2; exit }')"
        gateway_health="$(printf '%s\n' "$gateway_status_text" | awk -F': ' '/^health: / { print $2; exit }')"
    fi
    if [[ "$bundled_glyphos" == "yes" ]]; then
        bundled_glyphos_import_error="$(
            GLYPHOS_ROOT="$INSTALLED_APP_ROOT/integrations/public-glyphos-ai-compute" python3 - <<'PY' 2>&1
import os
import sys

sys.path.insert(0, os.environ["GLYPHOS_ROOT"])
from glyphos_ai.ai_compute.router import routing_telemetry_snapshot

snapshot = routing_telemetry_snapshot(limit=1)
if not isinstance(snapshot, dict):
    raise TypeError("routing_telemetry_snapshot did not return a dict")
PY
        )" && bundled_glyphos_importable="yes" || bundled_glyphos_importable="no"
    fi
    [[ -f "$INSTALLED_APP_ROOT/integrations/context-mode-mcp/package.json" ]] && context_mode_mcp="yes"
    [[ -f "$INSTALLED_APP_ROOT/integrations/context-mode-mcp/dist/index.js" ]] && context_mode_mcp_dist="yes"
    if [[ "$installed_web_launcher" != "yes" || "$installed_web_app" != "yes" || "$installed_gateway_script" != "yes" || "$bundled_glyphos" != "yes" || "$bundled_glyphos_importable" != "yes" || "$context_mode_mcp" != "yes" || "$context_mode_mcp_dist" != "yes" ]]; then
        install_ok="no"
        if [[ "$context_mode_mcp" == "yes" && "$context_mode_mcp_dist" != "yes" ]]; then
            install_guidance="Run llama-model context-mcp build, then llama-model gateway restart and restart llama-model-web."
        else
            install_guidance="Run ./install.sh from the current repo checkout, or rerun the latest bootstrap installer, then restart llama-model-web."
        fi
    fi
    if [[ "${LLAMA_MODEL_DOCTOR_SKIP_DASHBOARD_API:-0}" != "1" ]] && dashboard_state_json="$(curl -fsS --max-time 2 "${DASHBOARD_SERVICE_URL%/}/api/state" 2>/dev/null)"; then
        dashboard_api_reachable="yes"
        while IFS='=' read -r key value; do
            case "$key" in
                glyphos_telemetry) dashboard_api_glyphos_telemetry="$value" ;;
                glyphos_install_detail) dashboard_api_glyphos_install_detail="$value" ;;
                glyphos_error) dashboard_api_glyphos_error="$value" ;;
                context_status) dashboard_api_context_glyphos_status="$value" ;;
                glyphos_config) dashboard_api_glyphos_config="$value" ;;
            esac
        done < <(printf '%s' "$dashboard_state_json" | python3 -c '
import json
import sys

try:
    data = json.load(sys.stdin)
except Exception:
    data = {}

glyphos = data.get("glyphos_telemetry") if isinstance(data.get("glyphos_telemetry"), dict) else {}
context = data.get("context_glyphos_pipeline") if isinstance(data.get("context_glyphos_pipeline"), dict) else {}
print("glyphos_telemetry=" + ("yes" if glyphos.get("available") else "no"))
print("glyphos_install_detail=" + ("yes" if "installed" in glyphos else "unknown"))
print("glyphos_error=" + str(glyphos.get("error") or ""))
print("context_status=" + str(context.get("status") or "missing"))
print("glyphos_config=" + ("yes" if data.get("glyphos_config_exists") else "no"))
')
        if [[ "$dashboard_api_glyphos_config" == "yes" && "$dashboard_api_glyphos_telemetry" != "yes" && "$bundled_glyphos" == "yes" ]]; then
            dashboard_api_guidance="Live dashboard cannot see bundled GlyphOS even though install assets exist; restart llama-model-web and hard refresh the browser."
        elif [[ "$dashboard_api_glyphos_install_detail" == "unknown" && "$bundled_glyphos_importable" == "yes" ]]; then
            dashboard_api_guidance="Live dashboard is running older backend code; restart llama-model-web and hard refresh the browser so the refreshed package state appears."
        fi
    fi

    printf 'pid: %s\n' "${pid:-stopped}"
    printf 'alias: %s\n' "$alias"
    printf 'model: %s\n' "${model_path:-}"
    printf 'health: %s\n' "$health"
    printf 'host_os: %s\n' "$SELECTED_LLAMA_SERVER_HOST_OS"
    printf 'host_arch: %s\n' "$SELECTED_LLAMA_SERVER_HOST_ARCH"
    printf 'host_backends: %s\n' "$SELECTED_LLAMA_SERVER_HOST_BACKENDS"
    printf 'defaults_file: %s\n' "$DEFAULTS_FILE"
    printf 'registry_file: %s\n' "$MODELS_FILE"
    printf 'log: %s\n' "$LLAMA_SERVER_LOG"
    printf 'installed_app_root: %s\n' "$INSTALLED_APP_ROOT"
    printf 'installed_web_launcher: %s\n' "$installed_web_launcher"
    printf 'installed_web_app: %s\n' "$installed_web_app"
    printf 'installed_gateway_script: %s\n' "$installed_gateway_script"
    printf 'bundled_glyphos_integration: %s\n' "$bundled_glyphos"
    printf 'bundled_glyphos_importable: %s\n' "$bundled_glyphos_importable"
    printf 'bundled_glyphos_import_error: %s\n' "$bundled_glyphos_import_error"
    printf 'context_mode_mcp_installed: %s\n' "$context_mode_mcp"
    printf 'context_mode_mcp_dist: %s\n' "$context_mode_mcp_dist"
    printf 'install_ok: %s\n' "$install_ok"
    printf 'install_guidance: %s\n' "$install_guidance"
    printf 'dashboard_api_reachable: %s\n' "$dashboard_api_reachable"
    printf 'dashboard_api_glyphos_telemetry: %s\n' "$dashboard_api_glyphos_telemetry"
    printf 'dashboard_api_glyphos_install_detail: %s\n' "$dashboard_api_glyphos_install_detail"
    printf 'dashboard_api_glyphos_error: %s\n' "$dashboard_api_glyphos_error"
    printf 'dashboard_api_context_glyphos_status: %s\n' "$dashboard_api_context_glyphos_status"
    printf 'dashboard_api_glyphos_config: %s\n' "$dashboard_api_glyphos_config"
    printf 'dashboard_api_guidance: %s\n' "$dashboard_api_guidance"
    printf 'gateway_running: %s\n' "$gateway_running"
    printf 'gateway_health: %s\n' "$gateway_health"
    printf 'gateway_url: %s\n' "$gateway_url"
    printf 'gateway_backend_api_base: %s\n' "$gateway_backend_api_base"
    printf 'gateway_mode_default: %s\n' "$gateway_mode_default"
    printf 'route_state: %s\n' "$route_state"
    printf 'route_guidance: %s\n' "$route_guidance"
    printf 'legacy_opencode_gateway_default: %s\n' "$legacy_opencode_gateway_default"
    printf 'harness_mode_configured: %s\n' "$harness_mode_configured"
    printf 'stale_opencode_providers: %s\n' "$stale_opencode_providers"
    printf 'binary_ok: %s\n' "$binary_ok"
    printf 'binary: %s\n' "${SELECTED_LLAMA_SERVER_BIN:-}"
    printf 'binary_source: %s\n' "${SELECTED_LLAMA_SERVER_SOURCE:-none}"
    printf 'binary_backend: %s\n' "${SELECTED_LLAMA_SERVER_BACKEND:-none}"
    printf 'binary_status: %s\n' "${SELECTED_LLAMA_SERVER_STATUS:-unavailable}"
    printf 'binary_message: %s\n' "${SELECTED_LLAMA_SERVER_MESSAGE:-}"
    printf 'binary_guidance: %s\n' "${SELECTED_LLAMA_SERVER_GUIDANCE:-}"
    printf 'binary_label: %s\n' "${SELECTED_LLAMA_SERVER_LABEL:-}"
    printf 'external_owner: %s\n' "$external_owner"
    printf 'external_owner_unit: %s\n' "$external_owner_unit"
    printf 'external_owner_message: %s\n' "$external_owner_message"
    printf 'startup_category: %s\n' "$startup_category"
    printf 'startup_diagnosis: %s\n' "$startup_diagnosis"
    printf 'startup_suggested_fix: %s\n' "$startup_suggested_fix"
    printf 'gpu_memory: %s\n' "$gpu_memory"
    printf 'system_memory: %s\n' "$system_memory"
    printf 'fit_posture: %s\n' "$fit_posture"
    printf 'fit_guidance: %s\n' "$fit_guidance"
    printf 'cuda_unified_memory: %s\n' "$cuda_unified_memory"
    printf 'auto_fit_override_reason: %s\n' "$auto_fit_override_reason"
    printf 'gpu_process_count: %s\n' "$gpu_process_count"
    printf 'gpu_processes: %s\n' "$gpu_processes"
    printf 'endpoint: http://%s:%s/v1\n' "$LLAMA_SERVER_HOST" "$LLAMA_SERVER_PORT"
    printf 'build_info: %s\n' "$build_info"
    printf 'offload: %s\n' "$offload"
    printf 'kv_buffer: %s\n' "$kv_buffer"
    printf 'graph_splits: %s\n' "$graph_splits"
    printf 'server: %s\n' "$listening"
}

show_mode() {
    local pid
    local active_parallel="stopped"

    pid="$(find_pid)"
    if [[ -n "$pid" ]]; then
        active_parallel="$(active_parallel_value "$pid")"
    fi

    printf 'configured_mode: %s\n' "$(configured_mode_name)"
    if [[ -n "${LLAMA_SERVER_PARALLEL:-}" ]]; then
        printf 'configured_parallel: %s\n' "$LLAMA_SERVER_PARALLEL"
    else
        printf 'configured_parallel: auto\n'
    fi
    printf 'active_parallel: %s\n' "$active_parallel"
    if [[ "$active_parallel" == "stopped" ]]; then
        printf 'active_mode: stopped\n'
    else
        printf 'active_mode: %s\n' "$(active_mode_name "$active_parallel")"
    fi
}

set_mode() {
    local mode="$1"
    local restart_after="${2:-}"

    case "$mode" in
        single)
            set_default_value "LLAMA_SERVER_PARALLEL" "1"
            LLAMA_SERVER_PARALLEL="1"
            ;;
        multi)
            set_default_value "LLAMA_SERVER_PARALLEL" ""
            LLAMA_SERVER_PARALLEL=""
            ;;
        *)
            die "unknown mode: $mode (expected single or multi)"
            ;;
    esac

    printf 'configured_mode: %s\n' "$(configured_mode_name)"
    if [[ -n "${LLAMA_SERVER_PARALLEL:-}" ]]; then
        printf 'configured_parallel: %s\n' "$LLAMA_SERVER_PARALLEL"
    else
        printf 'configured_parallel: auto\n'
    fi

    if [[ "$restart_after" == "--restart" ]]; then
        restart_model
    else
        printf 'note: restart the server to apply this mode\n'
    fi
}

switch_model() {
    local spec="$1"
    shift || true
    local resolved
    local alias
    local model_path
    local model_extra
    local model_context
    local model_ngl
    local model_batch
    local model_threads
    local model_parallel
    local model_device
    local model_notes
    local -a fields=()

    resolved="$(resolve_model "$spec")"
    mapfile -d '' -t fields < <(split_tsv_record "$resolved")
    alias="${fields[0]}"
    model_path="${fields[1]}"
    model_extra="${fields[2]}"
    model_context="${fields[3]}"
    model_ngl="${fields[4]}"
    model_batch="${fields[5]}"
    model_threads="${fields[6]}"
    model_parallel="${fields[7]}"
    model_device="${fields[8]}"
    model_notes="${fields[9]}"

    stop_server
    backup_log
    start_server "$alias" "$model_path" "$model_extra" "$model_context" "$model_ngl" "$model_batch" "$model_threads" "$model_parallel" "$model_device" "$@"
}

restart_model() {
    local spec="${1:-}"
    local pid
    local model_path
    local alias

    if [[ -n "$spec" ]]; then
        switch_model "$@"
        return 0
    fi

    pid="$(find_pid)"
    [[ -n "$pid" ]] || die "no running server and no model specified"

    model_path="$(cmd_arg_from_pid "$pid" -m || true)"
    alias="$(lookup_alias_for_path "$model_path" || true)"
    [[ -n "$alias" ]] || alias="$model_path"

    switch_model "$alias"
}

show_logs() {
    local lines="${1:-40}"
    tail -n "$lines" "$LLAMA_SERVER_LOG"
}

parse_add_options() {
    local alias="$1"
    local model_path="$2"
    shift 2 || true
    local extra=""
    local context=""
    local ngl=""
    local batch=""
    local threads=""
    local parallel=""
    local device=""
    local notes=""
    ADD_FORCE_MMPROJ="0"

    while (($#)); do
        case "$1" in
            --mmproj)
                [[ $# -ge 2 ]] || die "--mmproj requires a path"
                extra="$(trim_whitespace "${extra} --mmproj $2")"
                shift 2
                ;;
            --force-mmproj)
                ADD_FORCE_MMPROJ="1"
                shift
                ;;
            --extra)
                [[ $# -ge 2 ]] || die "--extra requires a value"
                extra="$(trim_whitespace "${extra} $2")"
                shift 2
                ;;
            --context)
                [[ $# -ge 2 ]] || die "--context requires a value"
                context="$2"
                shift 2
                ;;
            --ngl)
                [[ $# -ge 2 ]] || die "--ngl requires a value"
                ngl="$2"
                shift 2
                ;;
            --batch)
                [[ $# -ge 2 ]] || die "--batch requires a value"
                batch="$2"
                shift 2
                ;;
            --threads)
                [[ $# -ge 2 ]] || die "--threads requires a value"
                threads="$2"
                shift 2
                ;;
            --parallel)
                [[ $# -ge 2 ]] || die "--parallel requires a value"
                parallel="$2"
                shift 2
                ;;
            --device)
                [[ $# -ge 2 ]] || die "--device requires a value"
                device="$2"
                shift 2
                ;;
            --notes)
                [[ $# -ge 2 ]] || die "--notes requires a value"
                notes="$2"
                shift 2
                ;;
            --)
                shift
                extra="$(trim_whitespace "${extra} $*")"
                break
                ;;
            *)
                die "unknown add option: $1"
                ;;
        esac
    done

    printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\n' \
        "$alias" "$model_path" "$extra" "$context" "$ngl" "$batch" "$threads" "$parallel" "$device" "$notes"
}

write_registry_line() {
    local alias="$1"
    local model_path="$2"
    local extra="$3"
    local context="$4"
    local ngl="$5"
    local batch="$6"
    local threads="$7"
    local parallel="$8"
    local device="$9"
    local notes="${10:-}"
    local -a fields=("$alias" "$model_path" "$extra" "$context" "$ngl" "$batch" "$threads" "$parallel" "$device" "$notes")

    while ((${#fields[@]} > 3)); do
        local last_index=$(( ${#fields[@]} - 1 ))
        if [[ -n "${fields[$last_index]}" ]]; then
            break
        fi
        unset 'fields[$last_index]'
    done

    local joined=""
    local field
    for field in "${fields[@]}"; do
        if [[ -n "$joined" ]]; then
            joined+=$'\t'
        fi
        joined+="$field"
    done
    printf '%s\n' "$joined"
}

add_model() {
    local alias="$1"
    local model_path="$2"
    shift 2 || true
    local parsed
    local extra
    local context
    local ngl
    local batch
    local threads
    local parallel
    local device
    local notes
    local tmp
    local existing_alias
    local raw_line
    local -a fields=()
    local line_alias
    local line_path
    local line_extra
    local line_context
    local line_ngl
    local line_batch
    local line_threads
    local line_parallel
    local line_device
    local line_notes
    local replaced=0

    alias="$(sanitize_alias "$alias")"
    [[ -n "$alias" ]] || die "alias resolved to empty value"

    model_path="$(canonicalize_path "$model_path")"
    [[ -f "$model_path" ]] || die "model not found: $model_path"

    ADD_FORCE_MMPROJ="0"
    for option in "$@"; do
        if [[ "$option" == "--force-mmproj" ]]; then
            ADD_FORCE_MMPROJ="1"
            break
        fi
    done
    parsed="$(parse_add_options "$alias" "$model_path" "$@")"
    mapfile -d '' -t fields < <(split_tsv_record "$parsed")
    existing_alias="${fields[0]}"
    model_path="${fields[1]}"
    extra="${fields[2]}"
    context="${fields[3]}"
    ngl="${fields[4]}"
    batch="${fields[5]}"
    threads="${fields[6]}"
    parallel="${fields[7]}"
    device="${fields[8]}"
    notes="${fields[9]}"

    validate_mmproj_for_model "$model_path" "$extra" "$ADD_FORCE_MMPROJ" "0"

    ensure_models_file
    tmp="$(mktemp)"

    while IFS= read -r raw_line || [[ -n "$raw_line" ]]; do
        if [[ -z "$raw_line" ]] || [[ "${raw_line:0:1}" == "#" ]]; then
            printf '%s\n' "$raw_line" >>"$tmp"
            continue
        fi

        mapfile -d '' -t fields < <(split_tsv_record "$raw_line")
        line_alias="${fields[0]}"
        line_path="${fields[1]}"
        line_extra="${fields[2]}"
        line_context="${fields[3]}"
        line_ngl="${fields[4]}"
        line_batch="${fields[5]}"
        line_threads="${fields[6]}"
        line_parallel="${fields[7]}"
        line_device="${fields[8]}"
        line_notes="${fields[9]}"
        if [[ "$line_alias" == "$alias" ]]; then
            write_registry_line "$alias" "$model_path" "$extra" "$context" "$ngl" "$batch" "$threads" "$parallel" "$device" "$notes" >>"$tmp"
            replaced=1
        else
            printf '%s\n' "$raw_line" >>"$tmp"
        fi
    done <"$MODELS_FILE"

    if [[ "$replaced" -eq 0 ]]; then
        write_registry_line "$alias" "$model_path" "$extra" "$context" "$ngl" "$batch" "$threads" "$parallel" "$device" "$notes" >>"$tmp"
    fi

    mv "$tmp" "$MODELS_FILE"
    if [[ "$replaced" -eq 1 ]]; then
        printf 'updated %s in %s\n' "$alias" "$MODELS_FILE"
    else
        printf 'added %s to %s\n' "$alias" "$MODELS_FILE"
    fi
}

remove_model() {
    local alias="$1"
    local tmp
    local found=0
    local line_alias
    local line

    ensure_models_file
    tmp="$(mktemp)"

    while IFS= read -r line || [[ -n "$line" ]]; do
        if [[ -z "$line" ]] || [[ "${line:0:1}" == "#" ]]; then
            printf '%s\n' "$line" >>"$tmp"
            continue
        fi

        line_alias="${line%%$'\t'*}"
        if [[ "$line_alias" == "$alias" ]]; then
            found=1
            continue
        fi
        printf '%s\n' "$line" >>"$tmp"
    done <"$MODELS_FILE"

    [[ "$found" -eq 1 ]] || die "unknown model alias: $alias"
    mv "$tmp" "$MODELS_FILE"
    printf 'removed %s from %s\n' "$alias" "$MODELS_FILE"
}

guess_mmproj_for_model() {
    local model_path="$1"
    local dir
    local mmproj

    dir="$(dirname "$model_path")"
    mmproj="$(find "$dir" -maxdepth 1 -type f -iname '*mmproj*.gguf' | sort | head -n 1 || true)"
    if [[ -n "$mmproj" ]]; then
        printf '%s\n' "$mmproj"
    fi
}

discover_models() {
    local root="${1:-$HOME/models}"
    local model_path
    local basename
    local alias
    local imported
    local mmproj
    local extra

    [[ -d "$root" ]] || die "discover root not found: $root"

    printf '%-10s %-24s %-8s %s\n' "IMPORTED" "ALIAS" "MMPROJ" "MODEL"
    while IFS= read -r -d '' model_path; do
        basename="$(basename "$model_path")"
        if [[ "${basename,,}" == *mmproj* ]]; then
            continue
        fi

        alias="$(sanitize_alias "$basename")"
        imported="no"
        if lookup_alias_for_path "$(canonicalize_path "$model_path")" >/dev/null 2>&1; then
            imported="yes"
        fi

        mmproj="$(guess_mmproj_for_model "$model_path" || true)"
        extra="no"
        if [[ -n "$mmproj" ]]; then
            extra="yes"
        fi

        printf '%-10s %-24s %-8s %s\n' "$imported" "$alias" "$extra" "$(canonicalize_path "$model_path")"
    done < <(find "$root" -type f -name '*.gguf' -print0 | sort -z)
}



require_python3() {
    command_available python3 || die "python3 is required for this integration command"
}

upstream_api_base() {
    printf 'http://%s:%s/v1\n' "$LLAMA_SERVER_HOST" "$LLAMA_SERVER_PORT"
}

lmm_gateway_api_base() {
    printf 'http://%s:%s/v1\n' "$LLAMA_MODEL_GATEWAY_HOST" "$LLAMA_MODEL_GATEWAY_PORT"
}

normalize_harness_mode() {
    local mode="${1:-$LLAMA_MODEL_HARNESS_MODE}"
    mode="$(trim_whitespace "$mode")"
    [[ -n "$mode" ]] || mode="routed"
    case "$mode" in
        routed|gateway) printf 'routed\n' ;;
        direct|backend|llamacpp) printf 'direct\n' ;;
        *) die "unsupported harness mode: $mode (expected routed or direct)" ;;
    esac
}

harness_api_base() {
    local mode
    mode="$(normalize_harness_mode "${1:-}")"
    if [[ "$mode" == "direct" ]]; then
        upstream_api_base
    else
        lmm_gateway_api_base
    fi
}

harness_route_label() {
    local mode
    local context_pipeline
    mode="$(normalize_harness_mode "${1:-}")"
    context_pipeline="${LLAMA_MODEL_CONTEXT_GLYPHOS_PIPELINE:-}"
    context_pipeline="${context_pipeline,,}"
    if [[ "$mode" == "direct" ]]; then
        printf 'direct\n'
    elif [[ "$context_pipeline" == "1" || "$context_pipeline" == "true" || "$context_pipeline" == "yes" || "$context_pipeline" == "on" ]]; then
        printf 'routed-full-capable\n'
    else
        printf 'routed-basic\n'
    fi
}

context_mcp_root() {
    if [[ -n "${CONTEXT_MODE_MCP_ROOT:-}" ]]; then
        printf '%s\n' "$CONTEXT_MODE_MCP_ROOT"
    else
        printf '%s\n' "$APP_ROOT/integrations/context-mode-mcp"
    fi
}

context_mcp_bridge_path() {
    printf '%s\n' "$APP_ROOT/scripts/context_mcp_bridge.py"
}

context_mcp_status() {
    local root
    local dist
    local bridge
    local status="bridge_ready"
    local guidance=""

    root="$(context_mcp_root)"
    dist="$root/dist/index.js"
    bridge="$(context_mcp_bridge_path)"

    if [[ ! -f "$root/package.json" ]]; then
        status="missing"
        guidance="Context Mode MCP package is missing; rerun the latest installer."
    elif [[ ! -f "$bridge" ]]; then
        status="missing_bridge"
        guidance="Context MCP bridge is missing; rerun the latest installer."
    elif [[ ! -f "$dist" ]]; then
        status="missing_dist"
        guidance="Run: llama-model context-mcp build, then llama-model gateway restart and restart llama-model-web."
    fi

    printf 'status: %s\n' "$status"
    printf 'root: %s\n' "$root"
    printf 'bridge: %s\n' "$bridge"
    printf 'dist: %s\n' "$dist"
    printf 'package_json: %s\n' "$([[ -f "$root/package.json" ]] && printf yes || printf no)"
    printf 'bridge_exists: %s\n' "$([[ -f "$bridge" ]] && printf yes || printf no)"
    printf 'dist_exists: %s\n' "$([[ -f "$dist" ]] && printf yes || printf no)"
    printf 'guidance: %s\n' "$guidance"
}

# npm_hardened_ci — supply-chain safe npm install wrapper.
#
#   npm_hardened_ci omit  — Context MCP server bundle (no optional deps needed)
#   npm_hardened_ci keep  — Next/Vite/dashboard/frontend builds (need optional
#                           platform packages like SWC binaries)
npm_hardened_ci() {
    local optional_mode="${1:-omit}"
    [[ -f package-lock.json ]] || die "package-lock.json is required; refusing unlocked npm install"
    case "$optional_mode" in
        omit) npm ci --omit=optional --ignore-scripts --no-audit --fund=false ;;
        keep) npm ci --ignore-scripts --no-audit --fund=false ;;
        *)    die "unknown npm optional mode: $optional_mode" ;;
    esac
}

context_mcp_build() {
    local root
    local dist

    root="$(context_mcp_root)"
    dist="$root/dist/index.js"
    [[ -f "$root/package.json" ]] || die "Context Mode MCP package not found: $root"
    command_available npm || die "npm is required to build Context Mode MCP; install npm or rerun the installer on a host with npm"
    [[ -f "$root/package-lock.json" ]] || die "Context Mode MCP package-lock.json is required; refusing unlocked npm install during supply-chain risk window"

    (
        cd "$root"
        npm_hardened_ci omit
        npm run build:mcp
    )

    [[ -f "$dist" ]] || die "Context Mode MCP build finished but dist/index.js is still missing: $dist"
    printf 'status: built\n'
    printf 'dist: %s\n' "$dist"
    printf 'restart_note: run llama-model gateway restart and restart llama-model-web so running processes load the rebuilt Context MCP bundle\n'
}

context_mcp_command() {
    local action="${1:-status}"
    shift || true
    case "$action" in
        status) context_mcp_status ;;
        build) context_mcp_build ;;
        *)
            printf '%s\n' 'Usage: llama-model context-mcp status|build'
            return 2
            ;;
    esac
}

update_check() {
    local component="all"
    local json_output="0"

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --component)
                shift
                [[ $# -gt 0 ]] || die "--component requires lmm, llamacpp, or all"
                component="$1"
                ;;
            --component=*)
                component="${1#--component=}"
                ;;
            --json)
                json_output="1"
                ;;
            *)
                die "unknown update-check option: $1"
                ;;
        esac
        shift
    done
    case "$component" in
        lmm|llamacpp|all) ;;
        *) die "--component must be lmm, llamacpp, or all" ;;
    esac

    LMM_UPDATE_COMPONENT="$component" \
    LMM_UPDATE_JSON="$json_output" \
    LMM_VERSION="${LMM_VERSION:-v2.1.0}" \
    LLAMA_CPP_REF="${LLAMA_CPP_REF:-$LLAMA_CPP_REF}" \
    APP_ROOT="$APP_ROOT" \
    STATE_DIR="$STATE_DIR" \
    python3 - <<'PY'
import json
import os
import sys
from pathlib import Path

app_root = Path(os.environ["APP_ROOT"])
sys.path.insert(0, str(app_root / "scripts"))

from lmm_config import load_lmm_config_from_env  # noqa: E402
from lmm_updates import UpdateChecker  # noqa: E402

component = os.environ.get("LMM_UPDATE_COMPONENT", "all")
json_output = os.environ.get("LMM_UPDATE_JSON") == "1"
config = load_lmm_config_from_env().update_watcher
checker = UpdateChecker(
    current_lmm_version=os.environ.get("LMM_VERSION", "v2.1.0"),
    lmm_repo=config.lmm_repo,
    llamacpp_repo=config.llamacpp_repo,
    timeout=config.timeout_seconds,
    state_file=config.state_file,
)

results = {}
if component in {"lmm", "all"}:
    results["lmm"] = checker.check_lmm_update().to_dict()
if component in {"llamacpp", "all"}:
    results["llamacpp"] = checker.check_llamacpp_update(os.environ.get("LLAMA_CPP_REF", "unknown")).to_dict()

if json_output:
    print(json.dumps(results, indent=2))
    raise SystemExit(0)

labels = {"lmm": "LMM", "llamacpp": "llama.cpp"}
for key in ("lmm", "llamacpp"):
    if key not in results:
        continue
    item = results[key]
    print(f"{labels[key]}:")
    print(f"  Current:  {item.get('current_version') or 'unknown'}")
    print(f"  Latest:   {item.get('latest_version') or 'unknown'}")
    print(f"  Update:   {'Available' if item.get('update_available') else 'Not available'}")
    if item.get("release_url"):
        print(f"  URL:      {item['release_url']}")
PY
}

ensure_lmm_gateway_for_routed_harness() {
    local mode="$1"
    local output=""
    [[ "$mode" == "routed" ]] || return 0
    if ! toggle_enabled "$LLAMA_MODEL_AUTOSTART_GATEWAY_ON_SYNC"; then
        HARNESS_GATEWAY_STATUS="autostart-disabled"
        return 0
    fi
    if lmm_gateway_health; then
        HARNESS_GATEWAY_STATUS="already-running"
        return 0
    fi
    if output="$(lmm_gateway_start 2>&1)"; then
        HARNESS_GATEWAY_STATUS="started"
        return 0
    fi
    printf '%s\n' "$output" >&2
    die "routed harness mode requires the LMM gateway, but it could not be started; run: llama-model gateway logs"
}

api_current_model_id() {
    local api_base

    api_base="$(upstream_api_base)"
    curl -fsS --max-time 2 "${api_base%/}/models" 2>/dev/null | python3 -c '
import json
import sys

try:
    payload = json.load(sys.stdin)
except Exception:
    raise SystemExit(1)

items = payload.get("data", []) if isinstance(payload, dict) else []
for item in items:
    if isinstance(item, dict) and item.get("id"):
        print(str(item["id"]))
        raise SystemExit(0)
raise SystemExit(1)
'
}

resolve_sync_target() {
    local spec="${1:-}"
    local resolved=""
    local pid=""
    local -a fields=()
    local alias=""
    local model_path=""
    local context=""
    local source=""

    if [[ -n "$spec" ]]; then
        resolved="$(resolve_model "$spec")"
        mapfile -d '' -t fields < <(split_tsv_record "$resolved")
        alias="${fields[0]}"
        model_path="${fields[1]}"
        context="${fields[3]}"
        source="explicit-target"
    else
        pid="$(find_pid)"
        if [[ -n "$pid" ]]; then
            model_path="$(cmd_arg_from_pid "$pid" -m || true)"
            if [[ -n "$model_path" ]]; then
                alias="$(lookup_alias_for_path "$model_path" || true)"
                [[ -n "$alias" ]] || alias="custom"
                source="running-server"
            else
                model_path="$(api_current_model_id || true)"
                [[ -n "$model_path" ]] || die "running llama-server on port $LLAMA_SERVER_PORT did not report a model path or OpenAI model id"
                alias="custom"
                source="running-api"
            fi
            context="$(cmd_arg_from_pid "$pid" -c || true)"
        elif read_state_file && [[ -n "${CURRENT_MODEL:-}" ]]; then
            model_path="$CURRENT_MODEL"
            alias="${CURRENT_ALIAS:-custom}"
            context="${CURRENT_CONTEXT:-}"
            source="saved-state"
        else
            die "no running server and no saved model state; start or switch a model first"
        fi
    fi

    [[ "$source" == "running-api" || -f "$model_path" ]] || die "model not found: $model_path"

    SYNC_TARGET_SOURCE="$source"
    SYNC_TARGET_ALIAS="$alias"
    if [[ "$source" == "running-api" ]]; then
        SYNC_TARGET_MODEL_PATH="$model_path"
    else
        SYNC_TARGET_MODEL_PATH="$(canonicalize_path "$model_path")"
    fi
    SYNC_TARGET_MODEL_NAME="$(basename "$SYNC_TARGET_MODEL_PATH")"
    if [[ -n "$alias" && "$alias" != "custom" ]]; then
        SYNC_TARGET_MODEL_ID="$alias"
    else
        SYNC_TARGET_MODEL_ID="$(sanitize_alias "$SYNC_TARGET_MODEL_PATH")"
    fi
    SYNC_TARGET_CONTEXT="${context:-$LLAMA_SERVER_CONTEXT}"
}

sync_glyphos() {
    [[ $# -le 1 ]] || die "sync-glyphos accepts at most one optional alias or path"
    local spec="${1:-}"
    local config_exists_before="no"
    local api_base
    local timeout_seconds

    resolve_sync_target "$spec"
    api_base="$(upstream_api_base)"
    timeout_seconds="$(trim_whitespace "${GLYPHOS_LLAMACPP_TIMEOUT_SECONDS:-3600}")"
    [[ "$timeout_seconds" =~ ^[0-9]+$ ]] || die "GLYPHOS_LLAMACPP_TIMEOUT_SECONDS must be a positive integer"
    (( timeout_seconds >= 1 )) || die "GLYPHOS_LLAMACPP_TIMEOUT_SECONDS must be at least 1"
    [[ -f "$GLYPHOS_CONFIG_FILE" ]] && config_exists_before="yes"

    require_python3
    python3 "$APP_ROOT/scripts/integration_sync.py" glyphos \
        --config-file "$GLYPHOS_CONFIG_FILE" \
        --model-name "$SYNC_TARGET_MODEL_NAME" \
        --api-base "$api_base" \
        --timeout-seconds "$timeout_seconds" || return $?

    printf 'status: synced\n'
    printf 'source: %s\n' "$SYNC_TARGET_SOURCE"
    printf 'alias: %s\n' "$SYNC_TARGET_ALIAS"
    printf 'model_path: %s\n' "$SYNC_TARGET_MODEL_PATH"
    printf 'glyphos_model: %s\n' "$SYNC_TARGET_MODEL_NAME"
    printf 'api_base: %s\n' "$api_base"
    printf 'config_file: %s\n' "$GLYPHOS_CONFIG_FILE"
    printf 'config_exists_before: %s\n' "$config_exists_before"
    printf 'routing_preference: llamacpp\n'
    printf 'timeout_seconds: %s\n' "$timeout_seconds"
}

resolve_openclaw_config_file() {
    local profile="${1:-}"
    if [[ -z "$profile" || "$profile" == "main" ]]; then
        printf '%s\n' "$HOME/.openclaw/openclaw.json"
    else
        printf '%s\n' "$HOME/.openclaw-${profile}/openclaw.json"
    fi
}

opencode_preset_values() {
    local preset="${1:-balanced}"
    case "$preset" in
        balanced)
            printf '1800000\t60000\n'
            ;;
        long-run|longrun)
            printf '7200000\t300000\n'
            ;;
        *)
            die "unsupported opencode preset: $preset (expected balanced or long-run)"
            ;;
    esac
}

opencode_compaction_reserved() {
    local preset="$1"
    local context_window="${2:-0}"
    local override="${OPENCODE_COMPACTION_RESERVED:-}"

    if [[ -n "$override" ]]; then
        [[ "$override" =~ ^[0-9]+$ ]] || die "OPENCODE_COMPACTION_RESERVED must be a positive integer"
        (( override >= 1024 )) || die "OPENCODE_COMPACTION_RESERVED must be at least 1024"
        printf '%s\n' "$override"
        return 0
    fi

    [[ "$context_window" =~ ^[0-9]+$ ]] || context_window=0
    if [[ "$preset" == "long-run" || "$preset" == "longrun" ]]; then
        if (( context_window >= 128000 )); then
            printf '64000\n'
        elif (( context_window >= 65536 )); then
            printf '32768\n'
        elif (( context_window >= 32768 )); then
            printf '16384\n'
        elif (( context_window > 0 )); then
            printf '%s\n' "$(( context_window / 4 > 4096 ? context_window / 4 : 4096 ))"
        else
            printf '64000\n'
        fi
    else
        if (( context_window >= 128000 )); then
            printf '32768\n'
        elif (( context_window >= 65536 )); then
            printf '16384\n'
        elif (( context_window >= 32768 )); then
            printf '8192\n'
        elif (( context_window > 0 )); then
            printf '%s\n' "$(( context_window / 8 > 4096 ? context_window / 8 : 4096 ))"
        else
            printf '16384\n'
        fi
    fi
}

sync_opencode() {
    local preset="balanced"
    local mode="$LLAMA_MODEL_HARNESS_MODE"
    local spec=""
    local config_exists_before="no"
    local state_exists_before="no"
    local api_base
    local timeout_ms
    local chunk_timeout_ms
    local compaction_reserved
    local context_window
    local runtime_note=""
    local HARNESS_GATEWAY_STATUS="not-required"

    while (($#)); do
        case "$1" in
            --mode)
                [[ $# -ge 2 ]] || die "--mode requires routed or direct"
                mode="$2"
                shift 2
                ;;
            --preset)
                [[ $# -ge 2 ]] || die "--preset requires balanced or long-run"
                preset="$2"
                shift 2
                ;;
            *)
                [[ -z "$spec" ]] || die "sync-opencode accepts at most one optional alias or path"
                spec="$1"
                shift
                ;;
        esac
    done

    IFS=$'\t' read -r timeout_ms chunk_timeout_ms <<<"$(opencode_preset_values "$preset")"
    mode="$(normalize_harness_mode "$mode")"

    resolve_sync_target "$spec"
    ensure_lmm_gateway_for_routed_harness "$mode"
    api_base="$(harness_api_base "$mode")"
    context_window="${SYNC_TARGET_CONTEXT:-$LLAMA_SERVER_CONTEXT}"
    [[ "$context_window" =~ ^[0-9]+$ ]] || context_window="$LLAMA_SERVER_CONTEXT"
    [[ "$context_window" =~ ^[0-9]+$ ]] || context_window=0
    compaction_reserved="$(opencode_compaction_reserved "$preset" "$context_window")"
    [[ -f "$OPENCODE_CONFIG_FILE" ]] && config_exists_before="yes"
    [[ -f "$OPENCODE_MODEL_STATE_FILE" ]] && state_exists_before="yes"
    if [[ "$preset" == "long-run" && "$(configured_mode_name)" != "single-client" ]]; then
        runtime_note="single-client recommended for long local reasoning sessions"
    fi
    require_python3
    python3 "$APP_ROOT/scripts/integration_sync.py" opencode \
        --config-file "$OPENCODE_CONFIG_FILE" \
        --state-file "$OPENCODE_MODEL_STATE_FILE" \
        --model-name "$SYNC_TARGET_MODEL_NAME" \
        --display-name "$SYNC_TARGET_MODEL_NAME" \
        --api-base "$api_base" \
        --timeout-ms "$timeout_ms" \
        --chunk-timeout-ms "$chunk_timeout_ms" \
        --compaction-reserved "$compaction_reserved" \
        --context-window "$context_window" \
        --preset "$preset" \
        --route-mode "$mode" || return $?

    printf 'status: synced\n'
    printf 'preset: %s\n' "$preset"
    printf 'source: %s\n' "$SYNC_TARGET_SOURCE"
    printf 'alias: %s\n' "$SYNC_TARGET_ALIAS"
    printf 'model_path: %s\n' "$SYNC_TARGET_MODEL_PATH"
    printf 'opencode_model: llamacpp/%s\n' "$SYNC_TARGET_MODEL_NAME"
    printf 'route_mode: %s\n' "$mode"
    printf 'route_label: %s\n' "$(harness_route_label "$mode")"
    printf 'api_base: %s\n' "$api_base"
    printf 'backend_api_base: %s\n' "$(upstream_api_base)"
    printf 'gateway_api_base: %s\n' "$(lmm_gateway_api_base)"
    printf 'gateway_status: %s\n' "$HARNESS_GATEWAY_STATUS"
    printf 'timeout_ms: %s\n' "$timeout_ms"
    printf 'chunk_timeout_ms: %s\n' "$chunk_timeout_ms"
    printf 'compaction_reserved: %s\n' "$compaction_reserved"
    printf 'context_window: %s\n' "$context_window"
    printf 'timeout_source_note: provider timeout is configured here; observed 1800s message/session timeout must be surfaced by opencode runtime\n'
    printf 'runtime_note: %s\n' "$runtime_note"
    printf 'config_file: %s\n' "$OPENCODE_CONFIG_FILE"
    printf 'config_exists_before: %s\n' "$config_exists_before"
    printf 'state_file: %s\n' "$OPENCODE_MODEL_STATE_FILE"
    printf 'state_exists_before: %s\n' "$state_exists_before"
}

sync_openclaw() {
    local profile="$OPENCLAW_PROFILE"
    local mode="$LLAMA_MODEL_HARNESS_MODE"
    local spec=""
    local config_file
    local profile_label
    local config_exists_before="no"
    local api_base
    local api_key
    local context_window
    local max_tokens="4096"
    local workspace
    local HARNESS_GATEWAY_STATUS="not-required"

    while (($#)); do
        case "$1" in
            --mode)
                [[ $# -ge 2 ]] || die "--mode requires routed or direct"
                mode="$2"
                shift 2
                ;;
            --profile)
                [[ $# -ge 2 ]] || die "--profile requires a name"
                profile="$2"
                shift 2
                ;;
            *)
                [[ -z "$spec" ]] || die "sync-openclaw accepts at most one alias or path"
                spec="$1"
                shift
                ;;
        esac
    done

    resolve_sync_target "$spec"
    mode="$(normalize_harness_mode "$mode")"
    ensure_lmm_gateway_for_routed_harness "$mode"
    api_base="$(harness_api_base "$mode")"
    api_key="$(trim_whitespace "${OPENCLAW_API_KEY:-llama-local}")"
    [[ -n "$api_key" ]] || api_key="llama-local"
    context_window="${SYNC_TARGET_CONTEXT:-$LLAMA_SERVER_CONTEXT}"
    [[ "$context_window" =~ ^[0-9]+$ ]] || context_window="$LLAMA_SERVER_CONTEXT"
    profile_label="${profile:-main}"
    config_file="$(resolve_openclaw_config_file "$profile")"
    [[ -f "$config_file" ]] && config_exists_before="yes"

    require_python3
    workspace="$(python3 "$APP_ROOT/scripts/integration_sync.py" openclaw \
        --config-file "$config_file" \
        --model-id "$SYNC_TARGET_MODEL_ID" \
        --display-name "$SYNC_TARGET_MODEL_NAME" \
        --alias "$SYNC_TARGET_ALIAS" \
        --api-base "$api_base" \
        --api-key "$api_key" \
        --context-window "$context_window" \
        --max-tokens "$max_tokens")" || return $?

    printf 'status: synced\n'
    printf 'source: %s\n' "$SYNC_TARGET_SOURCE"
    printf 'profile: %s\n' "$profile_label"
    printf 'alias: %s\n' "$SYNC_TARGET_ALIAS"
    printf 'model_path: %s\n' "$SYNC_TARGET_MODEL_PATH"
    printf 'openclaw_model: llamacpp/%s\n' "$SYNC_TARGET_MODEL_ID"
    printf 'route_mode: %s\n' "$mode"
    printf 'route_label: %s\n' "$(harness_route_label "$mode")"
    printf 'api_base: %s\n' "$api_base"
    printf 'backend_api_base: %s\n' "$(upstream_api_base)"
    printf 'gateway_api_base: %s\n' "$(lmm_gateway_api_base)"
    printf 'gateway_status: %s\n' "$HARNESS_GATEWAY_STATUS"
    printf 'workspace: %s\n' "$workspace"
    printf 'config_file: %s\n' "$config_file"
    printf 'config_exists_before: %s\n' "$config_exists_before"
}

post_switch_sync_warning() {
    local client="$1"
    local detail="$2"
    detail="$(printf '%s' "$detail" | tr '\n' ' ' | sed 's/[[:space:]][[:space:]]*/ /g' | cut -c 1-240)"
    printf 'warn_%s_sync: %s\n' "$client" "$detail"
}

post_switch_run_sync() {
    local client="$1"
    shift
    local output
    local synced_value=""

    if output="$("$@" 2>&1)"; then
        case "$client" in
            opencode)
                synced_value="$(printf '%s\n' "$output" | awk -F': ' '/^opencode_model: / { print $2; exit }')"
                printf 'synced_opencode_model: %s\n' "${synced_value:-unknown}"
                printf 'opencode_reload_note: restart or reload OpenCode to pick up config changes\n'
                ;;
            claude)
                synced_value="$(printf '%s\n' "$output" | awk -F': ' '/^model_id: / { print $2; exit }')"
                printf 'synced_claude_model: %s\n' "${synced_value:-unknown}"
                printf 'claude_reload_note: restart Claude Code and restart the local Claude gateway if it was already running\n'
                ;;
            openclaw)
                synced_value="$(printf '%s\n' "$output" | awk -F': ' '/^openclaw_model: / { print $2; exit }')"
                printf 'synced_openclaw_model: %s\n' "${synced_value:-unknown}"
                printf 'openclaw_reload_note: restart or reload OpenClaw to pick up config changes\n'
                ;;
            glyphos)
                synced_value="$(printf '%s\n' "$output" | awk -F': ' '/^glyphos_model: / { print $2; exit }')"
                printf 'synced_glyphos_model: %s\n' "${synced_value:-unknown}"
                ;;
        esac
    else
        post_switch_sync_warning "$client" "$output"
    fi
}

post_switch_client_sync() {
    local alias="${1:-}"
    local model_path="${2:-}"
    local context="${3:-}"

    : "$alias" "$model_path" "$context"

    if toggle_enabled "$LLAMA_MODEL_SYNC_OPENCODE"; then
        post_switch_run_sync opencode sync_opencode --preset balanced
    else
        printf 'skipped_opencode_sync: disabled\n'
    fi

    if toggle_enabled "$LLAMA_MODEL_SYNC_CLAUDE"; then
        post_switch_run_sync claude sync_claude
    else
        printf 'skipped_claude_sync: disabled\n'
    fi

    if toggle_enabled "$LLAMA_MODEL_SYNC_OPENCLAW"; then
        post_switch_run_sync openclaw sync_openclaw
    else
        printf 'skipped_openclaw_sync: disabled\n'
    fi

    if toggle_enabled "$LLAMA_MODEL_SYNC_GLYPHOS"; then
        post_switch_run_sync glyphos sync_glyphos
    else
        printf 'skipped_glyphos_sync: disabled\n'
    fi
}

sync_claude() {
    [[ $# -le 1 ]] || die "sync-claude accepts at most one optional model id"
    local model_id="$(trim_whitespace "${1:-}")"
    local base_url
    local auth_token
    local api_key
    local api_key_source="unchanged"
    local settings_exists_before="no"

    if [[ -z "$model_id" ]]; then
        model_id="$(trim_whitespace "${CLAUDE_MODEL_ID:-}")"
    fi
    if [[ -z "$model_id" ]]; then
        resolve_sync_target ""
        model_id="$SYNC_TARGET_MODEL_ID"
    fi

    base_url="$(trim_whitespace "${CLAUDE_BASE_URL:-}")"
    if [[ -z "$base_url" ]]; then
        base_url="http://${CLAUDE_GATEWAY_HOST}:${CLAUDE_GATEWAY_PORT}"
    fi
    auth_token="$(trim_whitespace "${CLAUDE_AUTH_TOKEN:-${ANTHROPIC_AUTH_TOKEN:-}}")"
    api_key="$(trim_whitespace "${CLAUDE_API_KEY:-${ANTHROPIC_API_KEY:-}}")"
    if [[ -z "$api_key" && -n "$auth_token" ]]; then
        api_key="$auth_token"
        api_key_source="mirrored-from-auth-token"
    elif [[ -n "$api_key" ]]; then
        api_key_source="configured"
    fi
    [[ -f "$CLAUDE_SETTINGS_FILE" ]] && settings_exists_before="yes"

    require_python3
    python3 "$APP_ROOT/scripts/integration_sync.py" claude \
        --settings-file "$CLAUDE_SETTINGS_FILE" \
        --model-id "$model_id" \
        --base-url "$base_url" \
        --auth-token "$auth_token" \
        --api-key "$api_key" || return $?

    printf 'status: synced\n'
    printf 'model_id: %s\n' "$model_id"
    printf 'base_url: %s\n' "$base_url"
    printf 'settings_file: %s\n' "$CLAUDE_SETTINGS_FILE"
    printf 'settings_exists_before: %s\n' "$settings_exists_before"
    printf 'claude_auth: %s\n' "$([[ -n "$auth_token" ]] && printf configured || printf unchanged)"
    printf 'claude_api_key: %s\n' "$api_key_source"
}

lmm_gateway_script() {
    local script="$APP_ROOT/scripts/glyphos_openai_gateway.py"
    [[ -f "$script" ]] || die "LMM gateway script not found: $script"
    printf '%s\n' "$script"
}

lmm_gateway_model_id() {
    local model_id
    if model_id="$(api_current_model_id 2>/dev/null)" && [[ -n "$model_id" ]]; then
        printf '%s\n' "$model_id"
        return 0
    fi
    if [[ -n "${SYNC_TARGET_MODEL_ID:-}" ]]; then
        printf '%s\n' "$SYNC_TARGET_MODEL_ID"
        return 0
    fi
    resolve_sync_target ""
    printf '%s\n' "$SYNC_TARGET_MODEL_ID"
}

lmm_gateway_pid() {
    if [[ -f "$LLAMA_MODEL_GATEWAY_PID_FILE" ]]; then
        cat "$LLAMA_MODEL_GATEWAY_PID_FILE"
    fi
}

lmm_gateway_running() {
    local pid
    pid="$(lmm_gateway_pid 2>/dev/null || true)"
    [[ -n "$pid" && "$pid" =~ ^[0-9]+$ ]] || return 1
    kill -0 "$pid" >/dev/null 2>&1
}

lmm_gateway_health() {
    curl -fsS --max-time 2 "http://${LLAMA_MODEL_GATEWAY_HOST}:${LLAMA_MODEL_GATEWAY_PORT}/healthz" >/dev/null 2>&1
}

lmm_gateway_wait_for_health() {
    local pid="$1"
    local attempts="${2:-30}"
    local i
    for ((i = 0; i < attempts; i++)); do
        if lmm_gateway_health; then
            return 0
        fi
        if ! kill -0 "$pid" >/dev/null 2>&1; then
            return 1
        fi
        sleep 0.1
    done
    return 1
}

lmm_gateway_start() {
    local script
    local model_id
    local pid
    if lmm_gateway_running && lmm_gateway_health; then
        printf 'running: yes\n'
        printf 'pid: %s\n' "$(lmm_gateway_pid)"
        printf 'url: %s\n' "$(lmm_gateway_api_base)"
        printf 'message: LMM gateway already running\n'
        return 0
    fi
    require_python3
    script="$(lmm_gateway_script)"
    model_id="$(lmm_gateway_model_id)"
    mkdir -p "$(dirname "$LLAMA_MODEL_GATEWAY_LOG")" "$(dirname "$LLAMA_MODEL_GATEWAY_PID_FILE")"
    : >"$LLAMA_MODEL_GATEWAY_LOG"
    GLYPHOS_CONFIG_FILE="$GLYPHOS_CONFIG_FILE" \
    GLYPHOS_LLAMACPP_URL="$(upstream_api_base)" \
    GLYPHOS_LLAMACPP_MODEL="$model_id" \
    GLYPHOS_LLAMACPP_TIMEOUT="$GLYPHOS_LLAMACPP_TIMEOUT_SECONDS" \
    LLAMA_MODEL_CONTEXT_GLYPHOS_PIPELINE="${LLAMA_MODEL_CONTEXT_GLYPHOS_PIPELINE:-}" \
    LLAMA_MODEL_GLYPHOS_TELEMETRY_FILE="${LLAMA_MODEL_GLYPHOS_TELEMETRY_FILE:-$STATE_DIR/glyphos-routing.json}" \
    LMM_GATEWAY_STATE_FILE="${LMM_GATEWAY_STATE_FILE:-$STATE_DIR/lmm-gateway-requests.json}" \
    setsid python3 "$script" \
        --host "$LLAMA_MODEL_GATEWAY_HOST" \
        --port "$LLAMA_MODEL_GATEWAY_PORT" \
        --backend-base-url "$(upstream_api_base)" \
        --model-id "$model_id" \
        >>"$LLAMA_MODEL_GATEWAY_LOG" 2>&1 &
    pid="$!"
    printf '%s\n' "$pid" >"$LLAMA_MODEL_GATEWAY_PID_FILE"
    if lmm_gateway_wait_for_health "$pid" 40; then
        printf 'running: yes\n'
        printf 'pid: %s\n' "$(lmm_gateway_pid)"
        printf 'url: %s\n' "$(lmm_gateway_api_base)"
        printf 'backend_api_base: %s\n' "$(upstream_api_base)"
        printf 'model_id: %s\n' "$model_id"
        printf 'log: %s\n' "$LLAMA_MODEL_GATEWAY_LOG"
    else
        rm -f "$LLAMA_MODEL_GATEWAY_PID_FILE"
        if kill -0 "$pid" >/dev/null 2>&1; then
            kill "$pid" >/dev/null 2>&1 || true
        fi
        printf 'running: no\n'
        printf 'url: %s\n' "$(lmm_gateway_api_base)"
        printf 'error: LMM gateway failed health check after startup\n'
        printf 'log: %s\n' "$LLAMA_MODEL_GATEWAY_LOG"
        tail -n 20 "$LLAMA_MODEL_GATEWAY_LOG" 2>/dev/null || true
        return 1
    fi
}

lmm_gateway_stop() {
    local pid
    pid="$(lmm_gateway_pid 2>/dev/null || true)"
    if [[ -n "$pid" && "$pid" =~ ^[0-9]+$ ]] && kill -0 "$pid" >/dev/null 2>&1; then
        kill "$pid" >/dev/null 2>&1 || true
    fi
    rm -f "$LLAMA_MODEL_GATEWAY_PID_FILE"
    printf 'stopped LMM gateway on port %s\n' "$LLAMA_MODEL_GATEWAY_PORT"
}

lmm_gateway_status() {
    local running="no"
    local health="no"
    if lmm_gateway_running; then
        running="yes"
    fi
    if lmm_gateway_health; then
        health="yes"
    fi
    printf 'running: %s\n' "$running"
    printf 'health: %s\n' "$health"
    printf 'pid: %s\n' "$(lmm_gateway_pid 2>/dev/null || true)"
    printf 'url: %s\n' "$(lmm_gateway_api_base)"
    printf 'backend_api_base: %s\n' "$(upstream_api_base)"
    printf 'mode_default: %s\n' "$(normalize_harness_mode "$LLAMA_MODEL_HARNESS_MODE")"
    printf 'log: %s\n' "$LLAMA_MODEL_GATEWAY_LOG"
}

lmm_gateway_logs() {
    local lines="${1:-100}"
    [[ -f "$LLAMA_MODEL_GATEWAY_LOG" ]] || die "LMM gateway log not found: $LLAMA_MODEL_GATEWAY_LOG"
    tail -n "$lines" "$LLAMA_MODEL_GATEWAY_LOG"
}

lmm_gateway_command() {
    local action="${1:-status}"
    shift || true
    case "$action" in
        start) lmm_gateway_start ;;
        stop) lmm_gateway_stop ;;
        restart) lmm_gateway_stop; lmm_gateway_start ;;
        status) lmm_gateway_status ;;
        logs) lmm_gateway_logs "$@" ;;
        help|-h|--help)
            printf '%s\n' 'Usage: llama-model gateway start|stop|restart|status|logs'
            ;;
        *) die "unknown gateway action: $action" ;;
    esac
}

claude_gateway_script() {
    local script="$APP_ROOT/scripts/claude_gateway.py"
    [[ -f "$script" ]] || die "Claude gateway script not found: $script"
    printf '%s\n' "$script"
}

claude_gateway_model_id() {
    local model_id
    model_id="$(trim_whitespace "${CLAUDE_MODEL_ID:-}")"
    if [[ -n "$model_id" ]]; then
        printf '%s\n' "$model_id"
        return 0
    fi
    resolve_sync_target ""
    printf '%s\n' "$SYNC_TARGET_MODEL_ID"
}

claude_gateway_url() {
    printf 'http://%s:%s\n' "$CLAUDE_GATEWAY_HOST" "$CLAUDE_GATEWAY_PORT"
}

claude_gateway_upstream_base() {
    upstream_api_base
}

claude_gateway_timeout_seconds() {
    local upstream_timeout_seconds
    upstream_timeout_seconds="$(trim_whitespace "${CLAUDE_GATEWAY_UPSTREAM_TIMEOUT_SECONDS:-1800}")"
    [[ "$upstream_timeout_seconds" =~ ^[0-9]+$ ]] || die "CLAUDE_GATEWAY_UPSTREAM_TIMEOUT_SECONDS must be a positive integer"
    (( upstream_timeout_seconds >= 1 )) || die "CLAUDE_GATEWAY_UPSTREAM_TIMEOUT_SECONDS must be at least 1"
    printf '%s
' "$upstream_timeout_seconds"
}

claude_gateway_pid() {
    [[ -f "$CLAUDE_GATEWAY_PID_FILE" ]] || return 1
    cat "$CLAUDE_GATEWAY_PID_FILE"
}

claude_gateway_listener_pid() {
    local pid=""

    if command_available lsof; then
        pid="$(lsof -tiTCP:"$CLAUDE_GATEWAY_PORT" -sTCP:LISTEN 2>/dev/null | head -n 1 || true)"
        [[ -n "$pid" ]] && { printf '%s\n' "$pid"; return 0; }
    fi

    if command_available ss; then
        pid="$(ss -ltnp "( sport = :$CLAUDE_GATEWAY_PORT )" 2>/dev/null | sed -n 's/.*pid=\([0-9]\+\).*/\1/p' | head -n 1 || true)"
        [[ -n "$pid" ]] && { printf '%s\n' "$pid"; return 0; }
    fi

    pid="$(pgrep -af 'claude_gateway.py' 2>/dev/null | awk -v port="$CLAUDE_GATEWAY_PORT" '$0 ~ ("--port " port "([[:space:]]|$)") { print $1; exit }' || true)"
    [[ -n "$pid" ]] && printf '%s\n' "$pid"
}

pid_matches_claude_gateway() {
    local pid="$1"
    local cmdline

    cmdline="$(pid_command_line "$pid")"
    [[ -n "$cmdline" ]] || return 1
    [[ "$cmdline" == *claude_gateway.py* ]] || return 1
    [[ "$cmdline" == *"--port ${CLAUDE_GATEWAY_PORT}"* ]] || return 1
    return 0
}

claude_gateway_health_ok() {
    curl -fsS "$(claude_gateway_url)/healthz" >/dev/null 2>&1
}

claude_gateway_detect_pid() {
    local pid=""

    pid="$(claude_gateway_pid 2>/dev/null || true)"
    if [[ -n "$pid" ]] && kill -0 "$pid" 2>/dev/null && pid_matches_claude_gateway "$pid"; then
        printf '%s\n' "$pid"
        return 0
    fi

    pid="$(claude_gateway_listener_pid 2>/dev/null || true)"
    if [[ -n "$pid" ]] && kill -0 "$pid" 2>/dev/null && pid_matches_claude_gateway "$pid"; then
        printf '%s\n' "$pid"
        return 0
    fi

    return 1
}

claude_gateway_running() {
    claude_gateway_health_ok
}

claude_gateway_wait_ready() {
    local pid="$1"
    local url="$(claude_gateway_url)/healthz"
    local waited

    for waited in $(seq 1 30); do
        if curl -fsS "$url" >/dev/null 2>&1; then
            return 0
        fi
        if ! kill -0 "$pid" 2>/dev/null; then
            tail -n 60 "$CLAUDE_GATEWAY_LOG" >&2 || true
            die "claude gateway exited during startup"
        fi
        sleep 1
    done
    tail -n 60 "$CLAUDE_GATEWAY_LOG" >&2 || true
    die "timed out waiting for $(claude_gateway_url)/healthz"
}

claude_gateway_start() {
    local script
    local pid=""
    local listener_pid=""
    local model_id=""
    local upstream_base
    local upstream_timeout_seconds
    local -a cmd=()
    require_python3
    script="$(claude_gateway_script)"
    upstream_base="$(claude_gateway_upstream_base)"
    upstream_timeout_seconds="$(claude_gateway_timeout_seconds)"
    model_id="$(claude_gateway_model_id 2>/dev/null || true)"
    mkdir -p "$(dirname "$CLAUDE_GATEWAY_LOG")" "$(dirname "$CLAUDE_GATEWAY_PID_FILE")"

    listener_pid="$(claude_gateway_listener_pid 2>/dev/null || true)"
    if claude_gateway_health_ok; then
        pid="$listener_pid"
        if [[ -z "$pid" ]]; then
            pid="$(claude_gateway_pid 2>/dev/null || true)"
        fi
        if [[ -n "$pid" ]]; then
            printf '%s\n' "$pid" > "$CLAUDE_GATEWAY_PID_FILE"
        fi
        printf 'status: running\n'
        printf 'pid: %s\n' "$pid"
        printf 'url: %s\n' "$(claude_gateway_url)"
        printf 'upstream_base: %s\n' "$upstream_base"
        printf 'model_id: %s\n' "$model_id"
        printf 'log: %s\n' "$CLAUDE_GATEWAY_LOG"
        return 0
    fi

    if [[ -n "$listener_pid" ]] && ! pid_matches_claude_gateway "$listener_pid"; then
        die "port ${CLAUDE_GATEWAY_PORT} is already occupied by another process"
    fi

    cmd=(python3 "$script" --host "$CLAUDE_GATEWAY_HOST" --port "$CLAUDE_GATEWAY_PORT" --upstream-base "$upstream_base" --upstream-timeout-seconds "$upstream_timeout_seconds")
    if [[ -n "$model_id" ]]; then
        cmd+=(--advertised-model-id "$model_id")
    fi

    setsid "${cmd[@]}" >"$CLAUDE_GATEWAY_LOG" 2>&1 < /dev/null &
    pid=$!
    disown "$pid" 2>/dev/null || true
    printf '%s\n' "$pid" > "$CLAUDE_GATEWAY_PID_FILE"
    claude_gateway_wait_ready "$pid"

    printf 'status: running\n'
    printf 'pid: %s\n' "$pid"
    printf 'url: %s\n' "$(claude_gateway_url)"
    printf 'upstream_base: %s\n' "$upstream_base"
    printf 'model_id: %s\n' "$model_id"
    printf 'log: %s\n' "$CLAUDE_GATEWAY_LOG"
}

claude_gateway_stop() {
    local pid
    pid="$(claude_gateway_detect_pid 2>/dev/null || true)"
    if [[ -z "$pid" ]]; then
        pid="$(claude_gateway_listener_pid 2>/dev/null || true)"
    fi
    if [[ -z "$pid" ]]; then
        rm -f "$CLAUDE_GATEWAY_PID_FILE"
        printf 'status: stopped\n'
        return 0
    fi
    kill -TERM "$pid" 2>/dev/null || true
    for _ in $(seq 1 15); do
        if ! kill -0 "$pid" 2>/dev/null; then
            rm -f "$CLAUDE_GATEWAY_PID_FILE"
            printf 'status: stopped\n'
            return 0
        fi
        sleep 1
    done
    die "claude gateway pid $pid did not stop"
}

claude_gateway_restart() {
    claude_gateway_stop >/dev/null 2>&1 || true
    claude_gateway_start
}

claude_gateway_status() {
    local running="no"
    local pid=""
    local model_id="$(claude_gateway_model_id 2>/dev/null || true)"
    local upstream_timeout_seconds="$(claude_gateway_timeout_seconds)"
    pid="$(claude_gateway_detect_pid 2>/dev/null || true)"
    if [[ -z "$pid" ]]; then
        pid="$(claude_gateway_listener_pid 2>/dev/null || true)"
    fi
    if claude_gateway_health_ok; then
        running="yes"
        if [[ -n "$pid" ]]; then
            printf '%s\n' "$pid" > "$CLAUDE_GATEWAY_PID_FILE"
        fi
    fi
    printf 'running: %s\n' "$running"
    printf 'pid: %s\n' "$pid"
    printf 'url: %s\n' "$(claude_gateway_url)"
    printf 'upstream_base: %s\n' "$(claude_gateway_upstream_base)"
    printf 'upstream_timeout_seconds: %s\n' "$upstream_timeout_seconds"
    printf 'model_id: %s\n' "$model_id"
    printf 'log: %s\n' "$CLAUDE_GATEWAY_LOG"
}

claude_gateway_logs() {
    local lines="${1:-100}"
    tail -n "$lines" "$CLAUDE_GATEWAY_LOG"
}

claude_gateway_command() {
    local action="${1:-status}"
    shift || true
    case "$action" in
        start) claude_gateway_start ;;
        stop) claude_gateway_stop ;;
        restart) claude_gateway_restart ;;
        status) claude_gateway_status ;;
        logs) claude_gateway_logs "$@" ;;
        help|-h|--help)
            printf '%s\n' 'Usage: llama-model claude-gateway start|stop|restart|status|logs'
            ;;
        *) die "unknown claude-gateway action: $action" ;;
    esac
}

dashboard_systemctl_available() {
    if [[ -n "${LLAMA_MODEL_SYSTEMCTL_BIN:-}" ]]; then
        [[ -x "$LLAMA_MODEL_SYSTEMCTL_BIN" ]]
        return $?
    fi
    command_available systemctl
}

dashboard_systemctl() {
    if [[ -n "${LLAMA_MODEL_SYSTEMCTL_BIN:-}" ]]; then
        "$LLAMA_MODEL_SYSTEMCTL_BIN" --user "$@"
    else
        systemctl --user "$@"
    fi
}

dashboard_journalctl_available() {
    if [[ -n "${LLAMA_MODEL_JOURNALCTL_BIN:-}" ]]; then
        [[ -x "$LLAMA_MODEL_JOURNALCTL_BIN" ]]
        return $?
    fi
    command_available journalctl
}

dashboard_journalctl() {
    if [[ -n "${LLAMA_MODEL_JOURNALCTL_BIN:-}" ]]; then
        "$LLAMA_MODEL_JOURNALCTL_BIN" "$@"
    else
        journalctl "$@"
    fi
}

dashboard_service_dir_writable() {
    local target="$DASHBOARD_SERVICE_UNIT_DIR"

    while [[ ! -e "$target" ]]; do
        target="$(dirname "$target")"
    done

    [[ -d "$target" && -w "$target" ]]
}

dashboard_service_manager_reachable() {
    dashboard_systemctl_available || return 1
    dashboard_systemctl show-environment >/dev/null 2>&1
}

dashboard_service_installed() {
    [[ -f "$DASHBOARD_SERVICE_UNIT_FILE" ]]
}

dashboard_service_enabled() {
    dashboard_service_installed && dashboard_service_manager_reachable && dashboard_systemctl is-enabled "$DASHBOARD_SERVICE_NAME" >/dev/null 2>&1
}

dashboard_service_active() {
    dashboard_service_installed && dashboard_service_manager_reachable && dashboard_systemctl is-active "$DASHBOARD_SERVICE_NAME" >/dev/null 2>&1
}

dashboard_service_unit_text() {
    cat <<EOF
[Unit]
Description=LLM Model Manager Dashboard
After=default.target

[Service]
Type=simple
ExecStart=%h/.local/bin/llama-model-web --no-browser --require-bind --host ${DASHBOARD_SERVICE_HOST} --port ${DASHBOARD_SERVICE_PORT}
Environment=LLAMA_MODEL_WEB_SERVICE=1
Restart=on-failure
RestartSec=3

[Install]
WantedBy=default.target
EOF
}

dashboard_service_status() {
    local supported="no"
    local manager_reachable="no"
    local installable="no"
    local installed="no"
    local enabled="no"
    local active="no"
    local logs_available="no"
    local status="unavailable"
    local message="Background dashboard service is available only on systems with systemd user services."

    if dashboard_systemctl_available; then
        supported="yes"
        if dashboard_journalctl_available; then
            logs_available="yes"
        fi
        if dashboard_service_dir_writable; then
            installable="yes"
        fi
        if dashboard_service_manager_reachable; then
            manager_reachable="yes"
            message="The dashboard normally runs on demand and does not stay resident. Install the optional background service only if you want it available at all times."
        else
            message="systemd user services are installed but the user service manager is not reachable in this session."
        fi
        if dashboard_service_installed; then
            installed="yes"
        fi
        if [[ "$manager_reachable" == "yes" ]]; then
            if dashboard_service_enabled; then
                enabled="yes"
            fi
            if dashboard_service_active; then
                active="yes"
            fi
        fi
        if [[ "$installed" == "yes" ]]; then
            if [[ "$active" == "yes" ]]; then
                status="running"
                message="Background dashboard service is running."
            else
                status="stopped"
                if [[ "$enabled" == "yes" ]]; then
                    message="Background dashboard service is installed and enabled at login, but not currently running."
                else
                    message="Background dashboard service is installed but stopped."
                fi
            fi
        elif [[ "$manager_reachable" == "yes" ]]; then
            status="not-installed"
            message="The dashboard normally runs on demand and does not stay resident. Install the optional background service only if you want it available at all times."
        fi
    fi

    printf 'supported: %s\n' "$supported"
    printf 'manager_reachable: %s\n' "$manager_reachable"
    printf 'installable: %s\n' "$installable"
    printf 'installed: %s\n' "$installed"
    printf 'enabled: %s\n' "$enabled"
    printf 'active: %s\n' "$active"
    printf 'logs_available: %s\n' "$logs_available"
    printf 'status: %s\n' "$status"
    printf 'unit: %s\n' "$DASHBOARD_SERVICE_NAME"
    printf 'unit_file: %s\n' "$DASHBOARD_SERVICE_UNIT_FILE"
    printf 'url: %s\n' "$DASHBOARD_SERVICE_URL"
    printf 'host: %s\n' "$DASHBOARD_SERVICE_HOST"
    printf 'port: %s\n' "$DASHBOARD_SERVICE_PORT"
    printf 'message: %s\n' "$message"
}

dashboard_service_require_support() {
    dashboard_systemctl_available || die "Background dashboard service is available only on systems with systemd user services"
    dashboard_service_manager_reachable || die "systemd user service manager is not reachable in this session"
    dashboard_service_dir_writable || die "dashboard service unit directory is not writable: $DASHBOARD_SERVICE_UNIT_DIR"
}

dashboard_service_require_installed_bin() {
    [[ -x "$DASHBOARD_SERVICE_INSTALLED_BIN" ]] || die "installed dashboard launcher not found: $DASHBOARD_SERVICE_INSTALLED_BIN"
}

dashboard_service_install() {
    dashboard_service_require_support
    dashboard_service_require_installed_bin
    mkdir -p "$DASHBOARD_SERVICE_UNIT_DIR"
    dashboard_service_unit_text >"$DASHBOARD_SERVICE_UNIT_FILE"
    chmod 0644 "$DASHBOARD_SERVICE_UNIT_FILE"
    dashboard_systemctl daemon-reload
    printf 'installed %s\n' "$DASHBOARD_SERVICE_UNIT_FILE"
}

dashboard_service_enable() {
    dashboard_service_require_support
    dashboard_service_installed || die "dashboard service is not installed"
    dashboard_systemctl enable "$DASHBOARD_SERVICE_NAME"
    printf 'enabled %s\n' "$DASHBOARD_SERVICE_NAME"
}

dashboard_service_disable() {
    dashboard_service_require_support
    dashboard_service_installed || die "dashboard service is not installed"
    dashboard_systemctl disable "$DASHBOARD_SERVICE_NAME"
    printf 'disabled %s\n' "$DASHBOARD_SERVICE_NAME"
}

dashboard_service_start() {
    dashboard_service_require_support
    dashboard_service_installed || die "dashboard service is not installed"
    dashboard_systemctl start "$DASHBOARD_SERVICE_NAME"
    printf 'started %s\n' "$DASHBOARD_SERVICE_NAME"
}

dashboard_service_stop() {
    dashboard_service_require_support
    dashboard_service_installed || die "dashboard service is not installed"
    dashboard_systemctl stop "$DASHBOARD_SERVICE_NAME"
    printf 'stopped %s\n' "$DASHBOARD_SERVICE_NAME"
}

dashboard_service_restart() {
    dashboard_service_require_support
    dashboard_service_installed || die "dashboard service is not installed"
    dashboard_systemctl restart "$DASHBOARD_SERVICE_NAME"
    printf 'restarted %s\n' "$DASHBOARD_SERVICE_NAME"
}

dashboard_service_logs() {
    local lines="${1:-100}"
    dashboard_service_require_support
    dashboard_journalctl_available || die "journalctl is required to read dashboard service logs"
    dashboard_journalctl --user -u "$DASHBOARD_SERVICE_NAME" -n "$lines" --no-pager
}

dashboard_service_uninstall() {
    if dashboard_service_manager_reachable && dashboard_service_installed; then
        dashboard_systemctl disable --now "$DASHBOARD_SERVICE_NAME" >/dev/null 2>&1 || true
        dashboard_systemctl reset-failed "$DASHBOARD_SERVICE_NAME" >/dev/null 2>&1 || true
    fi
    dashboard_service_installed || die "dashboard service is not installed"
    rm -f "$DASHBOARD_SERVICE_UNIT_FILE"
    if dashboard_service_manager_reachable; then
        dashboard_systemctl daemon-reload
    fi
    printf 'removed %s\n' "$DASHBOARD_SERVICE_UNIT_FILE"
}

lmm_handoff_command() {
    local action="${1:-status}"
    shift || true

    case "$action" in
        status)
            local json_flag=""
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --json) json_flag="--json"; shift ;;
                    *) shift ;;
                esac
            done
            python3 -c "
import sys, json, os
sys.path.insert(0, os.path.join(os.environ.get('APP_ROOT', '${APP_ROOT:-}'), 'scripts'))
try:
    from lmm_handoff import HandoffSummary, format_handoff_text
    from lmm_storage import JsonRunRecordStore
    state_dir = os.environ.get('XDG_STATE_HOME', os.path.expanduser('~/.local/state'))
    store_path = os.path.join(state_dir, 'llama-server', 'run-records.json')
    store = JsonRunRecordStore(store_path, recent_limit=1)
    records = store.read_recent(limit=1)
    if not records:
        print('No run records found.')
        sys.exit(0)
    record = records[0]
    summary = HandoffSummary.from_run_record(record)
    if '$json_flag':
        print(json.dumps(summary.__dict__, indent=2))
    else:
        print(format_handoff_text(summary))
except ImportError:
    print('Handoff module not available.')
    sys.exit(1)
except Exception as exc:
    print(f'Error reading handoff status: {exc}', file=sys.stderr)
    sys.exit(1)
"
            ;;
        *)
            die "handoff: unknown action '$action'. Use: status"
            ;;
    esac
}

dashboard_service_command() {
    local action="${1:-status}"
    shift || true

    case "$action" in
        install) dashboard_service_install "$@" ;;
        enable) dashboard_service_enable "$@" ;;
        disable) dashboard_service_disable "$@" ;;
        start) dashboard_service_start "$@" ;;
        stop) dashboard_service_stop "$@" ;;
        restart) dashboard_service_restart "$@" ;;
        status) dashboard_service_status ;;
        logs) dashboard_service_logs "$@" ;;
        uninstall|remove) dashboard_service_uninstall ;;
        help|-h|--help)
            printf '%s\n' 'Usage: llama-model dashboard-service install|enable|disable|start|stop|restart|status|logs|uninstall'
            ;;
        *) die "unknown dashboard-service action: $action" ;;
    esac
}

main() {
    local cmd="${1:-}"

    case "$cmd" in
        list)
            shift
            list_models "$@"
            ;;
        show)
            shift
            [[ $# -ge 1 ]] || die "show requires a model alias"
            show_model "$@"
            ;;
        add)
            shift
            [[ $# -ge 2 ]] || die "add requires an alias and model path"
            add_model "$@"
            ;;
        remove)
            shift
            [[ $# -ge 1 ]] || die "remove requires a model alias"
            remove_model "$@"
            ;;
        discover)
            shift
            discover_models "$@"
            ;;
        current)
            shift
            show_current "$@"
            ;;
        doctor)
            shift
            show_doctor "$@"
            ;;
        build-runtime)
            shift
            build_runtime "$@"
            ;;
        mode)
            shift
            show_mode "$@"
            ;;
        set-mode)
            shift
            [[ $# -ge 1 ]] || die "set-mode requires single or multi"
            set_mode "$@"
            ;;
        switch)
            shift
            [[ $# -ge 1 ]] || die "switch requires a model alias or path"
            switch_model "$@"
            ;;
        restart)
            shift
            restart_model "$@"
            ;;
        sync-opencode)
            shift
            sync_opencode "$@"
            ;;
        sync-openclaw)
            shift
            sync_openclaw "$@"
            ;;
        sync-claude)
            shift
            sync_claude "$@"
            ;;
        sync-glyphos)
            shift
            sync_glyphos "$@"
            ;;
        context-mcp)
            shift
            context_mcp_command "$@"
            ;;
        update-check)
            shift
            update_check "$@"
            ;;
        gateway)
            shift
            lmm_gateway_command "$@"
            ;;
        claude-gateway)
            shift
            claude_gateway_command "$@"
            ;;
        download-jobs)
            shift
            download_jobs "$@"
            ;;
        download-cancel)
            shift
            [[ $# -ge 1 ]] || die "download-cancel requires a job id"
            download_cancel "$@"
            ;;
        download-retry)
            shift
            [[ $# -ge 1 ]] || die "download-retry requires a job id"
            download_retry "$@"
            ;;
        stop)
            shift
            stop_server
            printf 'stopped llama-server on port %s\n' "$LLAMA_SERVER_PORT"
            ;;
        logs)
            shift
            show_logs "$@"
            ;;
        dashboard-service)
            shift
            dashboard_service_command "$@"
            ;;
        handoff)
            shift
            lmm_handoff_command "$@"
            ;;
        help|-h|--help|"")
            usage
            ;;
        *)
            die "unknown command: $cmd"
            ;;
    esac
}

if [[ "${BASH_SOURCE[0]}" == "$0" ]]; then
    main "$@"
fi
