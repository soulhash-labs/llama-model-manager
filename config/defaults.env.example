# Leave blank to let llama-model-manager choose a validated bundled runtime
# or an installed external llama-server.
LLAMA_SERVER_BIN=
LLAMA_SERVER_HOST=127.0.0.1
LLAMA_SERVER_PORT=8081
# Leave blank unless you have a matching backend-specific runtime and want a
# specific device such as cuda0 or vulkan0.
LLAMA_SERVER_DEVICE=
LLAMA_SERVER_CONTEXT=128000
# GPU builds can use a large NGL value. CPU fallback forces NGL=0 automatically.
LLAMA_SERVER_NGL=999
LLAMA_SERVER_BATCH=128
LLAMA_SERVER_THREADS=16
# Set to 1 for a single coding harness, or leave empty for auto slots.
LLAMA_SERVER_PARALLEL=1
# Experimental: allow CUDA unified-memory fallback into system RAM when the
# enlarged context / KV / compute reservation path would otherwise exhaust
# VRAM. This can enable larger contexts, but it may be much slower on
# discrete GPUs. Use 1 to enable it, otherwise leave it blank.
GGML_CUDA_ENABLE_UNIFIED_MEMORY=
LLAMA_SERVER_LOG=$HOME/models/llama-server.log
LLAMA_SERVER_WAIT_SECONDS=300
# Optional global extra args passed to every llama-server launch.
LLAMA_SERVER_EXTRA_ARGS=

# Post-switch client sync. OpenCode is enabled by default because it keeps a
# static local model catalog; other clients are opt-in to avoid disrupting
# active coding-agent sessions unless you choose that behavior.
LLAMA_MODEL_SYNC_OPENCODE=1
# When the file exists, sync-opencode also updates oh-my-openagent agents to
# prefer the fast GlyphOS lane with the full GlyphOS lane as fallback.
LLAMA_MODEL_SYNC_OH_MY_OPENAGENT=1
OH_MY_OPENAGENT_CONFIG_FILE=$HOME/.config/opencode/oh-my-openagent.json
LLAMA_MODEL_SYNC_CLAUDE=0
LLAMA_MODEL_SYNC_OPENCLAW=0
LLAMA_MODEL_SYNC_GLYPHOS=0

# Harness routing. Routed mode points OpenAI-compatible clients at the LMM
# gateway first, then through GlyphOS AI Compute to the local llama.cpp backend.
# Use direct only when you explicitly want to bypass Context + GlyphOS.
LLAMA_MODEL_HARNESS_MODE=routed
LLAMA_MODEL_GATEWAY_HOST=127.0.0.1
LLAMA_MODEL_GATEWAY_PORT=4010
LLAMA_MODEL_GATEWAY_LOG=$HOME/models/lmm-gateway.log
LLAMA_MODEL_GATEWAY_FAST_ENABLED=0
LLAMA_MODEL_GATEWAY_FAST_PORT=4011
LLAMA_MODEL_GATEWAY_FAST_LOG=$HOME/models/lmm-gateway-fast.log
LMM_GATEWAY_FAST_CONTEXT_TIMEOUT_MS=500
LMM_GATEWAY_FAST_CONTEXT_STREAM_TIMEOUT_MS=250
GLYPHOS_CONFIG_FILE=$HOME/.glyphos/config.yaml
GLYPHOS_LLAMACPP_TIMEOUT_SECONDS=3600

# Optional update watcher. Disabled by default; notify-only, never auto-installs.
LMM_UPDATE_WATCHER_ENABLED=0
LMM_UPDATE_CHECK_INTERVAL_HOURS=12
LMM_UPDATE_LMM_REPO=soulhash-labs/llama-model-manager
LMM_UPDATE_LLAMACPP_REPO=ggml-org/llama.cpp
LMM_UPDATE_TIMEOUT_SECONDS=5

# Optional OpenClaw profile name. Leave blank for the main profile.
OPENCLAW_PROFILE=
# API key written into the OpenClaw llamacpp provider block.
OPENCLAW_API_KEY=llama-local

# Claude Code local gateway defaults.
CLAUDE_GATEWAY_HOST=127.0.0.1
CLAUDE_GATEWAY_PORT=4000
CLAUDE_GATEWAY_LOG=$HOME/models/claude-gateway.log
# Max seconds the local Claude gateway will wait for a slow upstream llama.cpp
# request before failing. Raise this for long local coding sessions.
CLAUDE_GATEWAY_UPSTREAM_TIMEOUT_SECONDS=1800
# Leave blank to follow the local gateway host and port automatically.
CLAUDE_BASE_URL=
# Leave blank to follow the active registered alias when syncing Claude Code.
CLAUDE_MODEL_ID=
CLAUDE_AUTH_TOKEN=
CLAUDE_API_KEY=
