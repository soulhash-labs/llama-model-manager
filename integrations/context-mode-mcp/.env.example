# Context-Mode-MCP environment variables
#
# Copy this file to .env and adjust as needed, or export the variables
# directly in your shell/profile. The server also accepts --project-root
# as a CLI argument (see --help or --index-project).

# Project root used for context resolution and path policy checks.
# Defaults to process.cwd() if unset.
CTX_PROJECT_ROOT=/path/to/your/project
